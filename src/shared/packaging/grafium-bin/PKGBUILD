# Maintainer: smplOS <os@smpl-os>
#
# AUR-style "-bin" package: repackages the upstream Grafium .deb release asset
# into a native pacman package. Grafium is not in the AUR yet, so smplOS ships
# this PKGBUILD and builds it on-device via smplos-update-apps (which pins
# `pkgver` to the latest GitHub release tag before calling makepkg).
#
# Grafium: local-first knowledge graph & note-taking workspace (Tauri app).
pkgname=grafium-bin
_appname=Grafium
pkgver=0.0.40
pkgrel=1
pkgdesc="Grafium — local-first knowledge graph & note-taking workspace"
arch=('x86_64')
url="https://github.com/KonTy/grafium"
license=('custom')
depends=('webkit2gtk-4.1' 'gtk3')
provides=('grafium')
conflicts=('grafium')
options=('!strip' '!debug')
source=("grafium-${pkgver}.deb::https://github.com/KonTy/grafium/releases/download/v${pkgver}/${_appname}_${pkgver}_amd64.deb")
noextract=("grafium-${pkgver}.deb")
sha256sums=('SKIP')

package() {
  cd "$srcdir"
  # A .deb is an `ar` archive; bsdtar (libarchive) reads it directly.
  # Unpack the container, then extract the data payload into $pkgdir.
  bsdtar -xf "grafium-${pkgver}.deb"
  bsdtar -xf data.tar.* -C "$pkgdir"
}

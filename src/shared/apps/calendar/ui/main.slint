// smplOS Calendar — smpl-calendar
// Two-mode UI:
//   Compact : small month picker (230×500)
//   Details : Teams-style full calendar (1100×700)
//             Left sidebar: mini month + nav
//             Main area: toolbar + 7-col big month grid + slide-in day panel

// ── Window sizes (single source of truth — Rust reads these via global) ───────

export global Sizes {
    out property <float> compact-w: 230;
    out property <float> compact-h: 500;
    out property <float> details-w: 1100;
    out property <float> details-h: 700;
}

// ── Data structures ───────────────────────────────────────────────────────────

struct DayCell {
    day:            int,
    row:            int,
    col:            int,
    is-today:       bool,
    is-selected:    bool,
    has-events:     bool,
    event-count:    int,
    // Adjacent-month cells (padding to fill the 6×7 grid)
    is-other-month: bool,
    month-offset:   int,   // -1 = prev month, 0 = this month, +1 = next month
    // First 3 event display strings (empty string = no event at that slot)
    ev1-id:         int,
    ev1-title:      string,
    ev1-time:       string,
    ev2-id:         int,
    ev2-title:      string,
    ev2-time:       string,
    ev3-id:         int,
    ev3-title:      string,
    ev3-time:       string,
}

struct CalEvent {
    id:               int,
    title:            string,
    description:      string,
    time-label:       string,
    has-recurrence:   bool,
    recurrence-label: string,
    start-hour:       int,
    start-min:        int,
    end-hour:         int,
    end-min:          int,
    all-day:          bool,
    recurrence-idx:   int,
    is-past:          bool,
    // day this event belongs to (1–31), used to filter in the big grid
    day:              int,
}

// ── Theme ─────────────────────────────────────────────────────────────────────

export global Theme {
    in-out property <color>  bg:            #1e1e2e;
    in-out property <color>  fg:            #cdd6f4;
    in-out property <color>  fg-dim:        #a6adc8;
    in-out property <color>  accent:        #89b4fa;
    in-out property <color>  bg-light:      #45475a;
    in-out property <color>  bg-lighter:    #585b70;
    in-out property <color>  danger:        #f38ba8;
    in-out property <color>  success:       #a6e3a1;
    in-out property <color>  warning:       #f9e2af;
    in-out property <color>  info:          #94e2d5;
    in-out property <float>  opacity:       0.92;
    in-out property <length> border-radius: 12px;
}

// ── IconBtn ───────────────────────────────────────────────────────────────────

component IconBtn inherits Rectangle {
    in property <string> icon;
    in property <color>  fg-color:    Theme.fg-dim;
    in property <color>  hover-bg:    Theme.bg-light;
    in property <color>  hover-color: Theme.fg;
    in property <length> icon-size:   15px;
    in property <length> sz:          28px;
    callback clicked();

    width: root.sz; height: root.sz;
    border-radius: root.sz / 2;
    background: ta.has-hover ? root.hover-bg : transparent;
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    Text {
        text: root.icon; color: ta.has-hover ? root.hover-color : root.fg-color;
        font-size: root.icon-size;
        horizontal-alignment: center; vertical-alignment: center;
    }
}

// ── PillBtn ───────────────────────────────────────────────────────────────────

component PillBtn inherits Rectangle {
    in property <string> label;
    in property <color>  bg-normal: Theme.bg-light;
    in property <color>  bg-hover:  Theme.accent;
    in property <color>  fg-normal: Theme.fg;
    in property <color>  fg-hover:  Theme.bg;
    callback clicked();

    height: 30px; border-radius: 8px;
    background: ta.has-hover ? root.bg-hover : root.bg-normal;
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
    HorizontalLayout {
        padding-left: 12px; padding-right: 12px;
        Text {
            text: root.label;
            color: ta.has-hover ? root.fg-hover : root.fg-normal;
            font-size: 12px; font-weight: 600;
            horizontal-alignment: center; vertical-alignment: center;
            min-width: 40px;
        }
    }
}

// ── TimeInput (click-to-type, digits only, validated on Enter / Save) ────────

component TimeInput inherits Rectangle {
    in-out property <int> value: 0;
    in property <int> min-val: 0;
    in property <int> max-val: 59;
    callback changed(int);

    public function commit() {
        root.value = clamp(round(txt.text.to-float()), root.min-val, root.max-val);
        root.changed(root.value);
    }

    width: 40px; height: 32px; border-radius: 6px;
    background: Theme.bg-lighter;
    border-width: txt.has-focus ? 1px : 0px;
    border-color: txt.has-focus ? Theme.accent : transparent;

    txt := TextInput {
        x: 4px; width: parent.width - 8px; height: parent.height;
        text: root.value < 10 ? "0" + root.value : "" + root.value;
        color: Theme.fg; font-size: 14px; font-weight: 600;
        horizontal-alignment: center; vertical-alignment: center;
        single-line: true;
        input-type: InputType.number;
        accepted => { root.commit(); }
    }
}

// ── RecurrencePicker ──────────────────────────────────────────────────────────

component RecurrencePicker inherits Rectangle {
    in-out property <int> selected-idx: 0;
    out property <bool> open: false;
    private property <[string]> options: [
        "Does not repeat","Daily","Weekly","Every 2 weeks","Monthly","Yearly",
    ];

    height: 32px; border-radius: 6px; background: Theme.bg-lighter; clip: false;
    HorizontalLayout {
        padding-left: 10px; padding-right: 6px;
        Text { horizontal-stretch: 1; text: root.options[root.selected-idx];
               color: Theme.fg; font-size: 12px; vertical-alignment: center; }
        Text { text: root.open ? "\u{25B2}" : "\u{25BC}";
               color: Theme.fg-dim; font-size: 9px; vertical-alignment: center; }
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.open = !root.open; } }
    if root.open: Rectangle {
        x: 0px; y: 34px; width: parent.width; height: 6 * 32px;
        border-radius: 6px; background: Theme.bg-lighter;
        drop-shadow-blur: 8px; drop-shadow-color: #00000055; z: 100;
        VerticalLayout {
            for opt[i] in root.options: Rectangle {
                height: 32px; border-radius: 4px;
                background: r.has-hover ? Theme.bg-light
                          : (root.selected-idx == i ? Theme.accent.transparentize(0.7) : transparent);
                r := TouchArea { mouse-cursor: pointer;
                    clicked => { root.selected-idx = i; root.open = false; } }
                Text { x: 10px; text: opt;
                       color: root.selected-idx == i ? Theme.accent : Theme.fg;
                       font-size: 12px; vertical-alignment: center; }
            }
        }
    }
}

// ── ReminderPicker ────────────────────────────────────────────────────────────

component ReminderPicker inherits Rectangle {
    in-out property <int> selected-idx: 0;
    out property <bool> open: false;
    private property <[string]> options: [
        "No reminder","15 minutes before","30 minutes before",
        "1 hour before","8 hours before","24 hours before",
    ];

    height: 32px; border-radius: 6px; background: Theme.bg-lighter; clip: false;
    HorizontalLayout {
        padding-left: 10px; padding-right: 6px;
        Text { horizontal-stretch: 1; text: root.options[root.selected-idx];
               color: Theme.fg; font-size: 12px; vertical-alignment: center; }
        Text { text: root.open ? "\u{25B2}" : "\u{25BC}";
               color: Theme.fg-dim; font-size: 9px; vertical-alignment: center; }
    }
    TouchArea { mouse-cursor: pointer; clicked => { root.open = !root.open; } }
    if root.open: Rectangle {
        x: 0px; y: 34px; width: parent.width; height: 6 * 32px;
        border-radius: 6px; background: Theme.bg-lighter;
        drop-shadow-blur: 8px; drop-shadow-color: #00000055; z: 100;
        VerticalLayout {
            for opt[i] in root.options: Rectangle {
                height: 32px; border-radius: 4px;
                background: r.has-hover ? Theme.bg-light
                          : (root.selected-idx == i ? Theme.accent.transparentize(0.7) : transparent);
                r := TouchArea { mouse-cursor: pointer;
                    clicked => { root.selected-idx = i; root.open = false; } }
                Text { x: 10px; text: opt;
                       color: root.selected-idx == i ? Theme.accent : Theme.fg;
                       font-size: 12px; vertical-alignment: center; }
            }
        }
    }
}

// ── Mini month grid (sidebar + compact) ───────────────────────────────────────

component MiniMonthGrid inherits Rectangle {
    in property <[DayCell]> cells: [];
    callback day-clicked(int);
    // Fired when user clicks a day from the previous (-1) or next (+1) month
    callback other-month-clicked(/* offset */ int, /* day */ int);

    private property <length> cw: 30px;
    private property <length> ch: 28px;

    VerticalLayout {
        spacing: 0px;
        HorizontalLayout {
            for hdr in ["M","T","W","T","F","S","S"]: Rectangle {
                width: root.cw; height: 18px;
                Text { text: hdr; color: Theme.fg-dim; font-size: 10px; font-weight: 600;
                       horizontal-alignment: center; vertical-alignment: center; }
            }
        }
        for ri in [0,1,2,3,4,5]: HorizontalLayout {
            height: root.ch;
            for ci in [0,1,2,3,4,5,6]: Rectangle {
                private property <DayCell> cell: root.cells[ri * 7 + ci];
                width: root.cw; height: root.ch;
                Rectangle {
                    private property <length> csz: 22px;
                    x: (parent.width - csz)/2; y: (parent.height - csz)/2;
                    width: csz; height: csz; border-radius: csz/2;
                    background: cell.day == 0    ? transparent
                              : cell.is-selected ? Theme.accent
                              : cell.is-today    ? Theme.accent.transparentize(0.65)
                              : dt.has-hover     ? Theme.bg-lighter
                              : transparent;
                }
                Text {
                    text: cell.day > 0 ? "" + cell.day : "";
                    color: cell.day == 0       ? transparent
                         : cell.is-selected    ? Theme.bg
                         : cell.is-today       ? Theme.accent
                         : cell.is-other-month ? Theme.fg-dim.transparentize(0.45)
                         : Theme.fg;
                    font-size: 11px;
                    font-weight: (cell.is-today || cell.has-events) ? 700 : 400;
                    horizontal-alignment: center; vertical-alignment: center;
                }
                if cell.has-events && !cell.is-selected && !cell.is-other-month: Rectangle {
                    x: (parent.width - 4px)/2; y: parent.height - 5px;
                    width: 4px; height: 4px; border-radius: 2px;
                    background: cell.is-today ? Theme.bg : Theme.accent;
                }
                dt := TouchArea {
                    visible: cell.day > 0; mouse-cursor: pointer;
                    clicked => {
                        if (cell.is-other-month) {
                            root.other-month-clicked(cell.month-offset, cell.day);
                        } else {
                            root.day-clicked(cell.day);
                        }
                    }
                }
            }
        }
    }
}

// ── Big grid cell (Teams-style) ───────────────────────────────────────────────

component BigDayCell inherits Rectangle {
    in property <DayCell> cell;
    callback cell-clicked(int);
    callback other-month-clicked(/* offset */ int, /* day */ int);
    callback add-clicked(int);
    callback event-clicked(/* day */ int, /* event-id */ int);

    vertical-stretch: 1;
    preferred-height: 0px;
    min-height: 0px;
    border-width: 1px; border-color: Theme.bg-lighter;
    background: cell.is-today    ? Theme.accent.transparentize(0.91)
              : cell.is-selected ? Theme.accent.transparentize(0.82)
              : transparent;
    // Dim adjacent-month cells — they are just context, not the active month
    opacity: cell.is-other-month ? 0.32 : 1.0;
    clip: true;

    // Full-cell click target — covers entire day square
    cell-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            if (root.cell.is-other-month) {
                root.other-month-clicked(root.cell.month-offset, root.cell.day);
            } else if (root.cell.day > 0) {
                root.cell-clicked(root.cell.day);
            }
        }
    }

    VerticalLayout {
        padding: 3px; spacing: 2px;
        alignment: start;

        // Row: day number chip + hover "+" button
        HorizontalLayout {
            height: 22px; spacing: 2px;
            Rectangle {
                width: 22px; height: 22px; border-radius: 11px;
                background: (!cell.is-other-month && cell.is-selected) ? Theme.accent
                          : (!cell.is-other-month && cell.is-today)    ? Theme.accent
                          : transparent;
                Text {
                    text: cell.day > 0 ? "" + cell.day : "";
                    color: (!cell.is-other-month && (cell.is-selected || cell.is-today)) ? Theme.bg
                         : Theme.fg;
                    font-size: 12px; font-weight: 600;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
            Rectangle {
                horizontal-stretch: 1; background: transparent;
            }
            Rectangle {
                width: 18px; height: 18px; border-radius: 9px;
                visible: !cell.is-other-month;
                opacity: cell-ta.has-hover || add-ta.has-hover ? 1.0 : 0.0;
                background: add-ta.has-hover ? Theme.accent : Theme.bg-lighter;
                Text {
                    text: "+"; font-size: 13px; font-weight: 700;
                    color: add-ta.has-hover ? Theme.bg : Theme.fg-dim;
                    horizontal-alignment: center; vertical-alignment: center;
                }
                add-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { if (root.cell.day > 0) { root.add-clicked(root.cell.day); } }
                }
            }
        }

        // Event pills — up to 3, embedded directly in DayCell struct
        if cell.ev1-title != "": Rectangle {
            height: 15px; border-radius: 3px;
            background: ev1-ta.has-hover ? Theme.accent.transparentize(0.35) : Theme.accent.transparentize(0.55);
            ev1-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.event-clicked(root.cell.day, root.cell.ev1-id); }
            }
            Text {
                x: 4px; width: parent.width - 8px; height: parent.height;
                text: cell.ev1-time != "" ? cell.ev1-time + " " + cell.ev1-title : cell.ev1-title;
                color: Theme.fg; font-size: 9px; overflow: elide;
                vertical-alignment: center;
            }
        }
        if cell.ev2-title != "": Rectangle {
            height: 15px; border-radius: 3px;
            background: ev2-ta.has-hover ? Theme.accent.transparentize(0.35) : Theme.accent.transparentize(0.55);
            ev2-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.event-clicked(root.cell.day, root.cell.ev2-id); }
            }
            Text {
                x: 4px; width: parent.width - 8px; height: parent.height;
                text: cell.ev2-time != "" ? cell.ev2-time + " " + cell.ev2-title : cell.ev2-title;
                color: Theme.fg; font-size: 9px; overflow: elide;
                vertical-alignment: center;
            }
        }
        if cell.ev3-title != "": Rectangle {
            height: 15px; border-radius: 3px;
            background: ev3-ta.has-hover ? Theme.accent.transparentize(0.35) : Theme.accent.transparentize(0.55);
            ev3-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.event-clicked(root.cell.day, root.cell.ev3-id); }
            }
            Text {
                x: 4px; width: parent.width - 8px; height: parent.height;
                text: cell.ev3-time != "" ? cell.ev3-time + " " + cell.ev3-title : cell.ev3-title;
                color: Theme.fg; font-size: 9px; overflow: elide;
                vertical-alignment: center;
            }
        }

        if cell.event-count > 3: Text {
            text: "+" + (cell.event-count - 3) + " more";
            color: Theme.fg-dim; font-size: 9px;
        }
    }
}

// ── EventCard (day panel list) ────────────────────────────────────────────────

component EventCard inherits Rectangle {
    in property <CalEvent> ev;
    callback edit-clicked(int);
    callback delete-clicked(int);

    opacity: root.ev.is-past ? 0.5 : 1.0;
    border-radius: 8px;
    background: rt.has-hover || edit-ta.has-hover || del-ta.has-hover
                ? Theme.bg-lighter : Theme.bg-light;
    min-height: 50px;
    rt := TouchArea { mouse-cursor: pointer; clicked => { root.edit-clicked(root.ev.id); } }
    HorizontalLayout {
        padding: 10px; spacing: 8px;
        Rectangle { width: 3px; border-radius: 2px; background: root.ev.is-past ? Theme.fg-dim : Theme.accent; vertical-stretch: 1; }
        VerticalLayout {
            horizontal-stretch: 1; alignment: center; spacing: 2px;
            HorizontalLayout {
                spacing: 6px; alignment: start;
                Text { text: root.ev.title; color: Theme.fg; font-size: 13px; font-weight: 600;
                       overflow: elide; horizontal-stretch: 1; }
                if root.ev.has-recurrence: Text {
                    text: "\u{21BA}"; color: Theme.accent; font-size: 12px; vertical-alignment: center; }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: root.ev.time-label; color: Theme.fg-dim; font-size: 11px; }
                if root.ev.has-recurrence: Text {
                    text: root.ev.recurrence-label; color: Theme.fg-dim; font-size: 11px; }
            }
            if root.ev.description != "": Text {
                text: root.ev.description; color: Theme.fg-dim; font-size: 11px; overflow: elide; }
        }
        VerticalLayout {
            width: 28px;
            alignment: center; spacing: 4px;
            opacity: rt.has-hover || edit-ta.has-hover || del-ta.has-hover ? 1.0 : 0.0;
            Rectangle {
                width: 28px; height: 28px; border-radius: 14px;
                background: edit-ta.has-hover ? Theme.accent.transparentize(0.6) : transparent;
                Text { text: "\u{270E}"; font-size: 15px;
                       color: edit-ta.has-hover ? Theme.accent : Theme.fg-dim;
                       horizontal-alignment: center; vertical-alignment: center; }
                edit-ta := TouchArea { mouse-cursor: pointer; clicked => { root.edit-clicked(root.ev.id); } }
            }
            Rectangle {
                width: 28px; height: 28px; border-radius: 14px;
                background: del-ta.has-hover ? Theme.danger.transparentize(0.6) : transparent;
                Text { text: "\u{2715}"; font-size: 15px;
                       color: del-ta.has-hover ? Theme.danger : Theme.fg-dim;
                       horizontal-alignment: center; vertical-alignment: center; }
                del-ta := TouchArea { mouse-cursor: pointer; clicked => { root.delete-clicked(root.ev.id); } }
            }
        }
    }
}

// ── EventForm (modal dialog, KOrganizer-style) ──────────────────────────────

component EventForm inherits Rectangle {
    in-out property <int>    editing-id:   -1;
    in-out property <string> form-title:   "";
    in-out property <string> form-desc:    "";
    in-out property <int>    form-start-h:  9;
    in-out property <int>    form-start-m:  0;
    in-out property <int>    form-end-h:   10;
    in-out property <int>    form-end-m:    0;
    in-out property <bool>   form-all-day: false;
    in-out property <int>    form-rec-idx:  0;
    in-out property <int>    form-alert-idx: 0;
    in-out property <string> form-date-str: "";
    in-out property <bool>   form-date-invalid: false;
    callback save();
    callback cancel();

    width: 380px;
    border-radius: 12px;
    background: Theme.bg-light;
    drop-shadow-blur: 32px;
    drop-shadow-color: #000000aa;
    clip: true;

    VerticalLayout {
        padding: 0px; spacing: 0px;

        // ── Header ──────────────────────────────────────────────────────
        Rectangle {
            height: 36px;
            background: Theme.bg.transparentize(0.3);

            HorizontalLayout {
                padding-left: 12px; padding-right: 6px;
                Text {
                    text: root.editing-id >= 0 ? "Edit Event" : "New Event";
                    color: Theme.fg; font-size: 15px; font-weight: 700;
                    vertical-alignment: center; horizontal-stretch: 1;
                }
                IconBtn {
                    icon: "\u{2715}"; sz: 28px;
                    hover-bg: Theme.danger.transparentize(0.5); hover-color: Theme.danger;
                    clicked => { root.cancel(); }
                }
            }
        }

        Rectangle { height: 1px; background: Theme.bg-lighter; }

        // ── Form body ───────────────────────────────────────────────────
        VerticalLayout {
            padding: 10px; spacing: 6px; alignment: start;

            // Title
            VerticalLayout {
                spacing: 2px;
                Text { text: "Title"; color: Theme.fg-dim; font-size: 11px; font-weight: 600; }
                Rectangle {
                    height: 30px; border-radius: 6px; background: Theme.bg-lighter;
                    border-width: ti.has-focus ? 1px : 0px; border-color: Theme.accent;
                    ti := TextInput {
                        x: 10px; width: parent.width - 20px; height: parent.height;
                        text <=> root.form-title; color: Theme.fg; font-size: 13px;
                        vertical-alignment: center; single-line: true;
                    }
                }
            }

            // Description
            VerticalLayout {
                spacing: 2px;
                Text { text: "Description"; color: Theme.fg-dim; font-size: 11px; font-weight: 600; }
                Rectangle {
                    height: 48px; border-radius: 6px; background: Theme.bg-lighter;
                    border-width: di.has-focus ? 1px : 0px; border-color: Theme.accent;
                    di := TextInput {
                        x: 10px; y: 6px; width: parent.width - 20px; height: parent.height - 12px;
                        text <=> root.form-desc; color: Theme.fg; font-size: 12px;
                        wrap: word-wrap; single-line: false;
                    }
                }
            }

            // All day toggle
            HorizontalLayout {
                spacing: 8px; alignment: start;
                Rectangle {
                    width: 38px; height: 20px; border-radius: 10px;
                    background: root.form-all-day ? Theme.accent : Theme.bg-lighter;
                    TouchArea { mouse-cursor: pointer; clicked => { root.form-all-day = !root.form-all-day; } }
                    Rectangle {
                        x: root.form-all-day ? 19px : 2px; y: 2px;
                        width: 16px; height: 16px; border-radius: 8px;
                        background: root.form-all-day ? Theme.bg : Theme.fg-dim;
                        animate x { duration: 120ms; easing: ease-in-out; }
                    }
                }
                Text { text: "All day"; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
            }

            // Date
            VerticalLayout {
                spacing: 2px;
                Text { text: "Date"; color: Theme.fg-dim; font-size: 11px; font-weight: 600; }
                Rectangle {
                    height: 30px; border-radius: 6px; background: Theme.bg-lighter;
                    border-width: dti.has-focus ? 1px : 0px;
                    border-color: root.form-date-invalid ? Theme.danger : Theme.accent;
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px;
                        dti := TextInput {
                            height: parent.height;
                            text <=> root.form-date-str;
                            color: root.form-date-invalid ? Theme.danger : Theme.fg;
                            font-size: 13px; font-weight: 600;
                            vertical-alignment: center; single-line: true;
                        }
                    }
                }
                if root.form-date-invalid: Text {
                    text: "Invalid date (use YYYY-MM-DD)";
                    color: Theme.danger; font-size: 10px;
                }
            }

            // Time (hidden when all-day)
            VerticalLayout {
                visible: !root.form-all-day;
                spacing: 4px;

                // Start row
                HorizontalLayout {
                    spacing: 8px; alignment: start;
                    Text {
                        width: 40px;
                        text: "Start:"; color: Theme.fg-dim; font-size: 12px; font-weight: 600;
                        vertical-alignment: center;
                    }
                    sh := TimeInput { value <=> root.form-start-h; max-val: 23; }
                    Text { text: ":"; color: Theme.fg; font-size: 14px; font-weight: 700; vertical-alignment: center; }
                    sm := TimeInput { value <=> root.form-start-m; max-val: 59; }
                }

                // End row
                HorizontalLayout {
                    spacing: 8px; alignment: start;
                    Text {
                        width: 40px;
                        text: "End:"; color: Theme.fg-dim; font-size: 12px; font-weight: 600;
                        vertical-alignment: center;
                    }
                    eh := TimeInput { value <=> root.form-end-h; max-val: 23; }
                    Text { text: ":"; color: Theme.fg; font-size: 14px; font-weight: 700; vertical-alignment: center; }
                    em := TimeInput { value <=> root.form-end-m; max-val: 59; }
                }
            }

            // Recurrence
            VerticalLayout {
                spacing: 2px;
                Text { text: "Repeat"; color: Theme.fg-dim; font-size: 11px; font-weight: 600; }
                RecurrencePicker { selected-idx <=> root.form-rec-idx; }
            }

            // Reminder
            VerticalLayout {
                spacing: 2px;
                Text { text: "Reminder"; color: Theme.fg-dim; font-size: 11px; font-weight: 600; }
                ReminderPicker { selected-idx <=> root.form-alert-idx; }
            }
        }

        Rectangle { height: 1px; background: Theme.bg-lighter; }

        // ── Footer buttons ──────────────────────────────────────────────
        Rectangle {
            height: 40px;
            HorizontalLayout {
                padding-left: 10px; padding-right: 10px; spacing: 8px; alignment: end;
                PillBtn { label: "Cancel"; clicked => { root.cancel(); } }
                PillBtn {
                    label: root.editing-id >= 0 ? "Save" : "Create";
                    bg-normal: Theme.accent; fg-normal: Theme.bg;
                    bg-hover: Theme.accent.darker(0.1); fg-hover: Theme.bg;
                    clicked => {
                        if (!root.form-all-day) {
                            sh.commit(); sm.commit(); eh.commit(); em.commit();
                        }
                        root.save();
                    }
                }
            }
        }
    }
}

// ── Main window ───────────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "Calendar"; no-frame: true;
    background: Theme.bg.transparentize(1.0 - Theme.opacity);
    // Size set from Rust on mode switch — no binding so user can resize freely.
    min-width:  root.is-details ? Sizes.details-w * 1px : Sizes.compact-w * 1px;
    min-height: root.is-details ? Sizes.details-h * 1px : Sizes.compact-h * 1px;

    // State
    in-out property <bool>   is-details:          false;
    in-out property <int>    year:                2026;
    in-out property <int>    month:               3;
    in-out property <string> month-name:          "March 2026";
    in-out property <int>    selected-day:        1;
    in-out property <string> selected-date-label: "Today";

    in-out property <[DayCell]>  day-cells:        [];
    in-out property <[CalEvent]> day-events:        [];

    // Current time tracking (for "now" line in day panel)
    in-out property <bool>   is-today-selected:  false;
    in-out property <int>    current-hour:        0;
    in-out property <int>    current-min:         0;

    in-out property <bool>   show-day-panel:  false;
    in-out property <bool>   show-form:       false;
    in-out property <int>    form-editing-id: -1;
    in-out property <string> form-title:      "";
    in-out property <string> form-desc:       "";
    in-out property <int>    form-start-h:     9;
    in-out property <int>    form-start-m:     0;
    in-out property <int>    form-end-h:       10;
    in-out property <int>    form-end-m:        0;
    in-out property <bool>   form-all-day:    false;
    in-out property <int>    form-rec-idx:      0;
    in-out property <int>    form-alert-idx:    0;
    in-out property <string> form-date-str:     "";
    in-out property <bool>   form-date-invalid: false;

    // Callbacks
    callback prev-month();
    callback next-month();
    callback select-day(int);
    callback open-details();
    callback close-details();
    // Navigate to adjacent month and select a day (for clicking other-month cells)
    callback navigate-to-month-day(/* offset */ int, /* day */ int);
    callback new-event();
    callback edit-event(int);
    callback delete-event(int);
    callback save-event();
    callback cancel-form();
    callback close();
    // Window drag: receives delta (dx, dy) in logical pixels computed from
    // (mouse-x - pressed-x). Rust side calls set_position() to move the window.
    // This works on X11 and Wayland without needing a compositor float rule.
    callback move-window(float, float);
    // Window resize: receives (dx, dy, edge) from edge TouchAreas.
    // edge: 0=top, 1=right, 2=bottom, 3=left, 4=top-left, 5=top-right, 6=bottom-left, 7=bottom-right
    callback resize-window(float, float, int);

    // ══════════════════════════════════════════════════════════════════════════
    // COMPACT VIEW  250 × 390
    // ══════════════════════════════════════════════════════════════════════════
    if !root.is-details: VerticalLayout {
            width: root.width;
            height: root.height;
            padding: 0px; spacing: 0px;

            // Toolbar (drag + buttons only)
            Rectangle {
                height: 36px;
                background: Theme.bg-light.transparentize(0.5);
                clip: true;

                HorizontalLayout {
                    padding-left: 4px; padding-right: 4px; spacing: 2px;

                    // Drag handle
                    Rectangle {
                        horizontal-stretch: 1; background: transparent;
                        TouchArea {
                            mouse-cursor: move;
                            moved => {
                                root.move-window(
                                    (self.mouse-x - self.pressed-x) / 1px,
                                    (self.mouse-y - self.pressed-y) / 1px,
                                );
                            }
                        }
                    }

                    PillBtn {
                        label: "\u{2261}";
                        bg-normal: Theme.accent.transparentize(0.7);
                        bg-hover: Theme.accent;
                        fg-normal: Theme.accent; fg-hover: Theme.bg;
                        clicked => { root.open-details(); }
                    }

                    Rectangle {
                        width: 26px; height: 26px; border-radius: 4px;
                        background: compact-close.has-hover ? Theme.danger : Theme.bg-lighter;
                        Text {
                            width: 100%; height: 100%;
                            text: "\u{2715}"; font-size: 12px;
                            color: compact-close.has-hover ? Theme.bg : Theme.fg;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        compact-close := TouchArea { mouse-cursor: pointer; clicked => { root.close(); } }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.bg-lighter; }

            // Month navigation with label between arrows
            HorizontalLayout {
                height: 28px; padding-left: 4px; padding-right: 4px;
                IconBtn { icon: "\u{276E}"; sz: 24px; clicked => { root.prev-month(); } }
                Text {
                    horizontal-stretch: 1;
                    text: root.month-name; color: Theme.fg;
                    font-size: 12px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                    overflow: elide;
                }
                IconBtn { icon: "\u{276F}"; sz: 24px; clicked => { root.next-month(); } }
            }

            // Mini calendar
            Rectangle {
                x: 6px; width: parent.width - 12px;
                height: 18px + 6 * 28px;
                MiniMonthGrid {
                    width: parent.width; height: parent.height;
                    cells: root.day-cells;
                    day-clicked(d) => { root.select-day(d); }
                    other-month-clicked(offset, day) => {
                        root.navigate-to-month-day(offset, day);
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.bg-lighter; }

            // Selected date header
            HorizontalLayout {
                height: 24px; padding-left: 8px; padding-right: 8px;
                Text {
                    horizontal-stretch: 1;
                    text: root.selected-date-label;
                    color: Theme.fg; font-size: 11px; font-weight: 600;
                    vertical-alignment: center; overflow: elide;
                }
                Text {
                    text: root.day-events.length > 0
                        ? root.day-events.length + " event(s)" : "";
                    color: Theme.fg-dim; font-size: 10px;
                    vertical-alignment: center;
                }
            }

            // Scrollable event list
            Flickable {
                vertical-stretch: 1;
                width: parent.width;
                viewport-width: self.width;

                VerticalLayout {
                    padding-left: 6px; padding-right: 6px;
                    padding-top: 4px; padding-bottom: 6px;
                    spacing: 4px; alignment: start;

                    if root.day-events.length == 0: Text {
                        text: "No events";
                        color: Theme.fg-dim; font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    for ev in root.day-events: Rectangle {
                        border-radius: 6px;
                        background: cev-ta.has-hover ? Theme.bg-lighter : Theme.bg-light;
                        opacity: ev.is-past ? 0.5 : 1.0;
                        height: cev-col.preferred-height + 10px;

                        cev-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.edit-event(ev.id); }
                        }

                        cev-col := VerticalLayout {
                            padding: 5px; spacing: 1px; alignment: center;
                            HorizontalLayout {
                                spacing: 4px;
                                Rectangle {
                                    width: 3px; height: 14px; border-radius: 1px;
                                    background: ev.is-past ? Theme.fg-dim : Theme.accent;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: ev.title; color: Theme.fg;
                                    font-size: 11px; font-weight: 600;
                                    overflow: elide; horizontal-stretch: 1;
                                }
                            }
                            if ev.time-label != "": Text {
                                text: ev.time-label; color: Theme.fg-dim;
                                font-size: 10px;
                                horizontal-alignment: left;
                            }
                        }
                    }
                }
            }

            Rectangle { height: 4px; background: transparent; }
        }

        // ══════════════════════════════════════════════════════════════════════
        // DETAILS VIEW  1100 × 680
        // ══════════════════════════════════════════════════════════════════════
        if root.is-details: HorizontalLayout {
            width: root.width;
            height: root.height;
            padding: 0px; spacing: 0px;

            // ── LEFT SIDEBAR ──────────────────────────────────────────────────
            Rectangle {
                width: 230px;
                background: Theme.bg-light.transparentize(0.6);

                VerticalLayout {
                    padding: 12px; spacing: 10px;

                    // App title / drag zone
                    Rectangle {
                        height: 36px; background: transparent;
                        TouchArea {
                            mouse-cursor: move;
                            moved => {
                                root.move-window(
                                    (self.mouse-x - self.pressed-x) / 1px,
                                    (self.mouse-y - self.pressed-y) / 1px,
                                );
                            }
                        }
                        Text {
                            width: parent.width; height: parent.height;
                            text: "\u{1F4C5}  smpl Calendar";
                            color: Theme.fg; font-size: 14px; font-weight: 700;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { height: 2px; background: transparent; }

                    HorizontalLayout {
                        height: 26px; spacing: 0px;
                        IconBtn { icon: "\u{276E}"; sz: 24px; clicked => { root.prev-month(); } }
                        Text {
                            horizontal-stretch: 1;
                            text: root.month-name; color: Theme.fg;
                            font-size: 12px; font-weight: 700;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        IconBtn { icon: "\u{276F}"; sz: 24px; clicked => { root.next-month(); } }
                    }

                    MiniMonthGrid {
                        cells: root.day-cells;
                        day-clicked(d) => {
                            root.select-day(d);
                            root.show-day-panel = true;
                            root.show-form = false;
                        }
                        other-month-clicked(offset, day) => {
                            root.navigate-to-month-day(offset, day);
                        }
                    }
                }
            }

            // Divider
            Rectangle { width: 1px; background: Theme.bg-lighter; }

            // ── MAIN AREA (pure layout chain — no Rectangle wrappers) ─────────
            VerticalLayout {
                horizontal-stretch: 1;
                padding: 0px; spacing: 0px;

                // Toolbar
                Rectangle {
                    height: 50px;
                    background: Theme.bg-light.transparentize(0.65);

                    HorizontalLayout {
                        padding-left: 12px; padding-right: 8px; spacing: 6px;

                        // Drag handle (fills remaining space)
                        Rectangle {
                            horizontal-stretch: 1; background: transparent;
                            TouchArea {
                                mouse-cursor: move;
                                moved => {
                                    root.move-window(
                                        (self.mouse-x - self.pressed-x) / 1px,
                                        (self.mouse-y - self.pressed-y) / 1px,
                                    );
                                }
                            }
                        }

                        // Collapse to compact
                        Rectangle {
                            width: 26px; height: 26px; border-radius: 4px;
                            background: collapse-ta.has-hover ? Theme.bg-lighter : Theme.bg-light;
                            Text {
                                width: 100%; height: 100%;
                                text: "\u{276C}"; font-size: 12px;
                                color: collapse-ta.has-hover ? Theme.fg : Theme.fg-dim;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            collapse-ta := TouchArea { mouse-cursor: pointer; clicked => { root.close-details(); } }
                        }

                        // Close
                        Rectangle {
                            width: 26px; height: 26px; border-radius: 4px;
                            background: details-close.has-hover ? Theme.danger : Theme.bg-light;
                            Text {
                                width: 100%; height: 100%;
                                text: "\u{2715}"; font-size: 12px;
                                color: details-close.has-hover ? Theme.bg : Theme.fg;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            details-close := TouchArea { mouse-cursor: pointer; clicked => { root.close(); } }
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.bg-lighter; }

                // DOW header
                HorizontalLayout {
                    height: 26px;
                    for hdr in ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]: Rectangle {
                        horizontal-stretch: 1; background: transparent;
                        Text { text: hdr; color: Theme.fg-dim; font-size: 11px; font-weight: 600;
                               horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                Rectangle { height: 1px; background: Theme.bg-lighter; }

                // Big month grid — directly in the VerticalLayout, stretches to fill
                for ri in [0,1,2,3,4,5]: HorizontalLayout {
                    vertical-stretch: 1; preferred-height: 0px; min-height: 0px; spacing: 0px;

                    for ci in [0,1,2,3,4,5,6]: BigDayCell {
                        horizontal-stretch: 1;
                        cell: root.day-cells[ri * 7 + ci];

                        cell-clicked(d) => {
                            root.select-day(d);
                            root.show-day-panel = true;
                            root.show-form = false;
                        }
                        other-month-clicked(offset, day) => {
                            root.navigate-to-month-day(offset, day);
                        }
                        add-clicked(d) => {
                            root.select-day(d);
                            root.new-event();
                            root.show-day-panel = true;
                        }
                        event-clicked(d, id) => {
                            root.selected-day = d;
                            root.edit-event(id);
                        }
                    }
                }
            }
        }

    // ── Day-detail slide-in panel (overlays the main area) ─────────────────
    if root.is-details && root.show-day-panel: Rectangle {
        x: root.width - 310px;
        y: 51px;
        width: 310px;
        height: root.height - 51px;
        background: Theme.bg.transparentize(0.06);
        drop-shadow-blur: 24px;
        drop-shadow-color: #00000077;
        drop-shadow-offset-x: -6px;
        clip: true;

        VerticalLayout {
            padding: 0px; spacing: 0px;

            // Panel header with date + Add button (fixed, never scrolls)
            Rectangle {
                height: 46px;
                background: Theme.bg-light.transparentize(0.4);

                HorizontalLayout {
                    padding-left: 14px; padding-right: 8px; spacing: 6px;
                    Text {
                        horizontal-stretch: 1;
                        text: root.selected-date-label;
                        color: Theme.fg; font-size: 13px; font-weight: 700;
                        vertical-alignment: center; overflow: elide;
                    }
                    PillBtn {
                        label: "+ Add";
                        bg-normal: Theme.accent.transparentize(0.3);
                        bg-hover: Theme.accent;
                        fg-normal: Theme.bg; fg-hover: Theme.bg;
                        clicked => { root.new-event(); }
                    }
                    IconBtn {
                        icon: "\u{2715}"; sz: 26px;
                        hover-bg: Theme.bg-lighter; hover-color: Theme.fg;
                        clicked => { root.show-day-panel = false; root.show-form = false; }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.bg-lighter; }

            Flickable {
                vertical-stretch: 1;
                width: parent.width;
                viewport-width: self.width;

                VerticalLayout {
                    padding: 12px; spacing: 8px; alignment: start;

                    // Empty state
                    if root.day-events.length == 0: VerticalLayout {
                        spacing: 10px; alignment: center;
                        Rectangle { height: 16px; }
                        Text { text: "\u{1F4C5}"; font-size: 28px; horizontal-alignment: center; }
                        Text { text: "No events"; color: Theme.fg-dim; font-size: 12px;
                               horizontal-alignment: center; }
                    }

                    // Event list with "Now" line for today
                    VerticalLayout {
                        spacing: 8px; alignment: start;
                        for ev[idx] in root.day-events: VerticalLayout {
                            spacing: 8px;
                            // Show "Now" line before the first non-past event on today
                            if root.is-today-selected && !ev.is-past && (idx == 0 || root.day-events[idx - 1].is-past): HorizontalLayout {
                                height: 16px; spacing: 6px;
                                padding-left: 4px; padding-right: 4px;
                                Rectangle {
                                    width: 8px; height: 8px; border-radius: 4px;
                                    background: Theme.danger;
                                    y: (parent.height - self.height) / 2;
                                }
                                Rectangle {
                                    horizontal-stretch: 1; height: 2px;
                                    background: Theme.danger;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: (root.current-hour < 10 ? "0" : "") + root.current-hour + ":" + (root.current-min < 10 ? "0" : "") + root.current-min;
                                    color: Theme.danger; font-size: 10px; font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                            EventCard {
                                width: parent.width - 24px;
                                ev: ev;
                                edit-clicked(id) => { root.edit-event(id); }
                                delete-clicked(id) => { root.delete-event(id); }
                            }
                        }
                        // Show "Now" line at the bottom if all events are past
                        if root.is-today-selected && root.day-events.length > 0 && root.day-events[root.day-events.length - 1].is-past: HorizontalLayout {
                            height: 16px; spacing: 6px;
                            padding-left: 4px; padding-right: 4px;
                            Rectangle {
                                width: 8px; height: 8px; border-radius: 4px;
                                background: Theme.danger;
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                horizontal-stretch: 1; height: 2px;
                                background: Theme.danger;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: (root.current-hour < 10 ? "0" : "") + root.current-hour + ":" + (root.current-min < 10 ? "0" : "") + root.current-min;
                                color: Theme.danger; font-size: 10px; font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Keyboard shortcuts ─────────────────────────────────────────────────
    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.show-form) {
                    root.cancel-form();
                } else if (root.show-day-panel) {
                    root.show-day-panel = false;
                } else {
                    root.close();
                }
                return accept;
            }
            return reject;
        }
    }

    // ── Modal event form (centered, blocks interaction behind) ───────────
    if root.show-form: Rectangle {
        x: 0px; y: 0px;
        width: root.width; height: root.height;
        background: #000000aa;
        // Backdrop click = cancel
        TouchArea {
            clicked => { root.cancel-form(); }
        }

        EventForm {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            editing-id   <=> root.form-editing-id;
            form-title   <=> root.form-title;
            form-desc    <=> root.form-desc;
            form-start-h <=> root.form-start-h;
            form-start-m <=> root.form-start-m;
            form-end-h   <=> root.form-end-h;
            form-end-m   <=> root.form-end-m;
            form-all-day <=> root.form-all-day;
            form-rec-idx     <=> root.form-rec-idx;
            form-alert-idx   <=> root.form-alert-idx;
            form-date-str    <=> root.form-date-str;
            form-date-invalid <=> root.form-date-invalid;
            save()   => { root.save-event(); }
            cancel() => { root.cancel-form(); }
        }
    }

    // ── Resize edge handles (sit on top of everything) ─────────────────────
    // Grab zone = 5px on each edge, 10px corners
    // Top
    Rectangle {
        x: 10px; y: 0px; width: root.width - 20px; height: 5px;
        TouchArea { mouse-cursor: n-resize;
            moved => { root.resize-window(0.0, (self.mouse-y - self.pressed-y) / 1px, 0); } }
    }
    // Bottom
    Rectangle {
        x: 10px; y: root.height - 5px; width: root.width - 20px; height: 5px;
        TouchArea { mouse-cursor: s-resize;
            moved => { root.resize-window(0.0, (self.mouse-y - self.pressed-y) / 1px, 2); } }
    }
    // Left
    Rectangle {
        x: 0px; y: 10px; width: 5px; height: root.height - 20px;
        TouchArea { mouse-cursor: w-resize;
            moved => { root.resize-window((self.mouse-x - self.pressed-x) / 1px, 0.0, 3); } }
    }
    // Right
    Rectangle {
        x: root.width - 5px; y: 10px; width: 5px; height: root.height - 20px;
        TouchArea { mouse-cursor: e-resize;
            moved => { root.resize-window((self.mouse-x - self.pressed-x) / 1px, 0.0, 1); } }
    }
    // Top-left corner
    Rectangle {
        x: 0px; y: 0px; width: 10px; height: 10px;
        TouchArea { mouse-cursor: nw-resize;
            moved => { root.resize-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px, 4); } }
    }
    // Top-right corner
    Rectangle {
        x: root.width - 10px; y: 0px; width: 10px; height: 10px;
        TouchArea { mouse-cursor: ne-resize;
            moved => { root.resize-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px, 5); } }
    }
    // Bottom-left corner
    Rectangle {
        x: 0px; y: root.height - 10px; width: 10px; height: 10px;
        TouchArea { mouse-cursor: sw-resize;
            moved => { root.resize-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px, 6); } }
    }
    // Bottom-right corner
    Rectangle {
        x: root.width - 10px; y: root.height - 10px; width: 10px; height: 10px;
        TouchArea { mouse-cursor: se-resize;
            moved => { root.resize-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px, 7); } }
    }
}
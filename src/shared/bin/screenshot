#!/bin/bash
# Screenshot Tool
# Wayland: grim + slurp [+ satty for annotation] | X11: maim + slop
#
# Usage: screenshot [region|window|fullscreen] [edit|quick]
#   edit  (default) — capture then open in satty for annotation before saving
#   quick           — capture, save immediately, copy to clipboard, no editor

SCREENSHOT_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
mkdir -p "$SCREENSHOT_DIR"

FILENAME="$SCREENSHOT_DIR/screenshot-$(date +'%Y-%m-%d_%H-%M-%S').png"
MODE="${1:-region}"
EDIT="${2:-edit}"

do_notify() {
  notify-send "Screenshot saved" "$FILENAME" -i "$FILENAME" -t 3000
}

if [[ -n "$WAYLAND_DISPLAY" ]]; then
  # ── Wayland capture ──
  case "$MODE" in
    region)
      SELECTION=$(slurp 2>/dev/null)
      [[ -z "$SELECTION" ]] && exit 0
      if [[ "$EDIT" == quick ]] || ! command -v satty &>/dev/null; then
        grim -g "$SELECTION" "$FILENAME"
        wl-copy < "$FILENAME" 2>/dev/null
        do_notify
      else
        grim -g "$SELECTION" - | satty --filename - --output-filename "$FILENAME" --copy-command "wl-copy"
      fi
      ;;
    window)
      SELECTION=$(hyprctl activewindow -j 2>/dev/null | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
      if [[ "$EDIT" == quick ]] || ! command -v satty &>/dev/null; then
        grim ${SELECTION:+-g "$SELECTION"} "$FILENAME"
        wl-copy < "$FILENAME" 2>/dev/null
        do_notify
      else
        grim ${SELECTION:+-g "$SELECTION"} - | satty --filename - --output-filename "$FILENAME" --copy-command "wl-copy"
      fi
      ;;
    fullscreen|full)
      if [[ "$EDIT" == quick ]] || ! command -v satty &>/dev/null; then
        grim "$FILENAME"
        wl-copy < "$FILENAME" 2>/dev/null
        do_notify
      else
        grim - | satty --filename - --output-filename "$FILENAME" --copy-command "wl-copy" --fullscreen
      fi
      ;;
    *) echo "Usage: screenshot [region|window|fullscreen] [edit|quick]"; exit 1 ;;
  esac
else
  # ── X11 capture ──
  case "$MODE" in
    region)        maim -s "$FILENAME" || exit 0 ;;
    window)        maim -i "$(xdotool getactivewindow)" "$FILENAME" ;;
    fullscreen|full) maim "$FILENAME" ;;
    *) echo "Usage: screenshot [region|window|fullscreen] [edit|quick]"; exit 1 ;;
  esac
  xclip -selection clipboard -t image/png < "$FILENAME" 2>/dev/null
  do_notify
fi

echo "$FILENAME"

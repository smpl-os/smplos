#!/bin/bash
# window-to-group — move focused window to workspace group N,
# keeping it on the same monitor (stays left on left, stays right on right).
#
# With the grouped-workspace layout (workspace-group), each monitor gets
# its own slot inside every group:
#   right/primary  (index 0) → workspace N
#   left/secondary (index 1) → workspace N + 10
#
# So Super+Shift+3 on the right monitor sends the window to workspace 3,
# while Super+Shift+3 on the left monitor sends it to workspace 13.
# Either way the window ends up in "group 3" on the monitor it started on.
#
# Usage:
#   window-to-group [--silent] N     (N = 1-10)

set -euo pipefail

silent=false
if [[ "${1:-}" == "--silent" ]]; then
    silent=true
    shift
fi
group="${1:-1}"

# ---------------------------------------------------------------------------
# Read workspace limit from bar.conf (default 10 = no limit)
# ---------------------------------------------------------------------------
max_group=10
bar_conf="$HOME/.config/smplos/bar.conf"
if [[ -f "$bar_conf" ]]; then
    # `|| true` so a missing ws_count= line (grep exit 1) doesn't trip
    # set -euo pipefail and silently abort the whole script.
    _ws=$(grep -m1 '^ws_count=' "$bar_conf" 2>/dev/null | cut -d= -f2 || true)
    [[ -n "$_ws" && "$_ws" =~ ^[0-9]+$ ]] && max_group=$_ws
fi
[[ $max_group -lt 1 ]] && max_group=1
[[ $max_group -gt 10 ]] && max_group=10

# Refuse to move to a group beyond the limit — Hyprland only. Under niri the
# slot count is dynamic and the niri branch below has its own range handling.
if [[ -z "${NIRI_SOCKET:-}" ]]; then
    [[ "$group" -gt $max_group ]] && exit 0
fi

# ---------------------------------------------------------------------------
# niri short-circuit (Hyprland code below is unchanged).
#
# On niri there is no "group" mechanic — workspaces are per-output. We map
# group N → the Nth non-scratchpad workspace by sorted idx (matches the
# bar / overview order). See src/shared/bin/workspace-group for rationale.
# ---------------------------------------------------------------------------
if [[ -n "${NIRI_SOCKET:-}" ]] && command -v niri >/dev/null 2>&1; then
    [[ ! "$group" =~ ^[0-9]+$ || $group -lt 1 ]] && exit 0
    mapfile -t real_idx < <(niri msg --json workspaces 2>/dev/null \
        | jq -r '[.[] | select(.name != "scratchpad")] | sort_by(.idx) | .[].idx')
    count=${#real_idx[@]}
    [[ $count -eq 0 ]] && exit 0
    if [[ $group -le $count ]]; then
        idx=${real_idx[$((group - 1))]}
    else
        idx=${real_idx[$((count - 1))]}
    fi
    if $silent; then
        niri msg action move-column-to-workspace --focus false "$idx" >/dev/null 2>&1 || true
    else
        niri msg action move-column-to-workspace "$idx" >/dev/null 2>&1 || true
    fi
    exit 0
fi

# ---------------------------------------------------------------------------
# Read monitors sorted rightmost-first (rightmost = primary, index 0)
# ---------------------------------------------------------------------------
readarray -t monitors < <(
    hyprctl monitors -j 2>/dev/null \
        | jq -r 'sort_by(.x) | reverse | .[].name'
)
n=${#monitors[@]}

# Find current monitor's index in the sorted list
current_mon=$(
    hyprctl monitors -j 2>/dev/null \
        | jq -r '.[] | select(.focused == true) | .name'
)

monitor_index=0
for i in "${!monitors[@]}"; do
    if [[ "${monitors[$i]}" == "$current_mon" ]]; then
        monitor_index=$i
        break
    fi
done

# Target workspace: group slot for this monitor
ws=$(( group + monitor_index * 10 ))

# Dispatch — use the legacy text form, which is valid on Hyprland 0.54.x.
# (The hl.dsp.window.move() Lua API is a 0.55+ addition and returns
# "Invalid dispatcher" on 0.54.2, which silently broke window-to-group.)
if $silent; then
    hyprctl dispatch movetoworkspacesilent "$ws" >/dev/null 2>&1
else
    hyprctl dispatch movetoworkspace "$ws" >/dev/null 2>&1
fi

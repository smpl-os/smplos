#!/bin/bash
# smplOS: Toggle a messenger window — show/hide floating in the bottom-right corner.
# Works for native apps (Signal, Telegram) and webapps (brave-discord, brave-teams).
#
# Usage: toggle-messenger <window-class> [launch-command...]
#
# Behavior:
#   - Window doesn't exist  → launch it (window rules handle positioning)
#   - Window visible         → hide to special:messenger_<class>
#   - Window hidden          → bring back to current workspace, reposition
#
# The window is floated, sized phone-like (480x720), and pinned to bottom-right
# with a gap above the bar.

set -euo pipefail

CLASS="${1:?Usage: toggle-messenger <window-class> [launch-command...]}"
shift
LAUNCH_CMD=("$@")

# Sanitize class for special workspace name (no dots/slashes)
WS_NAME="messenger_${CLASS//[^a-zA-Z0-9_-]/_}"

# Messenger window geometry
WIDTH=480
HEIGHT=720
MARGIN_RIGHT=2
MARGIN_BOTTOM=34  # 30px bar + 2px offset + 2px gap (matches notif-center)

# ============================================================================
# niri branch — short-circuit when running under niri.
#
# niri has no "special workspaces" that auto-hide from overview/alt-tab; we
# use a named workspace "scratchpad" (declared in config.kdl) purely as a
# stash. The user should NEVER feel they're "on the scratchpad" — these
# rules guarantee it:
#
#   1) Window on user's current REAL workspace → hide (move to scratchpad).
#   2) Anywhere else (scratchpad OR other workspace,
#      AND regardless of whether the user is currently focused on
#      scratchpad) → bring window to a REAL workspace and focus there.
#
# Rule 2 has two sub-paths:
#   - If user is currently focused on scratchpad (e.g. they alt-tabbed /
#     overview-clicked into it), first jump to their previous real
#     workspace (focus-workspace-previous), then move the window there.
#   - Otherwise just move the window to their focused workspace.
#
# Result: a single press of Super+Shift+S always puts Signal where you are,
# and a second press always tucks it away. You never get "stranded" on the
# scratchpad.
# ============================================================================
if [[ -n "${NIRI_SOCKET:-}" ]] && command -v niri >/dev/null 2>&1; then
  NIRI_SCRATCH="scratchpad"

  # Find an open window whose app_id matches CLASS (case-insensitive substring).
  win_json=$(niri msg --json windows 2>/dev/null \
    | jq -e --arg c "$CLASS" \
      '[.[] | select((.app_id // "") | ascii_downcase | contains($c | ascii_downcase))] | first // empty' \
    2>/dev/null) || true

  if [[ -z "$win_json" ]]; then
    # Not running → launch it. niri window-rules apply on open.
    if [[ ${#LAUNCH_CMD[@]} -gt 0 ]]; then
      setsid -f "${LAUNCH_CMD[@]}" >/dev/null 2>&1
    else
      name="${CLASS%.desktop}"
      launched=0
      for dir in "$HOME/.local/share/applications" "/usr/local/share/applications" "/usr/share/applications"; do
        if [[ -f "$dir/${name}.desktop" ]]; then
          setsid -f gtk-launch "$name" >/dev/null 2>&1
          launched=1
          break
        fi
      done
      [[ $launched -eq 0 ]] && setsid -f "$CLASS" >/dev/null 2>&1
    fi
    exit 0
  fi

  win_id=$(echo "$win_json" | jq -r '.id')
  win_ws_id=$(echo "$win_json" | jq -r '.workspace_id')

  win_ws_name=$(niri msg --json workspaces \
    | jq -r --argjson i "$win_ws_id" '.[] | select(.id == $i) | .name // ""')

  focused=$(niri msg --json workspaces | jq -c '.[] | select(.is_focused) | {id, name, idx}')
  focused_ws_id=$(echo "$focused" | jq -r '.id')
  focused_ws_name=$(echo "$focused" | jq -r '.name // ""')

  # Helper: resolve a workspace ref (name preferred, idx fallback) for a
  # given focused-json blob into a single token niri accepts.
  _ws_target_from() {
    local blob="$1"
    local n
    n=$(echo "$blob" | jq -r '.name // ""')
    if [[ -n "$n" && "$n" != "null" ]]; then
      printf '%s' "$n"
    else
      echo "$blob" | jq -r '.idx'
    fi
  }

  if [[ "$win_ws_id" == "$focused_ws_id" && "$focused_ws_name" != "$NIRI_SCRATCH" ]]; then
    # Rule 1: visible on user's current real workspace → hide.
    niri msg action move-window-to-workspace --window-id "$win_id" --focus false "$NIRI_SCRATCH" >/dev/null 2>&1 || true
  else
    # Rule 2: bring window to a real workspace where the user is (or will be).
    if [[ "$focused_ws_name" == "$NIRI_SCRATCH" ]]; then
      # User is stranded on scratchpad — escape to previous real workspace first.
      niri msg action focus-workspace-previous >/dev/null 2>&1 || true
      sleep 0.05
      # If history sent us back to scratchpad anyway, pick first non-scratchpad ws.
      new_focused=$(niri msg --json workspaces | jq -c '.[] | select(.is_focused) | {id, name, idx}')
      new_focused_name=$(echo "$new_focused" | jq -r '.name // ""')
      if [[ "$new_focused_name" == "$NIRI_SCRATCH" ]]; then
        # No named workspaces besides scratchpad — pick the first
        # non-scratchpad workspace by idx instead.
        fallback=$(niri msg --json workspaces \
          | jq -r --arg s "$NIRI_SCRATCH" \
            'first(.[] | select(.name != $s) | .idx) // empty')
        if [[ -n "$fallback" ]]; then
          niri msg action focus-workspace "$fallback" >/dev/null 2>&1 || true
          sleep 0.05
          new_focused=$(niri msg --json workspaces | jq -c '.[] | select(.is_focused) | {id, name, idx}')
        fi
      fi
      target=$(_ws_target_from "$new_focused")
    else
      target=$(_ws_target_from "$focused")
    fi
    niri msg action move-window-to-workspace --window-id "$win_id" "$target" >/dev/null 2>&1 || true
  fi
  exit 0
fi

# ============================================================================
# Hyprland branch (original implementation, unchanged below).
# ============================================================================

# Compute pixel position from active monitor
# POS_X / POS_Y  = monitor-relative  (for exec [move ...] and windowrules)
# ABS_X / ABS_Y  = compositor-absolute (for movewindowpixel exact)
POS_X=0
POS_Y=0
ABS_X=0
ABS_Y=0
calc_position() {
  local mon_json cpos cx cy
  cpos=$(hyprctl cursorpos 2>/dev/null); cx=${cpos%,*}; cy=${cpos#*, }
  # Monitor under the cursor (so the window lands on the screen you're using);
  # fall back to the focused monitor, then a 1080p default.
  mon_json=$(hyprctl -j monitors 2>/dev/null | jq -e --argjson cx "${cx:-0}" --argjson cy "${cy:-0}" 'first(.[] | select($cx>=.x and $cx<(.x+.width) and $cy>=.y and $cy<(.y+.height)))' 2>/dev/null) \
    || mon_json=$(hyprctl -j monitors 2>/dev/null | jq -e '.[] | select(.focused)' 2>/dev/null) || {
    # Fallback: assume 1920x1080 at origin
    POS_X=$(( 1920 - WIDTH - MARGIN_RIGHT ))
    POS_Y=$(( 1080 - HEIGHT - MARGIN_BOTTOM ))
    ABS_X=$POS_X
    ABS_Y=$POS_Y
    return 0
  }
  local mon_w mon_h mon_x mon_y scale
  mon_w=$(echo "$mon_json" | jq -r '.width')
  mon_h=$(echo "$mon_json" | jq -r '.height')
  mon_x=$(echo "$mon_json" | jq -r '.x')
  mon_y=$(echo "$mon_json" | jq -r '.y')
  scale=$(echo "$mon_json" | jq -r '.scale')
  # Effective resolution accounts for scaling
  local eff_w eff_h
  eff_w=$(awk "BEGIN { printf \"%d\", ${mon_w}/${scale} }")
  eff_h=$(awk "BEGIN { printf \"%d\", ${mon_h}/${scale} }")
  # Clamp height to fit the monitor (bar gap + 2px top margin); never exceed it.
  local max_h=$(( eff_h - MARGIN_BOTTOM - 2 ))
  (( HEIGHT > max_h )) && HEIGHT=$max_h
  # Monitor-relative position (for exec [move ...] which is relative to the
  # window's monitor).
  POS_X=$(( eff_w - WIDTH - MARGIN_RIGHT ))
  POS_Y=$(( eff_h - HEIGHT - MARGIN_BOTTOM ))
  # Absolute compositor position (for movewindowpixel exact).
  ABS_X=$(( mon_x + POS_X ))
  ABS_Y=$(( mon_y + POS_Y ))
}

# --- Query window state ---
window_json=$(hyprctl -j clients 2>/dev/null \
  | jq -e --arg c "$CLASS" \
    '[.[] | select((.class // "" | test($c; "i")) or (.initialClass // "" | test($c; "i")))] | first // empty' \
  2>/dev/null) || true

if [[ -n "$window_json" ]]; then
  addr=$(echo "$window_json" | jq -r '.address')
  ws_name=$(echo "$window_json" | jq -r '.workspace.name')

  if [[ "$ws_name" == special:* ]]; then
    # Hidden → bring back to the current workspace, floating, bottom-right.
    # Hyprland 0.55 lua mode rejects legacy `hyprctl dispatch` from the CLI;
    # drive the window via the hl.dsp.* lua dispatchers instead.
    calc_position
    cur_ws=$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id')
    hyprctl dispatch "hl.dsp.window.move({window='address:${addr}', workspace='${cur_ws}', silent=false})" >/dev/null 2>&1
    hyprctl dispatch "hl.dsp.window.float({window='address:${addr}', action='enable'})"                    >/dev/null 2>&1
    hyprctl dispatch "hl.dsp.window.resize({window='address:${addr}', x=${WIDTH}, y=${HEIGHT}, exact=true})" >/dev/null 2>&1
    hyprctl dispatch "hl.dsp.window.move({window='address:${addr}', x=${ABS_X}, y=${ABS_Y}})"              >/dev/null 2>&1
    hyprctl dispatch "hl.dsp.focus({window='address:${addr}'})"                                            >/dev/null 2>&1
  else
    # Visible → hide to special workspace
    hyprctl dispatch "hl.dsp.window.move({window='address:${addr}', workspace='special:${WS_NAME}', silent=true})" \
      >/dev/null 2>&1
  fi
else
  # Not running → launch with float rules
  calc_position
  if [[ ${#LAUNCH_CMD[@]} -gt 0 ]]; then
    hyprctl dispatch "hl.dsp.exec_cmd([[${LAUNCH_CMD[*]}]], {float=true, size='${WIDTH} ${HEIGHT}', move='${POS_X} ${POS_Y}'})" \
      >/dev/null 2>&1
  else
    # Try to launch via .desktop file (single-arg mode like focus-or-launch)
    name="${CLASS%.desktop}"
    for dir in "$HOME/.local/share/applications" "/usr/local/share/applications" "/usr/share/applications"; do
      if [[ -f "$dir/${name}.desktop" ]]; then
        hyprctl dispatch "hl.dsp.exec_cmd([[gtk-launch ${name}]], {float=true, size='${WIDTH} ${HEIGHT}', move='${POS_X} ${POS_Y}'})" \
          >/dev/null 2>&1
        exit 0
      fi
    done
    # Last resort: run directly
    hyprctl dispatch "hl.dsp.exec_cmd([[${CLASS}]], {float=true, size='${WIDTH} ${HEIGHT}', move='${POS_X} ${POS_Y}'})" \
      >/dev/null 2>&1
  fi
fi

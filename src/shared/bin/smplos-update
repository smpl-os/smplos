#!/bin/bash
# smplOS: System update -- smplOS files, pacman, AUR, Flatpak, forked apps
# Launched by app-center "Update" buttons or manually.
# Opens in the user's default terminal.
#
# Update order (full mode):
#   1. smplos-os-update   — git pull smplOS repo, sync scripts, run migrations
#   2. pacman -Syu        — general system packages, excluding critical stack
#   3. smplos-update-apps — forked apps from GitHub (smpl-apps, st-smpl, nemo-smpl, micro)
#   4. paru -Sua          — AUR packages, excluding critical stack
#   5. flatpak update     — Flatpak apps
#   6. critical bundle    — optional, explicit kernel/driver/compositor bundle
#
# Critical stack policy is source-controlled in the smplOS repo so App Center
# and CLI both follow the same behavior.

# Parse --mode flag: 'apps' skips kernel/drivers; 'full' is a complete system update
UPDATE_MODE="full"
for arg in "$@"; do
    case "$arg" in
        --mode) ;;
        apps)   UPDATE_MODE="apps" ;;
        full)   UPDATE_MODE="full" ;;
    esac
done

# ── Notification helper ──────────────────────────────────────────────────────
# Never emit the "Cannot autolaunch D-Bus without X11 $DISPLAY" noise when
# there's no session bus (e.g. after pkexec re-execs us as root); always echo
# to stderr too so the message isn't lost.
notify() {
    if command -v notify-send &>/dev/null \
       && [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" || -n "${WAYLAND_DISPLAY:-}" || -n "${DISPLAY:-}" ]]; then
        notify-send "$1" "${2:-}" 2>/dev/null || true
    fi
    echo "smplOS Update: $1${2:+ — $2}" >&2
}

# Resolve our own absolute path — pkexec requires one — regardless of how we
# were invoked (`smplos-update`, `bash smplos-update`, a relative path, …).
SELF="$(readlink -f "$0")"

# ── Presentation mode ────────────────────────────────────────────────────────
# Interactive terminal (CLI: `smplos-update`) → run the update inline, right
#   here in the current terminal (no new window, no D-Bus, no `terminal` binary).
# GUI launch (App Center, no controlling tty) → open a terminal window.
# `[[ -t 1 ]]` still holds after the pkexec re-exec when launched from a tty.
INLINE=0
if [[ -t 1 ]]; then INLINE=1; fi

# GUI mode needs a terminal emulator. Resolve it *before* pkexec — root's PATH
# can't see ~/.local/share/smplos/bin — and carry the path across the sanitized
# environment via SMPLOS_TERMINAL.
TERM_BIN="${SMPLOS_TERMINAL:-}"
if [[ $INLINE -eq 0 && -z "$TERM_BIN" ]]; then
    TERM_BIN="$(command -v terminal 2>/dev/null || true)"
    if [[ -z "$TERM_BIN" ]]; then
        for cand in ghostty foot alacritty kitty wezterm st xterm; do
            command -v "$cand" &>/dev/null && { TERM_BIN="$(command -v "$cand")"; break; }
        done
    fi
    if [[ -z "$TERM_BIN" ]]; then
        notify "smplOS Update" "No terminal emulator found"
        exit 1
    fi
fi

# ── Elevate to root — pkexec prompts on the TTY or via a graphical agent ──────
# pkexec sanitizes the environment, so carry the resolved terminal path across
# it with `env`. No password passing needed; pkexec handles authentication.
if [[ $EUID -ne 0 ]]; then
    exec pkexec /usr/bin/env "SMPLOS_TERMINAL=$TERM_BIN" bash "$SELF" "$@"
fi

UPDATE_SCRIPT=$(mktemp /tmp/smplos-update.XXXXXX.sh)

# Write mode into the script (unquoted heredoc for variable substitution)
cat > "$UPDATE_SCRIPT" << PREAMBLE
#!/bin/bash
UPDATE_MODE="$UPDATE_MODE"
PREAMBLE

# Append the body (single-quoted: no substitution; uses UPDATE_MODE set above)
cat >> "$UPDATE_SCRIPT" << 'EOF'

SMPLOS_PATH="${SMPLOS_PATH:-$HOME/.local/share/smplos}"
POLICY_DIR="$SMPLOS_PATH/repo/src/shared/update-policy"
CRITICAL_LIST_FILE="$POLICY_DIR/critical-packages.txt"
CRITICAL_BUNDLE_FILE="$POLICY_DIR/critical-bundle.conf"
STATE_DIR="$HOME/.local/state/smplos/update"
APPLIED_BUNDLE_FILE="$STATE_DIR/critical-bundle-applied"
BUNDLE_SNAPSHOT_FILE="$STATE_DIR/critical-bundle-versions"

DEFAULT_CRITICAL_PACKAGES=(
    linux linux-lts linux-zen linux-hardened
    linux-headers linux-lts-headers linux-zen-headers linux-hardened-headers
    nvidia nvidia-lts nvidia-dkms nvidia-utils lib32-nvidia-utils
    mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon amdvlk lib32-amdvlk
    xf86-video-amdgpu xf86-video-intel xf86-video-nouveau
    amd-ucode intel-ucode
    grub mkinitcpio mkinitcpio-busybox
    hyprland eww xdg-desktop-portal xdg-desktop-portal-hyprland
    hyprpaper hypridle hyprlock hyprsunset hyprpicker
)

APPS_EXTRA_IGNORE=(pacman libalpm)
CRITICAL_PACKAGES=()
CRITICAL_IGNORE=""
APPS_MODE_IGNORE=""
NETWORK_OK=1

csv_join() {
    local IFS=,
    echo "$*"
}

load_critical_packages() {
    CRITICAL_PACKAGES=("${DEFAULT_CRITICAL_PACKAGES[@]}")

    if [[ -f "$CRITICAL_LIST_FILE" ]]; then
        mapfile -t CRITICAL_PACKAGES < <(
            awk '
                /^[[:space:]]*#/ { next }
                /^[[:space:]]*$/ { next }
                { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); print $0 }
            ' "$CRITICAL_LIST_FILE"
        )
    fi

    if [[ ${#CRITICAL_PACKAGES[@]} -eq 0 ]]; then
        CRITICAL_PACKAGES=("${DEFAULT_CRITICAL_PACKAGES[@]}")
    fi

    CRITICAL_IGNORE=$(csv_join "${CRITICAL_PACKAGES[@]}")
    APPS_MODE_IGNORE=$(csv_join "${CRITICAL_PACKAGES[@]}" "${APPS_EXTRA_IGNORE[@]}")
}

critical_bundle_prompt_and_apply() {
    [[ "$UPDATE_MODE" == "full" ]] || return 0
    [[ -f "$CRITICAL_BUNDLE_FILE" ]] || return 0
    if [[ "$NETWORK_OK" -eq 0 ]]; then
        echo "── Critical bundle ──"
        echo "  Skipped: no internet connection"
        echo
        return 0
    fi

    # shellcheck disable=SC1090
    source "$CRITICAL_BUNDLE_FILE" 2>/dev/null || {
        echo "── Critical bundle ──"
        echo "  WARNING: could not parse critical-bundle.conf"
        echo
        return 0
    }

    local bundle_id="${BUNDLE_ID:-}"
    local bundle_desc="${DESCRIPTION:-Critical stack update}"
    local bundle_reboot="${REBOOT_REQUIRED:-1}"
    local bundle_packages_raw="${PACKAGES:-}"

    [[ -n "$bundle_id" && -n "$bundle_packages_raw" ]] || return 0

    mkdir -p "$STATE_DIR"
    local applied_id=""
    [[ -f "$APPLIED_BUNDLE_FILE" ]] && applied_id=$(<"$APPLIED_BUNDLE_FILE")

    if [[ "$applied_id" == "$bundle_id" ]]; then
        return 0
    fi

    # Split PACKAGES into an array. Elements can be plain package names or
    # pinned specs like "nvidia=570.153.02-1".
    local bundle_packages=()
    read -r -a bundle_packages <<< "$bundle_packages_raw"
    [[ ${#bundle_packages[@]} -gt 0 ]] || return 0

    echo "── Critical bundle ──"
    echo "  Applying $bundle_id: $bundle_desc"
    echo "  Packages: ${bundle_packages[*]}"
    echo
    if sudo pacman -S --noconfirm --needed "${bundle_packages[@]}"; then
        printf '%s\n' "$bundle_id" > "$APPLIED_BUNDLE_FILE"
        : > "$BUNDLE_SNAPSHOT_FILE"
        for spec in "${bundle_packages[@]}"; do
            pkg_name="${spec%%=*}"
            pacman -Q "$pkg_name" 2>/dev/null >> "$BUNDLE_SNAPSHOT_FILE" || true
        done
        echo "  ✓ Critical bundle applied: $bundle_id"
        if [[ "$bundle_reboot" == "1" ]]; then
            # Write reboot-pending marker (boot_id so it self-expires on reboot)
            mkdir -p "$(dirname "$STATE_DIR")/smplos"
            cat /proc/sys/kernel/random/boot_id 2>/dev/null | tr -d '-' \
                > "$STATE_DIR/reboot-pending" || true
            echo "  Reboot required — you will be reminded when you close this window."
        fi
    else
        echo "  WARNING: critical bundle install failed (safe to retry)"
    fi
    echo
}

warn_if_critical_stack_drifted() {
    [[ -f "$BUNDLE_SNAPSHOT_FILE" ]] || return 0

    local drifted=0
    while read -r pkg ver; do
        [[ -n "$pkg" && -n "$ver" ]] || continue
        current=$(pacman -Q "$pkg" 2>/dev/null | awk '{print $2}')
        [[ -n "$current" ]] || continue
        if [[ "$current" != "$ver" ]]; then
            if [[ $drifted -eq 0 ]]; then
                echo "── Critical stack drift detected ──"
                echo "  Critical packages changed outside the managed bundle path:"
            fi
            drifted=1
            echo "  - $pkg: $ver -> $current"
        fi
    done < "$BUNDLE_SNAPSHOT_FILE"

    if [[ $drifted -eq 1 ]]; then
        echo "  A new critical bundle should be applied to restore a known-good stack."
        echo
    fi
}

detect_network() {
    # Best-effort connectivity probe so offline runs skip network steps cleanly.
    if curl -fsSL --connect-timeout 5 --max-time 8 https://archlinux.org >/dev/null 2>&1; then
        NETWORK_OK=1
    else
        NETWORK_OK=0
    fi
}

# Note: We're already running as root (elevated via pkexec),
# so sudo calls are just for safety/compatibility. No password needed.

# Log all output to file for debugging
LOG_DIR="$HOME/.local/state/smplos/update"
LOG_FILE="$LOG_DIR/update-$(date +%Y%m%d-%H%M%S).log"
mkdir -p "$LOG_DIR"

# Create a simple wrapper that tees to both terminal and log
{
    echo "════════════════════════════════════════"
    echo "  smplOS System Update"
    echo "  $(date)"
    echo "════════════════════════════════════════"
    echo

load_critical_packages
detect_network
warn_if_critical_stack_drifted
if [[ "$UPDATE_MODE" == "apps" ]]; then
    echo "══════════════════════════════════════"
    echo "  smplOS App Update"
    echo "  (critical stack preserved)"
    echo "══════════════════════════════════════"
else
    echo "══════════════════════════════════════"
    echo "  smplOS Full System Update"
    echo "  (critical stack via explicit bundle)"
    echo "══════════════════════════════════════"
fi
if [[ "$NETWORK_OK" -eq 0 ]]; then
    echo "  Network check: offline"
    echo "  Network-dependent steps will be skipped with warnings."
fi
echo

# ── Step 1: smplOS system files (git pull + sync scripts + migrations) ───────
# Only in full mode — these aren't "app" updates.
if [[ "$UPDATE_MODE" == "full" ]]; then
    if command -v smplos-os-update &>/dev/null; then
        smplos-os-update 2>&1 || echo "    WARNING: OS file update failed (exit $?)"
    fi
    echo
fi

# ── Step 2: Official repos ───────────────────────────────────────────────────
if [[ "$UPDATE_MODE" == "apps" ]]; then
    echo "── Pacman (apps only) ──"
    if [[ "$NETWORK_OK" -eq 0 ]]; then
        echo "  Skipped: no internet connection"
    elif ! sudo pacman -Syu --noconfirm --ignore "$APPS_MODE_IGNORE"; then
        echo "  WARNING: pacman update failed (check internet/mirrors)"
    fi
else
    echo "── Pacman (excluding critical stack) ──"
    if [[ "$NETWORK_OK" -eq 0 ]]; then
        echo "  Skipped: no internet connection"
    elif ! sudo pacman -Syu --noconfirm --ignore "$CRITICAL_IGNORE"; then
        echo "  WARNING: pacman update failed (check internet/mirrors)"
    fi
fi
echo

# ── Step 4: Forked smplOS apps (GitHub releases) ────────────────────────────
if command -v smplos-update-apps &>/dev/null; then
    echo "── smplOS Apps ──"
    if [[ "$NETWORK_OK" -eq 0 ]]; then
        echo "    Skipped: no internet connection"
    else
        smplos-update-apps 2>&1 || echo "    WARNING: smplOS app update failed"
    fi
    echo
fi

# ── Step 5: AUR packages (paru) — auto-heal if libalpm was bumped ────────────
paru_ok() { paru --version &>/dev/null 2>&1; }
if command -v paru &>/dev/null && ! paru_ok; then
    echo "── Healing paru (libalpm mismatch) ──"
    heal-paru || echo "WARNING: paru heal failed, AUR updates skipped"
    echo
fi
if paru_ok; then
    # Run paru at background CPU/IO priority so AUR compilation (e.g. webkit2gtk,
    # edk2) never starves Hyprland and causes input event drops / apparent
    # keybinding failures. nice -n 10 keeps compile threads below interactive
    # priority; ionice -c 3 (idle) ensures disk I/O doesn't block the compositor.
    _paru_run() {
        if command -v ionice &>/dev/null; then
            nice -n 10 ionice -c 3 paru "$@"
        else
            nice -n 10 paru "$@"
        fi
    }
    if [[ "$UPDATE_MODE" == "apps" ]]; then
        echo "── AUR (apps only, background priority) ──"
        if [[ "$NETWORK_OK" -eq 0 ]]; then
            echo "  Skipped: no internet connection"
        elif ! _paru_run -Sua --noconfirm --sudoloop --ignore "$APPS_MODE_IGNORE"; then
            echo "  WARNING: AUR update failed (check internet/mirrors)"
        fi
    else
        echo "── AUR (excluding critical stack, background priority) ──"
        if [[ "$NETWORK_OK" -eq 0 ]]; then
            echo "  Skipped: no internet connection"
        elif ! _paru_run -Sua --noconfirm --sudoloop --ignore "$CRITICAL_IGNORE"; then
            echo "  WARNING: AUR update failed (check internet/mirrors)"
        fi
    fi
    echo
fi

# ── Step 6: Flatpak (always safe — sandboxed, no kernel interaction) ─────────
if command -v flatpak &>/dev/null; then
    installed=$(flatpak list --app 2>/dev/null | wc -l)
    if [[ "$installed" -gt 0 ]]; then
        echo "── Flatpak ──"
        if [[ "$NETWORK_OK" -eq 0 ]]; then
            echo "  Skipped: no internet connection"
        elif ! flatpak update -y --noninteractive; then
            echo "  WARNING: flatpak update failed (check internet/remotes)"
        fi
        echo
    fi
fi

# ── Step 6: Critical bundle (explicit opt-in) ───────────────────────────────
critical_bundle_prompt_and_apply

# ── Final Hyprland reload ─────────────────────────────────────────────────────
# Reload config after all compilation is done so any state lost during heavy
# CPU load (e.g. paru building webkit2gtk) is cleanly restored.
if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]] && command -v hyprctl &>/dev/null; then
    echo "── Reloading Hyprland ──"
    hyprctl reload 2>/dev/null && echo "  Config reloaded" || echo "  Reload failed (safe to ignore)"
    echo
fi

echo "══════════════════════════════════════"
echo "  Update complete!"
echo "  Log: $LOG_FILE"
echo "══════════════════════════════════════"
echo

# Auto-close terminal after 3 seconds (user can press Ctrl+C to keep it open)
echo "Closing in 3 seconds... (Ctrl+C to cancel)"
sleep 3

# After the terminal closes, fire a reboot notification if needed.
# Running in background so the terminal window can close first.
if [[ -f "$STATE_DIR/reboot-pending" ]] && command -v smplos-reboot-notify &>/dev/null; then
    ( sleep 1; smplos-reboot-notify ) &
    disown
fi
} 2>&1 | tee -a "$LOG_FILE"
EOF
chmod +x "$UPDATE_SCRIPT"

# CLI invocation → run inline in the current terminal; GUI → open a window.
if [[ $INLINE -eq 1 ]]; then
    exec bash "$UPDATE_SCRIPT"
else
    exec "$TERM_BIN" -e "$UPDATE_SCRIPT"
fi

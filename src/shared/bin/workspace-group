#!/bin/bash
# workspace-group — switch ALL monitors to a workspace group simultaneously.
#
# This gives Windows-style virtual desktops: pressing Super+2 moves every
# monitor to "group 2" at once, rather than changing only the focused monitor.
#
# Layout (monitors sorted by X descending, rightmost = primary):
#   right/primary  (index 0) → workspace N
#   left/secondary (index 1) → workspace N + 10
#   third          (index 2) → workspace N + 20   (etc.)
#
# Usage:
#   workspace-group N      absolute group (1-10)
#   workspace-group +N     relative forward
#   workspace-group -N     relative backward
#
# Groups wrap around: group 11 → 1, group 0 → 10.

set -euo pipefail

# ---------------------------------------------------------------------------
# Read workspace limit from bar.conf (default 10 = no limit)
# ---------------------------------------------------------------------------
max_group=10
bar_conf="$HOME/.config/smplos/bar.conf"
if [[ -f "$bar_conf" ]]; then
    # `|| true` so a missing ws_count= line (grep exit 1) doesn't trip
    # set -euo pipefail and silently abort the whole script.
    _ws=$(grep -m1 '^ws_count=' "$bar_conf" 2>/dev/null | cut -d= -f2 || true)
    [[ -n "$_ws" && "$_ws" =~ ^[0-9]+$ ]] && max_group=$_ws
fi
[[ $max_group -lt 1 ]] && max_group=1
[[ $max_group -gt 10 ]] && max_group=10

# ---------------------------------------------------------------------------
# niri short-circuit (Hyprland code below is unchanged).
#
# niri is dynamic — it keeps N+1 workspaces per output (occupied + trailing
# empty). We map "bar dot N" → the Nth non-scratchpad workspace by sorted
# idx. This keeps the bar, the overview order, and Super+N in agreement
# regardless of where the scratchpad sits (named workspaces drift on
# config reload).
#
# Multi-monitor "switch all outputs together" parity with Hyprland would
# need per-output focus-workspace invocations — TODO; for now we focus
# the group on whichever output currently has focus.
# ---------------------------------------------------------------------------
if [[ -n "${NIRI_SOCKET:-}" ]] && command -v niri >/dev/null 2>&1; then
    arg="${1:-1}"
    ws_json=$(niri msg --json workspaces 2>/dev/null) || ws_json='[]'
    mapfile -t real_idx < <(echo "$ws_json" \
        | jq -r '[.[] | select(.name != "scratchpad")] | sort_by(.idx) | .[].idx')
    count=${#real_idx[@]}
    [[ $count -eq 0 ]] && exit 0
    # Under niri the slot count is dynamic — wrap/clamp against the live
    # workspace count, NOT the static bar.conf ws_count.
    niri_max=$count
    # current group = 1-based position of focused workspace in the
    # non-scratchpad list; default to 1 if focused on scratchpad.
    current_group=$(echo "$ws_json" \
        | jq -r '[.[] | select(.name != "scratchpad")] | sort_by(.idx)
                 | (to_entries[] | select(.value.is_focused) | .key + 1) // 1')
    case "$arg" in
        +*) target=$(( current_group + ${arg:1} ))
            # Relative motion wraps (Super+Tab cycling feels right).
            while [[ $target -lt 1 ]];         do target=$(( target + niri_max )); done
            while [[ $target -gt $niri_max ]]; do target=$(( target - niri_max )); done
            ;;
        -*) target=$(( current_group - ${arg:1} ))
            while [[ $target -lt 1 ]];         do target=$(( target + niri_max )); done
            while [[ $target -gt $niri_max ]]; do target=$(( target - niri_max )); done
            ;;
        *)  # Absolute target. Allow any positive number — if it exceeds
            # the live count we fall through to the trailing-empty
            # workspace (niri then appends a new empty after).
            target="$arg"
            [[ ! "$target" =~ ^[0-9]+$ || $target -lt 1 ]] && exit 0
            ;;
    esac
    # Translate bar-dot position → niri workspace idx. If target exceeds
    # the current workspace count, focus the last one (which is the
    # trailing empty — niri will append a new empty after).
    if [[ $target -le $count ]]; then
        idx=${real_idx[$((target - 1))]}
    else
        idx=${real_idx[$((count - 1))]}
    fi
    # No-op when already focused on the target idx — niri's
    # focus-workspace has built-in "back-and-forth" semantics that flip
    # to the previously focused workspace when the target == current,
    # which would otherwise turn Super+1 into a toggle.
    focused_idx=$(echo "$ws_json" | jq -r 'first(.[] | select(.is_focused)) | .idx')
    [[ "$idx" == "$focused_idx" ]] && exit 0
    niri msg action focus-workspace "$idx" >/dev/null 2>&1 || true
    exit 0
fi

# ---------------------------------------------------------------------------
# Read monitors sorted rightmost-first (rightmost = primary, index 0)
# ---------------------------------------------------------------------------
readarray -t monitors < <(
    hyprctl monitors -j 2>/dev/null \
        | jq -r 'sort_by(.x) | reverse | .[].name'
)
n=${#monitors[@]}
[[ $n -eq 0 ]] && exit 1

arg="${1:-1}"

# ---------------------------------------------------------------------------
# Single-monitor fast path — just use plain Hyprland workspace dispatch
# ---------------------------------------------------------------------------
if [[ $n -eq 1 ]]; then
    # Hyprland 0.55+ interprets `hyprctl dispatch` arguments as Lua code
    # (text-based dispatch protocol is gone). Use the hl.dsp.* API.
    case "$arg" in
        +*)
            new_ws=$(( $(hyprctl activeworkspace -j 2>/dev/null | jq '.id') + ${arg:1} ))
            new_group=$(( (new_ws - 1) % 10 + 1 ))
            [[ $new_group -gt $max_group ]] && new_ws=1
            [[ $new_group -lt 1 ]] && new_ws=$max_group
            hyprctl dispatch "hl.dsp.focus({workspace=$new_ws})" >/dev/null 2>&1 ;;
        -*)
            new_ws=$(( $(hyprctl activeworkspace -j 2>/dev/null | jq '.id') - ${arg:1} ))
            new_group=$(( (new_ws - 1) % 10 + 1 ))
            [[ $new_group -lt 1 || $new_ws -lt 1 ]] && new_ws=$max_group
            [[ $new_group -gt $max_group ]] && new_ws=$max_group
            hyprctl dispatch "hl.dsp.focus({workspace=$new_ws})" >/dev/null 2>&1 ;;
        *)
            [[ "$arg" -gt $max_group ]] && exit 0
            hyprctl dispatch "hl.dsp.focus({workspace=$arg})" >/dev/null 2>&1 ;;
    esac
    exit 0
fi

# ---------------------------------------------------------------------------
# Determine current group from primary monitor's active workspace
# ---------------------------------------------------------------------------
primary_ws=$(
    hyprctl monitors -j 2>/dev/null \
        | jq -r 'sort_by(.x) | reverse | .[0].activeWorkspace.id'
)
current_group=$(( (primary_ws - 1) % 10 + 1 ))

# ---------------------------------------------------------------------------
# Parse target group
# ---------------------------------------------------------------------------
case "$arg" in
    +*) target=$(( current_group + ${arg:1} )) ;;
    -*) target=$(( current_group - ${arg:1} )) ;;
    *)  target="$arg" ;;
esac

# Wrap to 1-max_group
while [[ $target -lt 1 ]];          do target=$(( target + max_group )); done
while [[ $target -gt $max_group ]]; do target=$(( target - max_group )); done

# ---------------------------------------------------------------------------
# Switch all monitors — no focusmonitor needed.
#
# Two-step per monitor:
#   1. hyprctl keyword workspace "N, monitor:MON"
#      → registers a persistent workspace rule that always routes workspace N
#        to MON.  Works even for workspaces that have never been visited before.
#   2. hyprctl dispatch workspace N
#      → switches MON to show workspace N (routes to MON because of the rule).
#
# This avoids all focusmonitor race conditions and viewport-snap-back bugs.
# Focus is never disturbed so the user's cursor/window focus is preserved.
# ---------------------------------------------------------------------------
for i in "${!monitors[@]}"; do
    ws=$(( target + i * 10 ))
    mon="${monitors[$i]}"
    hyprctl keyword workspace "$ws, monitor:$mon" >/dev/null 2>&1
    # Hyprland 0.55+ interprets `hyprctl dispatch` arguments as Lua code.
    hyprctl dispatch "hl.dsp.focus({workspace=$ws})" >/dev/null 2>&1
done

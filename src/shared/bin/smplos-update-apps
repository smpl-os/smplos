#!/bin/bash
# smplos-update-apps — Update smplOS custom apps from GitHub releases
#
# Downloads the latest versions of forked/custom apps:
#   - smpl-apps (start-menu, notif-center, settings, app-center, webapp-center, etc.)
#     plus the bundled XR glasses module (xr-workspace, xrctl, xr-game,
#     xr-glasses-hotplugd) which CI folds into the smpl-apps release tarball.
#   - st-smpl (st-wl terminal)
#   - nemo-smpl (file manager)
#   - micro-smpl (text editor with dynamic config reloading)
#   - grafium (knowledge graph / notes GUI — repackaged from upstream .deb into
#     a native pacman package via the OS PKGBUILD, since it's not in the AUR yet)
#
# Each app is only downloaded if a newer version exists on GitHub.
# Version state is tracked in ~/.local/state/smplos/app-versions/
#
# Usage: smplos-update-apps [--check | --quiet]

set -euo pipefail

STATE_DIR="$HOME/.local/state/smplos/app-versions"
SMPLOS_BIN="$HOME/.local/share/smplos/bin"
mkdir -p "$STATE_DIR" "$SMPLOS_BIN"

CHECK_ONLY=0; QUIET=0
for arg in "$@"; do
    case "$arg" in
        --check) CHECK_ONLY=1 ;;
        --quiet) QUIET=1 ;;
        -h|--help)
            echo "Usage: smplos-update-apps [--check | --quiet]"
            exit 0 ;;
    esac
done

# ── Ensure sudo is ready ─────────────────────────────────────────────────────
# When called from smplos-update, SMPLOS_SUDO_READY is set and credentials are
# already cached. When run standalone, authenticate once and start a keepalive.
if [[ "${SMPLOS_SUDO_READY:-0}" != "1" && $CHECK_ONLY -eq 0 ]]; then
    sudo -v || { echo "ERROR: sudo authentication failed" >&2; exit 1; }
    ( while kill -0 $$ 2>/dev/null; do sudo -n -v; sleep 30; done ) &
    _SUDO_PID=$!
    trap 'kill $_SUDO_PID 2>/dev/null' EXIT
fi

# ── Helpers ───────────────────────────────────────────────────────────────────
log()  { [[ $QUIET -eq 0 ]] && echo "  $*" || true; }
ok()   { [[ $QUIET -eq 0 ]] && echo "  \u2713 $*" || true; }
warn() { echo "  \u26a0 $*" >&2; }

_version_gt() {
    local a="${1#v}" b="${2#v}"
    [[ "$a" == "$b" ]] && return 1
    local highest
    highest=$(printf '%s\n%s\n' "$a" "$b" | sort -V | tail -1)
    [[ "$highest" == "$a" ]]
}

_gh_api() {
    local url="$1"
    _gh_json=""
    _gh_json=$(curl -fsSL --connect-timeout 15 --max-time 30 "$url" 2>/dev/null) || return 1
    [[ -n "$_gh_json" ]]
}

_cached_ver() {
    local name="$1"
    [[ -f "$STATE_DIR/$name" ]] && cat "$STATE_DIR/$name" || echo ""
}

n_updated=0

# ── smpl-apps ─────────────────────────────────────────────────────────────────
update_smpl_apps() {
    local cached_ver remote_ver
    cached_ver=$(_cached_ver smpl-apps)

    if ! _gh_api "https://api.github.com/repos/smpl-os/smpl-apps/releases/latest"; then
        warn "smpl-apps: GitHub unreachable"
        return
    fi

    remote_ver=$(echo "$_gh_json" | grep -oP '"tag_name"\s*:\s*"\K[^"]+' || true)
    [[ -z "$remote_ver" ]] && { warn "smpl-apps: could not parse version"; return; }

    if [[ -n "$cached_ver" ]] && ! _version_gt "$remote_ver" "$cached_ver"; then
        ok "smpl-apps: up to date ($cached_ver)"
        return
    fi

    if [[ $CHECK_ONLY -eq 1 ]]; then
        log "smpl-apps: update available ${cached_ver:-none} -> $remote_ver"
        return
    fi

    local tarball_url
    tarball_url=$(echo "$_gh_json" \
        | grep -oP '"browser_download_url"\s*:\s*"\K[^"]*smpl-apps-[^"]*x86_64\.tar\.gz' \
        | head -1 || true)

    if [[ -z "$tarball_url" ]]; then
        warn "smpl-apps: no tarball asset in release $remote_ver"
        return
    fi

    log "smpl-apps: updating ${cached_ver:-none} -> $remote_ver"

    local tmpdir
    tmpdir=$(mktemp -d /tmp/smplos-apps.XXXXXX)
    trap "rm -rf '$tmpdir'" RETURN

    if ! curl -fSL --connect-timeout 30 --retry 3 --progress-bar \
            "$tarball_url" | tar -xz -C "$tmpdir"; then
        warn "smpl-apps: download failed"
        return
    fi

    # Install each binary to /usr/local/bin/ and restart running ones
    local apps=(start-menu notif-center settings app-center webapp-center sync-center-daemon sync-center-gui smpl-calendar smpl-calendar-alertd)
    local restarted=()
    for app in "${apps[@]}"; do
        local src="$tmpdir/$app"
        [[ -f "$src" ]] || continue

        # Check if this app is currently running
        local was_running=0
        if pgrep -x "$app" &>/dev/null; then
            was_running=1
            # Kill gracefully so the new binary can take over
            pkill -x "$app" 2>/dev/null
            sleep 0.3
            # Force-kill if still alive
            pkill -9 -x "$app" 2>/dev/null || true
        fi

        sudo install -m755 "$src" "/usr/local/bin/$app"

        # ── Shadow scrub (single-copy invariant) ─────────────────────────
        # Previously this script also `install -m755` d the binary into
        # ~/.local/share/smplos/bin/, on the theory that dir sits earlier
        # on PATH than /usr/local/bin (envs.conf prepends it) and mirroring
        # the binary there would prevent stale user-local copies from
        # shadowing the canonical install. In practice the mirror IS the
        # shadow — every partial failure (sudo denied, disk full during
        # the second install -m755, script interrupted between the two)
        # left the two copies out of sync, and the ~/.local/share copy
        # silently kept serving old code because it comes first on PATH.
        # This is exactly how ~/.local/share/smplos/bin/smpl-calendar got
        # pinned at v0.7.4 while /usr/local/bin ran v0.8.11 — Eww resolved
        # by bare name, hit the shadow, users saw "the fix did not take".
        # We now DELETE any shadow left behind by previous runs (or by
        # deploy-local.sh) so the /usr/local/bin copy is the only one
        # anything on PATH can find.
        local shadow
        for shadow in \
            "$HOME/.local/share/smplos/bin/$app" \
            "$HOME/.local/bin/$app" \
            "$HOME/bin/$app"
        do
            [[ -e "$shadow" || -L "$shadow" ]] || continue
            rm -f "$shadow" 2>/dev/null || true
        done

        # Restart GUI apps that were running (not daemons — those restart via systemd/autostart)
        if [[ $was_running -eq 1 ]]; then
            case "$app" in
                sync-center-daemon|smpl-calendar-alertd)
                    # Daemon — let systemd or autostart handle restart
                    ;;
                *)
                    nohup "/usr/local/bin/$app" &>/dev/null &
                    disown
                    restarted+=("$app")
                    ;;
            esac
        fi
    done

    # XR glasses module — same story as apps above: canonical install goes to
    # /usr/local/bin only, then scrub the shadow dirs so PATH lookup can't
    # possibly resolve to a stale copy.
    local xr_installed=0 xrbin
    for xrbin in xr-workspace xrctl xr-game xr-glasses-hotplugd; do
        [[ -f "$tmpdir/$xrbin" ]] || continue
        sudo install -m755 "$tmpdir/$xrbin" "/usr/local/bin/$xrbin"
        for shadow in \
            "$HOME/.local/share/smplos/bin/$xrbin" \
            "$HOME/.local/bin/$xrbin" \
            "$HOME/bin/$xrbin"
        do
            [[ -e "$shadow" || -L "$shadow" ]] && rm -f "$shadow" 2>/dev/null || true
        done
        xr_installed=1
    done
    if [[ $xr_installed -eq 1 ]]; then
        log "XR module: binaries updated"
        # Nudge the watcher service so the new build takes effect without a
        # re-login (the unit is config/migration owned; Restart=always covers
        # the rest once ConditionPathExists is satisfied).
        if command -v systemctl &>/dev/null; then
            systemctl --user daemon-reload 2>/dev/null || true
            systemctl --user try-restart xr-glasses.service 2>/dev/null || true
        fi
        # If the renderer is live, swap it for the new build.
        if pgrep -x xr-workspace &>/dev/null; then
            pkill -x xr-workspace 2>/dev/null || true
            command -v xr-glasses-hotplugd &>/dev/null && \
                (xr-glasses-hotplugd --once 2>/dev/null || true)
        fi
    fi

    echo "$remote_ver" > "$STATE_DIR/smpl-apps"
    ok "smpl-apps: updated to $remote_ver"
    [[ ${#restarted[@]} -gt 0 ]] && log "Restarted: ${restarted[*]}"
    ((n_updated++)) || true
}

# ── st-smpl ───────────────────────────────────────────────────────────────────
update_st_smpl() {
    local cached_ver remote_ver
    cached_ver=$(_cached_ver st-smpl)

    if ! _gh_api "https://api.github.com/repos/smpl-os/st-smpl/releases/latest"; then
        warn "st-smpl: GitHub unreachable"
        return
    fi

    remote_ver=$(echo "$_gh_json" | grep -oP '"tag_name"\s*:\s*"\K[^"]+' || true)
    [[ -z "$remote_ver" ]] && { warn "st-smpl: could not parse version"; return; }

    if [[ -n "$cached_ver" ]] && ! _version_gt "$remote_ver" "$cached_ver"; then
        ok "st-smpl: up to date ($cached_ver)"
        return
    fi

    if [[ $CHECK_ONLY -eq 1 ]]; then
        log "st-smpl: update available ${cached_ver:-none} -> $remote_ver"
        return
    fi

    local asset_url
    asset_url=$(echo "$_gh_json" \
        | grep -oP '"browser_download_url"\s*:\s*"\K[^"]*st[^"]*x86_64[^"]*' \
        | head -1 || true)

    if [[ -z "$asset_url" ]]; then
        warn "st-smpl: no binary asset in release $remote_ver"
        return
    fi

    log "st-smpl: updating ${cached_ver:-none} -> $remote_ver"

    local tmpfile
    tmpfile=$(mktemp /tmp/st-wl.XXXXXX)
    trap "rm -f '$tmpfile'" RETURN

    if curl -fSL --connect-timeout 30 --retry 3 --progress-bar \
            "$asset_url" -o "$tmpfile"; then
        sudo install -m755 "$tmpfile" "/usr/local/bin/st-wl"
        # Single-copy invariant: scrub the shadow instead of mirroring the
        # binary into it. See the apps loop above for the full rationale.
        local st_shadow
        for st_shadow in \
            "$HOME/.local/share/smplos/bin/st-wl" \
            "$HOME/.local/bin/st-wl" \
            "$HOME/bin/st-wl"
        do
            [[ -e "$st_shadow" || -L "$st_shadow" ]] && rm -f "$st_shadow" 2>/dev/null || true
        done

        # Also install the matching terminfo so key sequences work correctly.
        # Download from the same release if available; fall back to repo copy.
        local info_url
        info_url=$(echo "$_gh_json" \
            | grep -oP '"browser_download_url"\s*:\s*"\K[^"]*st-wl\.info' \
            | head -1 || true)
        if [[ -n "$info_url" ]]; then
            local tmpinfo
            tmpinfo=$(mktemp /tmp/st-wl-info.XXXXXX)
            if curl -fsSL --connect-timeout 15 "$info_url" -o "$tmpinfo" 2>/dev/null; then
                sudo tic -sx "$tmpinfo" 2>/dev/null || true
                tic -sx "$tmpinfo" 2>/dev/null || true   # user terminfo too
                rm -f "$tmpinfo"
                log "  terminfo updated"
            else
                rm -f "$tmpinfo"
            fi
        fi

        echo "$remote_ver" > "$STATE_DIR/st-smpl"
        ok "st-smpl: updated to $remote_ver"
        ((n_updated++)) || true
    else
        warn "st-smpl: download failed"
    fi
}

# ── nemo-smpl ─────────────────────────────────────────────────────────────────
update_nemo_smpl() {
    local cached_ver remote_ver
    cached_ver=$(_cached_ver nemo-smpl)

    if ! _gh_api "https://api.github.com/repos/smpl-os/nemo-smpl/releases/latest"; then
        warn "nemo-smpl: GitHub unreachable"
        return
    fi

    remote_ver=$(echo "$_gh_json" | grep -oP '"tag_name"\s*:\s*"\K[^"]+' || true)
    [[ -z "$remote_ver" ]] && { warn "nemo-smpl: could not parse version"; return; }

    if [[ -n "$cached_ver" ]] && ! _version_gt "$remote_ver" "$cached_ver"; then
        ok "nemo-smpl: up to date ($cached_ver)"
        return
    fi

    if [[ $CHECK_ONLY -eq 1 ]]; then
        log "nemo-smpl: update available ${cached_ver:-none} -> $remote_ver"
        return
    fi

    local pkg_url
    pkg_url=$(echo "$_gh_json" \
        | grep -oP '"browser_download_url"\s*:\s*"\K[^"]*nemo-smpl-[^"]*x86_64\.pkg\.tar\.zst' \
        | head -1 || true)

    if [[ -z "$pkg_url" ]]; then
        warn "nemo-smpl: no .pkg.tar.zst in release $remote_ver"
        return
    fi

    log "nemo-smpl: updating ${cached_ver:-none} -> $remote_ver"

    local tmpfile
    tmpfile=$(mktemp /tmp/nemo-smpl.XXXXXX.pkg.tar.zst)
    trap "rm -f '$tmpfile'" RETURN

    if curl -fSL --connect-timeout 30 --retry 3 --progress-bar \
            "$pkg_url" -o "$tmpfile"; then
        # If nemo is running, remember so we can restart it after install
        local nemo_was_running=0
        if pgrep -x nemo &>/dev/null; then
            nemo_was_running=1
        fi

        if sudo pacman -U --noconfirm "$tmpfile"; then
            echo "$remote_ver" > "$STATE_DIR/nemo-smpl"
            ok "nemo-smpl: updated to $remote_ver"
            ((n_updated++)) || true

            # Restart nemo if it was running so it picks up the new binary
            if [[ $nemo_was_running -eq 1 ]]; then
                nemo --quit 2>/dev/null || pkill -x nemo 2>/dev/null || true
                sleep 0.5
                pkill -9 -x nemo 2>/dev/null || true
                nohup nemo &>/dev/null &
                disown
                log "  nemo restarted"
            fi
        else
            warn "nemo-smpl: pacman -U failed"
        fi
    else
        warn "nemo-smpl: download failed"
    fi
}

# ── micro-smpl ────────────────────────────────────────────────────────────────
update_micro_smpl() {
    local cached_ver remote_ver
    cached_ver=$(_cached_ver micro-smpl)

    if ! _gh_api "https://api.github.com/repos/smpl-os/micro/releases/latest"; then
        warn "micro-smpl: GitHub unreachable"
        return
    fi

    remote_ver=$(echo "$_gh_json" | grep -oP '"tag_name"\s*:\s*"\K[^"]+' || true)
    [[ -z "$remote_ver" ]] && { warn "micro-smpl: could not parse version"; return; }

    if [[ -n "$cached_ver" ]] && ! _version_gt "$remote_ver" "$cached_ver"; then
        ok "micro-smpl: up to date ($cached_ver)"
        return
    fi

    if [[ $CHECK_ONLY -eq 1 ]]; then
        log "micro-smpl: update available ${cached_ver:-none} -> $remote_ver"
        return
    fi

    local asset_url
    asset_url=$(echo "$_gh_json" \
        | grep -oP '"browser_download_url"\s*:\s*"\K[^"]*micro[^"]*linux64[^"]*\.tar\.gz' \
        | head -1 || true)

    if [[ -z "$asset_url" ]]; then
        warn "micro-smpl: no linux64 tarball in release $remote_ver"
        return
    fi

    log "micro-smpl: updating ${cached_ver:-none} -> $remote_ver"

    local tmpdir
    tmpdir=$(mktemp -d /tmp/micro-smpl.XXXXXX)
    trap "rm -rf '$tmpdir'" RETURN

    if curl -fSL --connect-timeout 30 --retry 3 --progress-bar \
            "$asset_url" | tar -xz -C "$tmpdir"; then
        # The tarball extracts to micro-VERSION/micro
        local micro_bin
        micro_bin=$(find "$tmpdir" -name micro -type f | head -1)
        if [[ -n "$micro_bin" ]]; then
            sudo install -m755 "$micro_bin" "/usr/local/bin/micro"
            # Single-copy invariant: scrub shadows rather than mirror.
            local m_shadow
            for m_shadow in \
                "$HOME/.local/share/smplos/bin/micro" \
                "$HOME/.local/bin/micro" \
                "$HOME/bin/micro"
            do
                [[ -e "$m_shadow" || -L "$m_shadow" ]] && rm -f "$m_shadow" 2>/dev/null || true
            done
            echo "$remote_ver" > "$STATE_DIR/micro-smpl"
            ok "micro-smpl: updated to $remote_ver"
            ((n_updated++)) || true
        else
            warn "micro-smpl: binary not found in tarball"
        fi
    else
        warn "micro-smpl: download failed"
    fi
}

# ── grafium ─────────────────────────────────────────────────────────────────
# Grafium (knowledge graph / note-taking GUI) is not in the AUR yet, so smplOS
# repackages its upstream .deb release asset into a native pacman package
# on-device via a PKGBUILD in the OS repo — pacman-tracked and upgradable, just
# like an AUR "-bin" package. Provides the app-menu entry + icons natively.
update_grafium() {
    local cached_ver remote_ver
    cached_ver=$(_cached_ver grafium)

    if ! _gh_api "https://api.github.com/repos/KonTy/grafium/releases/latest"; then
        warn "grafium: GitHub unreachable"
        return
    fi

    remote_ver=$(echo "$_gh_json" | grep -oP '"tag_name"\s*:\s*"\K[^"]+' || true)
    [[ -z "$remote_ver" ]] && { warn "grafium: could not parse version"; return; }

    if [[ -n "$cached_ver" ]] && ! _version_gt "$remote_ver" "$cached_ver"; then
        ok "grafium: up to date ($cached_ver)"
        return
    fi

    if [[ $CHECK_ONLY -eq 1 ]]; then
        log "grafium: update available ${cached_ver:-none} -> $remote_ver"
        return
    fi

    local pkgbuild_src="$SMPLOS_PATH/repo/src/shared/pkgbuilds/grafium-bin/PKGBUILD"
    if [[ ! -f "$pkgbuild_src" ]]; then
        warn "grafium: PKGBUILD not found ($pkgbuild_src)"
        return
    fi
    if ! command -v makepkg &>/dev/null; then
        warn "grafium: makepkg unavailable (base-devel not installed)"
        return
    fi

    log "grafium: updating ${cached_ver:-none} -> $remote_ver"

    local builddir
    builddir=$(mktemp -d /tmp/grafium-bin.XXXXXX)
    trap "rm -rf '$builddir'" RETURN
    cp "$pkgbuild_src" "$builddir/PKGBUILD"
    # Lock the build to the release we just resolved (prepare() honours this,
    # avoiding a race if a new release lands mid-build). Strip leading 'v'.
    local was_running=0
    pgrep -x grafium &>/dev/null && was_running=1

    # makepkg must run as the user (never root); its -i step uses the cached
    # sudo credentials to pacman -U the freshly built package.
    if ( cd "$builddir" && PKGVER_OVERRIDE="${remote_ver#v}" makepkg -sic --noconfirm ); then
        echo "$remote_ver" > "$STATE_DIR/grafium"
        ok "grafium: updated to $remote_ver"
        ((n_updated++)) || true

        if [[ $was_running -eq 1 ]]; then
            pkill -x grafium 2>/dev/null || true
            sleep 0.5
            pkill -9 -x grafium 2>/dev/null || true
            nohup grafium &>/dev/null &
            disown
            log "  grafium restarted"
        fi
    else
        warn "grafium: build/install failed"
    fi
}

# ── Main ─────────────────────────────────────────────────────────────
[[ $QUIET -eq 0 ]] && echo "── smplOS App Updates ──"

update_smpl_apps
update_st_smpl
update_nemo_smpl
update_micro_smpl
update_grafium

if [[ $CHECK_ONLY -eq 0 && $n_updated -gt 0 ]]; then
    ok "$n_updated app(s) updated"
fi

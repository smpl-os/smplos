#!/bin/bash
# Called by Hyprland bindn on every left click while start-menu is open.
# If the click is outside the start-menu window, dismiss it.

GEOM=$(hyprctl clients -j 2>/dev/null | jq -r '.[] | select(.class == "start-menu") | "\(.at[0]) \(.at[1]) \(.size[0]) \(.size[1])"')
[[ -z "$GEOM" ]] && exit 0

read -r wx wy ww wh <<< "$GEOM"
CURSOR=$(hyprctl cursorpos -j 2>/dev/null | jq -r '"\(.x) \(.y)"')
read -r cx cy <<< "$CURSOR"

if (( cx < wx || cx > wx + ww || cy < wy || cy > wy + wh )); then
    pkill -x start-menu
    # Force a fresh wl_pointer.enter on the bar after the window unmaps.
    # Hyprland 0.55 does not resend enter to the layer surface under a
    # stationary cursor when a toplevel unmaps, so eww-bar buttons go dead
    # until the pointer moves (every Nth click on the start button did
    # nothing). A 1px warp-and-back generates the motion that forces enter.
    # The legacy `dispatch movecursor` used before is silently rejected by
    # the 0.55 lua parser ("... Use eval."); use hl.dsp.cursor.move instead.
    {
        sleep 0.1
        p=$(hyprctl cursorpos 2>/dev/null)
        x=${p%,*}; y=${p#*, }
        x=${x//[[:space:]]/}; y=${y//[[:space:]]/}
        if [[ -n $x && -n $y ]]; then
            hyprctl dispatch "hl.dsp.cursor.move({x=$((x + 1)), y=$y})" >/dev/null 2>&1
            hyprctl dispatch "hl.dsp.cursor.move({x=$x, y=$y})"         >/dev/null 2>&1
        fi
    } &
fi

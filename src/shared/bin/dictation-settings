#!/bin/bash
# Open dictation settings
# Not installed → runs dictation-setup in a new terminal
# Installed     → opens ~/.config/voxtype/config.toml in the default editor

if ! command -v voxtype &>/dev/null; then
    terminal -e bash -c 'dictation-setup; exec bash'
    exit 0
fi

cfg="$HOME/.config/voxtype/config.toml"

terminal -e ${EDITOR:-micro} "$cfg"

#!/bin/bash
# Bar Control Script (EWW)

LOG="/tmp/eww-startup.log"

action="${1:-toggle}"
EWW_CONFIG="$HOME/.config/eww"
BAR_NAME="${2:-bar}"

echo "$(date '+%Y-%m-%d %H:%M:%S') bar-ctl: action=$action bar=$BAR_NAME config=$EWW_CONFIG" >> "$LOG"

if ! command -v eww &>/dev/null; then
    echo "Error: eww not found" | tee -a "$LOG"
    exit 1
fi

# Verify config files exist
for f in eww.yuck eww.scss theme-colors.scss; do
    if [[ ! -f "$EWW_CONFIG/$f" ]]; then
        echo "Warning: $EWW_CONFIG/$f not found" | tee -a "$LOG" >&2
    fi
done

# Ensure EWW listener scripts are executable
find "$EWW_CONFIG/scripts" -name '*.sh' ! -perm -u+x -exec chmod +x {} \; 2>/dev/null

eww_start() {
    if ! pidof eww &>/dev/null; then
        # Kill any orphaned listener scripts from a previous EWW crash/kill
        pkill -f "eww.*scripts/.*\.sh" 2>/dev/null
        pkill -f "socat -u UNIX-CONNECT:.*/hypr/.*\.socket2\.sock" 2>/dev/null
        pkill -f "pactl subscribe" 2>/dev/null
        pkill -f "nmcli monitor" 2>/dev/null
    else
        echo "$(date '+%H:%M:%S') eww already running (pid $(pidof eww))" >> "$LOG"
    fi

    # Let EWW handle daemon spawning itself — running 'eww open' on a
    # non-running daemon auto-starts one. This avoids the race condition
    # where a separate 'eww daemon' + 'eww open' could spawn two daemons
    # if the IPC socket wasn't ready between the two commands.
    echo "$(date '+%H:%M:%S') Opening: $BAR_NAME" >> "$LOG"
    eww --config "$EWW_CONFIG" open "$BAR_NAME" >> "$LOG" 2>&1

    # Apply saved bar settings (workspace count, position, etc.)
    eww_apply

    echo "$(date '+%H:%M:%S') Active windows:" >> "$LOG"
    eww --config "$EWW_CONFIG" active-windows >> "$LOG" 2>&1

    # Start the geometry watcher so the bar recomputes its width whenever the
    # monitor scale/resolution changes (Settings -> Display, hot-plug, etc.).
    if ! pgrep -f "bar-ctl watch" >/dev/null 2>&1; then
        setsid "$0" watch "$BAR_NAME" >/dev/null 2>&1 &
    fi

    # One-shot recompute shortly after boot: the bar may open before the final
    # monitor scale is applied, leaving it centred/too-narrow.  Redrawing once
    # the layout has settled snaps it back to the correct full width.
    ( sleep 2; "$0" redraw "$BAR_NAME" ) >/dev/null 2>&1 &

    echo "$(date '+%H:%M:%S') bar-ctl start complete" >> "$LOG"
}
eww_stop() {
    eww --config "$EWW_CONFIG" close "$BAR_NAME" 2>/dev/null
}

# Force the bar to recompute its geometry (percentage widths are resolved
# against the monitor only at open time, so a close+reopen is the reliable
# way to pick up a new scale/resolution).
eww_redraw() {
    eww --config "$EWW_CONFIG" close "$BAR_NAME" 2>/dev/null
    sleep 0.3
    eww --config "$EWW_CONFIG" open "$BAR_NAME" >> "$LOG" 2>&1
    eww_apply
    echo "$(date '+%H:%M:%S') bar-ctl redraw complete" >> "$LOG"
}

# Background daemon: listen on Hyprland's IPC socket2 and redraw the bar on any
# event that can change the monitor geometry (scale change via config reload,
# monitor hot-plug/unplug).  A short settle delay lets Hyprland finish applying
# the new layout before we recompute.
eww_watch() {
    local sock="${XDG_RUNTIME_DIR}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"
    [[ -S "$sock" ]] || return 0
    command -v socat &>/dev/null || return 0
    echo "$(date '+%H:%M:%S') bar-ctl watch started" >> "$LOG"
    socat -u "UNIX-CONNECT:$sock" - 2>/dev/null \
    | while IFS= read -r line; do
        case "${line%%>>*}" in
            monitoradded|monitoraddedv2|monitorremoved|configreloaded)
                sleep 1
                eww_redraw
                ;;
        esac
    done
}
eww_toggle() {
    eww --config "$EWW_CONFIG" open --toggle "$BAR_NAME"
}
eww_reload() {
    eww --config "$EWW_CONFIG" reload
    # eww reload resets all defvar to defaults — re-apply saved settings
    sleep 0.3
    eww_apply
}

# Apply bar settings from ~/.config/smplos/bar.conf to running EWW instance.
# File format: KEY=VALUE (shell-compatible).  Supported keys:
#   ws_count    = 1-10   (workspace dot count, default 4)
#   ws_position = center | left  (where workspaces live, default center)
eww_apply() {
    local conf="$HOME/.config/smplos/bar.conf"
    local ws_count=4
    local ws_position="center"
    local ws_spacing=1
    local ws_style="numbers"

    if [[ -f "$conf" ]]; then
        while IFS='=' read -r key val; do
            key="${key// /}"
            val="${val// /}"
            [[ -z "$key" || "$key" == \#* ]] && continue
            case "$key" in
                ws_count)    ws_count="$val" ;;
                ws_position) ws_position="$val" ;;
                ws_spacing)  ws_spacing="$val" ;;
                ws_style)    ws_style="$val" ;;
            esac
        done < "$conf"
    fi

    eww --config "$EWW_CONFIG" update ws-count="$ws_count" 2>/dev/null
    eww --config "$EWW_CONFIG" update ws-position="$ws_position" 2>/dev/null
    eww --config "$EWW_CONFIG" update ws-spacing="$ws_spacing" 2>/dev/null
    eww --config "$EWW_CONFIG" update ws-style="$ws_style" 2>/dev/null
    echo "$(date '+%H:%M:%S') bar-ctl apply: ws_count=$ws_count ws_position=$ws_position ws_spacing=$ws_spacing ws_style=$ws_style" >> "$LOG"
}

case "$action" in
    start|open)   eww_start ;;
    stop|close)   eww_stop ;;
    toggle)       eww_toggle ;;
    reload)       eww_reload ;;
    redraw)       eww_redraw ;;
    watch)        eww_watch ;;
    apply)        eww_apply ;;
    *)
        echo "Usage: bar-ctl [start|stop|toggle|reload|redraw|watch|apply] [bar]"
        exit 1
        ;;
esac

#!/bin/bash
# smplOS app cache builder -- indexes .desktop, Flatpak, and AppImage apps
# Outputs: ~/.cache/smplos/app_index (one entry per line)
# Format:  Name;Exec;Category;IconName
# Categories: multimedia,development,graphics,internet,office,apps,settings
# Run on boot via systemd, or on-demand when .desktop files change.

set -euo pipefail

CACHE_DIR="$HOME/.cache/smplos"
CACHE_FILE="$CACHE_DIR/app_index"
CACHE_TMP="$CACHE_FILE.tmp"

mkdir -p "$CACHE_DIR"

# ── Parse a .desktop file into cache format ──
parse_desktop() {
  local file="$1"
  local name="" exec="" icon="" nodisplay="" hidden="" tryexec="" terminal_flag=""
  local in_entry=false categories=""

  while IFS='=' read -r key val; do
    # Only parse the [Desktop Entry] section
    if [[ "$key" == "[Desktop Entry]" ]]; then
      in_entry=true; continue
    elif [[ "$key" == "["* ]]; then
      in_entry=false; continue
    fi
    $in_entry || continue

    case "$key" in
      Name)        [[ -z "$name" ]] && name="$val" ;;
      Exec)        exec="$val" ;;
      Icon)        icon="$val" ;;
      NoDisplay)   nodisplay="$val" ;;
      Hidden)      hidden="$val" ;;
      TryExec)     tryexec="$val" ;;
      Terminal)    terminal_flag="$val" ;;
      Categories)  categories="$val" ;;
    esac
  done < "$file"

  # Skip hidden/nodisplay entries
  [[ "$nodisplay" == "true" || "$hidden" == "true" ]] && return
  [[ -z "$name" || -z "$exec" ]] && return

  # Strip field codes (%u %U %f %F etc.) from Exec
  exec="${exec%% \%*}"

  # Terminal=true entries should launch inside terminal wrapper.
  if [[ "${terminal_flag,,}" == "true" ]]; then
    exec="terminal -e $exec"
  fi

  # Determine category bucket for launcher tabs
  local cat="apps"
  if [[ "$categories" == *"Settings"* ]]; then
    cat="settings"
  elif [[ "$categories" == *"AudioVideo"* || "$categories" == *"Audio"* || "$categories" == *"Video"* || "$categories" == *"Player"* || "$categories" == *"Recorder"* ]]; then
    cat="multimedia"
  elif [[ "$categories" == *"Graphics"* || "$categories" == *"Photography"* || "$categories" == *"RasterGraphics"* || "$categories" == *"VectorGraphics"* || "$categories" == *"2DGraphics"* || "$categories" == *"3DGraphics"* ]]; then
    cat="graphics"
  elif [[ "$categories" == *"Development"* || "$categories" == *"IDE"* || "$categories" == *"Debugger"* || "$categories" == *"Building"* || "$categories" == *"RevisionControl"* || "$categories" == *"GUIDesigner"* || "$categories" == *"Database"* || "$categories" == *"TextEditor"* ]]; then
    cat="development"
  elif [[ "$categories" == *"Office"* || "$categories" == *"WordProcessor"* || "$categories" == *"Spreadsheet"* || "$categories" == *"Presentation"* || "$categories" == *"Calendar"* || "$categories" == *"ContactManagement"* || "$categories" == *"Finance"* ]]; then
    cat="office"
  elif [[ "$categories" == *"Network"* || "$categories" == *"WebBrowser"* || "$categories" == *"Email"* || "$categories" == *"InstantMessaging"* || "$categories" == *"Chat"* || "$categories" == *"IRCClient"* || "$categories" == *"News"* || "$categories" == *"FileTransfer"* || "$categories" == *"P2P"* ]]; then
    cat="internet"
  fi

  printf '%s;%s;%s;%s\n' "$name" "$exec" "$cat" "$icon"
}

# ── Scan all .desktop directories ──
scan_desktop_dirs() {
  local dirs=(
    /usr/share/applications
    /usr/local/share/applications
    "$HOME/.local/share/applications"
  )

  # Include Flatpak export directories
  for fp_dir in /var/lib/flatpak/exports/share/applications \
                "$HOME/.local/share/flatpak/exports/share/applications"; do
    [[ -d "$fp_dir" ]] && dirs+=("$fp_dir")
  done

  for dir in "${dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    # Use -maxdepth 2 for user dir to pick up Wine subdirectories
    local depth_flag=(-maxdepth 1)
    [[ "$dir" == "$HOME/.local/share/applications"* ]] && depth_flag=()
    while IFS= read -r -d '' file; do
      [[ -r "$file" ]] || continue
      parse_desktop "$file"
    done < <(find "$dir" "${depth_flag[@]}" -name '*.desktop' -print0 2>/dev/null)
  done
}

# ── Scan AppImages ──
scan_appimages() {
  local dirs=("$HOME/Applications" "$HOME/AppImages")
  for dir in "${dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r -d '' appimage; do
      local basename
      basename=$(basename "$appimage")
      # Derive human name: strip extension, version suffixes, replace separators
      local name="${basename%.AppImage}"
      name="${name%.appimage}"
      name=$(echo "$name" | sed -E 's/[-_.]/ /g; s/  +/ /g; s/ [0-9]+.*//; s/^ +| +$//g')
      [[ -z "$name" ]] && name="$basename"
      printf '%s;%s;%s;%s\n' "$name" "$appimage" "apps" "application-x-executable"
    done < <(find "$dir" -maxdepth 1 \( -name '*.AppImage' -o -name '*.appimage' \) -executable -print0 2>/dev/null)
  done
}

# ── Settings entries (curated) ──
emit_settings() {
  # Format: Name;Exec;Category;Icon[;1]
  # The optional 5th field '1' marks an entry as search-only:
  #   - shown in search results when the user types a query
  #   - hidden from the settings browse list (only tabs + smpl apps shown there)
  cat <<'EOF'
App Center;toggle-app-center;settings;app-center
Web App Center;webapp-center;settings;webapp-center
Appearance;smplos-settings appearance;settings;preferences-desktop-theme
Display;smplos-settings display;settings;preferences-desktop-display
Keyboard;smplos-settings keyboard;settings;preferences-desktop-keyboard
Network;smplos-settings network;settings;preferences-system-network
Wi-Fi;smplos-settings wifi;settings;network-wireless
Bluetooth;smplos-settings bluetooth;settings;bluetooth
Audio;smplos-settings audio;settings;audio-volume-high
Dictation;smplos-settings dictation;settings;audio-input-microphone
Power;smplos-settings power;settings;preferences-system-power-management
About smplOS;smplos-settings about;settings;help-about
Keybindings;smplos-settings keybindings;settings;preferences-desktop-keyboard
Taskbar;smplos-settings taskbar;settings;preferences-system
EOF

  # ── Search-only card keywords ─────────────────────────────────────────────
  # These entries are NOT shown when browsing the Settings category, but DO
  # appear when the user types a search query. Each uses the deep-link format
  # (settings --tab X --highlight "Label") so the card is highlighted on open.
  cat <<'EOF'
Version;settings --tab about --highlight "Version";settings;help-about;1
Hostname;settings --tab about --highlight "Hostname";settings;help-about;1
Kernel;settings --tab about --highlight "Kernel";settings;help-about;1
Uptime;settings --tab about --highlight "Uptime";settings;help-about;1
Compositor;settings --tab about --highlight "Compositor";settings;help-about;1
Keyboard Layout;settings --tab keyboard --highlight "Keyboard Layout";settings;preferences-desktop-keyboard;1
Input Language;settings --tab keyboard --highlight "Input Language";settings;preferences-desktop-keyboard;1
XKB Layout;settings --tab keyboard --highlight "XKB Layout";settings;preferences-desktop-keyboard;1
Speech to Text;settings --tab dictation --highlight "Speech to Text";settings;audio-input-microphone;1
Whisper;settings --tab dictation --highlight "Whisper";settings;audio-input-microphone;1
Voice Input;settings --tab dictation --highlight "Voice Input";settings;audio-input-microphone;1
Monitor;settings --tab display --highlight "Monitor";settings;preferences-desktop-display;1
Resolution;settings --tab display --highlight "Resolution";settings;preferences-desktop-display;1
Scale;settings --tab display --highlight "Scale";settings;preferences-desktop-display;1
Refresh Rate;settings --tab display --highlight "Refresh Rate";settings;preferences-desktop-display;1
Primary Monitor;settings --tab display --highlight "Primary Monitor";settings;preferences-desktop-display;1
Screen Layout;settings --tab display --highlight "Screen Layout";settings;preferences-desktop-display;1
Power Profile;settings --tab power --highlight "Power Profile";settings;preferences-system-power-management;1
Power Saver;settings --tab power --highlight "Power Saver";settings;preferences-system-power-management;1
Sleep;settings --tab power --highlight "Sleep";settings;preferences-system-power-management;1
Suspend;settings --tab power --highlight "Suspend";settings;preferences-system-power-management;1
Lock Screen;settings --tab power --highlight "Lock Screen";settings;preferences-system-power-management;1
Shut Down;settings --tab power --highlight "Shut Down";settings;preferences-system-power-management;1
Restart;settings --tab power --highlight "Restart";settings;preferences-system-power-management;1
Log Out;settings --tab power --highlight "Log Out";settings;preferences-system-power-management;1
Keyboard Shortcuts;settings --tab keybindings --highlight "Keyboard Shortcuts";settings;preferences-desktop-keyboard;1
Hotkeys;settings --tab keybindings --highlight "Hotkeys";settings;preferences-desktop-keyboard;1
Key Binding;settings --tab keybindings --highlight "Key Binding";settings;preferences-desktop-keyboard;1
Workspaces;settings --tab taskbar --highlight "Workspaces";settings;preferences-system;1
Workspace Count;settings --tab taskbar --highlight "Workspace Count";settings;preferences-system;1
Workspace Style;settings --tab taskbar --highlight "Workspace Style";settings;preferences-system;1
Bar;settings --tab taskbar --highlight "Bar";settings;preferences-system;1
WiFi;settings --tab wifi --highlight "WiFi";settings;network-wireless;1
Wireless;settings --tab wifi --highlight "Wireless";settings;network-wireless;1
Connect Wi-Fi;settings --tab wifi --highlight "Connect Wi-Fi";settings;network-wireless;1
Wi-Fi Password;settings --tab wifi --highlight "Wi-Fi Password";settings;network-wireless;1
Airplane Mode;settings --tab wifi --highlight "Airplane Mode";settings;network-wireless;1
QR Code Wi-Fi;settings --tab wifi --highlight "QR Code Wi-Fi";settings;network-wireless;1
Bluetooth Devices;settings --tab bluetooth --highlight "Bluetooth Devices";settings;bluetooth;1
Pair Bluetooth;settings --tab bluetooth --highlight "Pair Bluetooth";settings;bluetooth;1
Connect Bluetooth;settings --tab bluetooth --highlight "Connect Bluetooth";settings;bluetooth;1
Headphones;settings --tab bluetooth --highlight "Headphones";settings;bluetooth;1
Discoverable;settings --tab bluetooth --highlight "Discoverable";settings;bluetooth;1
EOF
}

# ── Merge deep-link entries from settings app index ──
# The settings binary writes a per-card search index to settings_index.
# Each line:  Label;settings --tab X --highlight "Label";settings;
# We convert to app_index format with an icon derived from the tab name,
# and mark every entry as search-only (;1).
merge_settings_deep_links() {
  local idx="$CACHE_DIR/settings_index"
  [[ -f "$idx" ]] || return 0

  while IFS=';' read -r name exec _cat _rest; do
    [[ -z "$name" || -z "$exec" ]] && continue
    local icon="preferences-system"
    case "$exec" in
      *"--tab about"*)       icon="help-about" ;;
      *"--tab keyboard"*)    icon="preferences-desktop-keyboard" ;;
      *"--tab dictation"*)   icon="audio-input-microphone" ;;
      *"--tab display"*)     icon="preferences-desktop-display" ;;
      *"--tab power"*)       icon="preferences-system-power-management" ;;
      *"--tab keybindings"*) icon="preferences-desktop-keyboard" ;;
      *"--tab taskbar"*)     icon="preferences-system" ;;
      *"--tab wifi"*)        icon="network-wireless" ;;
      *"--tab bluetooth"*)   icon="bluetooth" ;;
    esac
    printf '%s;%s;%s;%s;1\n' "$name" "$exec" "settings" "$icon"
  done < "$idx"
}

# ── Build cache ──
# Browsable category entries come first so they win the awk dedup (first
# occurrence of each Name, case-insensitive).  Deep-link search-only entries
# follow and fill in any additional keywords.
{
  scan_desktop_dirs
  scan_appimages
  emit_settings
  merge_settings_deep_links
} | sort -s -t';' -k1,1 -f | awk -F';' '!seen[tolower($1)]++' > "$CACHE_TMP"

mv -f "$CACHE_TMP" "$CACHE_FILE"

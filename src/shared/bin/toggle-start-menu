#!/bin/bash
# Toggle smplOS Start Menu.
#
# Click-outside-to-dismiss is handled by a permanent non-consuming bind
# in hypr/popup_watchers.lua (→ popup-click-check). We do NOT manipulate
# binds at runtime: Hyprland 0.55+ rejects `hyprctl keyword bindn/unbind`
# with "keyword can't work with non-legacy parsers. Use eval." — silent
# failure that left the menu only dismissable via Esc.

APP_NAME="start-menu"
BIN_PATH="/usr/local/bin/$APP_NAME"
[[ -f "$BIN_PATH" ]] || BIN_PATH="$HOME/Documents/sources/smplos/src/shared/apps/start-menu/target/release/$APP_NAME"

if pkill -x "$APP_NAME" 2>/dev/null; then
    : # was running, now closed
else
    "$BIN_PATH" &
    disown
fi

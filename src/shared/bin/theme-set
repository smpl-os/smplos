#!/bin/bash
# smplOS Theme Switcher
# Sets the active theme and regenerates all configs
# Usage: theme-set <theme-name>

if [[ -z $1 ]]; then
  echo "Usage: theme-set <theme-name>"
  exit 1
fi

SMPLOS_PATH="${SMPLOS_PATH:-$HOME/.local/share/smplos}"
CURRENT_THEME_PATH="$HOME/.config/smplos/current/theme"
NEXT_THEME_PATH="$HOME/.config/smplos/current/next-theme"
USER_THEMES_PATH="$HOME/.config/smplos/themes"
STOCK_THEMES_PATH="$SMPLOS_PATH/themes"

resolve_theme_path() {
  local name="$1"
  if [[ -d "$USER_THEMES_PATH/$name" ]]; then
    echo "$USER_THEMES_PATH/$name"
  elif [[ -d "$STOCK_THEMES_PATH/$name" ]]; then
    echo "$STOCK_THEMES_PATH/$name"
  else
    return 1
  fi
}

toml_get() {
  local file="$1" key="$2"
  grep -E "^${key}[[:space:]]*=" "$file" 2>/dev/null | head -1 | sed 's/.*"\([^"]*\)".*/\1/'
}

# Normalize theme name: strip markup, lowercase, spaces to hyphens
THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

# Resolve theme path (user themes take precedence)
if ! THEME_PATH="$(resolve_theme_path "$THEME_NAME")"; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next-theme directory (atomic swap)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy all theme files (colors, configs, backgrounds, etc.)
# Each theme ships pre-baked configs — no template expansion needed
cp -r "$THEME_PATH/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Atomic swap: next-theme -> current theme
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" > "$HOME/.config/smplos/current/theme.name"

# Link EWW theme colors into EWW config dir
if [[ -f "$CURRENT_THEME_PATH/eww-colors.scss" ]]; then
  mkdir -p "$HOME/.config/eww"
  cp "$CURRENT_THEME_PATH/eww-colors.scss" "$HOME/.config/eww/theme-colors.scss"
fi

# Bake theme colors into SVG icon templates
# Templates in icons/status/ have {{accent}} and {{fg-dim}} placeholders
# We re-copy from source and replace with actual hex values each theme switch
_accent=$(grep '^accent' "$CURRENT_THEME_PATH/colors.toml" 2>/dev/null | head -1 | sed 's/.*"\(#[^"]*\)".*/\1/')
_fg=$(grep '^foreground' "$CURRENT_THEME_PATH/colors.toml" 2>/dev/null | head -1 | sed 's/.*"\(#[^"]*\)".*/\1/')
_bg=$(grep '^background' "$CURRENT_THEME_PATH/colors.toml" 2>/dev/null | head -1 | sed 's/.*"\(#[^"]*\)".*/\1/')
_fg=${_fg:-#888888}
_accent=${_accent:-#888888}
_bg=${_bg:-#1e1e2e}
EWW_ICONS_TPL="$HOME/.local/share/smplos/icons/status"
EWW_ICONS_DST="$HOME/.config/eww/icons/status"
if [[ -d "$EWW_ICONS_TPL" ]]; then
  mkdir -p "$EWW_ICONS_DST"
  for svg in "$EWW_ICONS_TPL"/*.svg; do
    [[ -f "$svg" ]] || continue
    sed "s/{{accent}}/$_accent/g; s/{{fg}}/$_fg/g; s/{{bg}}/$_bg/g" "$svg" > "$EWW_ICONS_DST/$(basename "$svg")"
  done
fi

# Compositor-specific theme configs
# Always copy if the files exist -- during install (chroot) there's no
# WAYLAND_DISPLAY yet, but the configs must be in place for first boot.
if [[ -f "$CURRENT_THEME_PATH/hyprland.conf" ]]; then
  mkdir -p "$HOME/.config/hypr"
  cp "$CURRENT_THEME_PATH/hyprland.conf" "$HOME/.config/hypr/theme.conf"
fi
if [[ -f "$CURRENT_THEME_PATH/hyprlock.conf" ]]; then
  mkdir -p "$HOME/.config/hypr"
  cp "$CURRENT_THEME_PATH/hyprlock.conf" "$HOME/.config/hypr/hyprlock-theme.conf"
fi

# Link dunst theme (concatenate core + theme colors)
if [[ -f "$CURRENT_THEME_PATH/dunstrc.theme" ]]; then
  mkdir -p "$HOME/.config/dunst"
  if [[ -f "$HOME/.config/dunst/dunstrc" ]]; then
    cat "$HOME/.config/dunst/dunstrc" "$CURRENT_THEME_PATH/dunstrc.theme" > "$HOME/.config/dunst/dunstrc.active"
  else
    cp "$CURRENT_THEME_PATH/dunstrc.theme" "$HOME/.config/dunst/dunstrc.active"
  fi
fi

# Link foot theme
if [[ -f "$CURRENT_THEME_PATH/foot.ini" ]]; then
  mkdir -p "$HOME/.config/foot"
  cp "$CURRENT_THEME_PATH/foot.ini" "$HOME/.config/foot/theme.ini"
fi

# Link rofi theme (single file used by launcher + all dialogs)
mkdir -p "$HOME/.config/rofi"
if [[ -f "$CURRENT_THEME_PATH/smplos-launcher.rasi" ]]; then
  cp "$CURRENT_THEME_PATH/smplos-launcher.rasi" "$HOME/.config/rofi/smplos-launcher.rasi"
fi

# st (suckless terminal) -- colors applied at runtime via OSC escape sequences
# No config file copy needed; theme-set-st reads colors.toml directly

# Link btop theme
if [[ -f "$CURRENT_THEME_PATH/btop.theme" ]]; then
  mkdir -p "$HOME/.config/btop/themes"
  cp "$CURRENT_THEME_PATH/btop.theme" "$HOME/.config/btop/themes/current.theme"
fi

# micro text editor — deploy colorscheme (reloads on next file open)
if [[ -f "$CURRENT_THEME_PATH/micro.theme" ]]; then
  mkdir -p "$HOME/.config/micro/colorschemes"
  cp "$CURRENT_THEME_PATH/micro.theme" "$HOME/.config/micro/colorschemes/smplos.micro"
fi

# Nemo file manager — deploy per-theme GTK3 CSS override
# nemo-smpl watches ~/.config/smplos/nemo-theme.css via GFileMonitor
# and reloads it live, so no nemo restart is required.
# Use atomic rename so the monitor never sees a truncated file.
if [[ -f "$CURRENT_THEME_PATH/nemo.css" ]]; then
  mkdir -p "$HOME/.config/smplos"
  cp "$CURRENT_THEME_PATH/nemo.css" "$HOME/.config/smplos/nemo-theme.css.tmp"
  mv -f "$HOME/.config/smplos/nemo-theme.css.tmp" "$HOME/.config/smplos/nemo-theme.css"
fi

# Link fish theme colors
if [[ -f "$CURRENT_THEME_PATH/fish.theme" ]]; then
  mkdir -p "$HOME/.config/fish"
  cp "$CURRENT_THEME_PATH/fish.theme" "$HOME/.config/fish/theme.fish"
fi

# Apply Tide prompt theme (set universal variables so Tide picks them up immediately)
if [[ -f "$CURRENT_THEME_PATH/tide.theme" ]] && command -v fish &>/dev/null; then
  fish -c "source '$CURRENT_THEME_PATH/tide.theme'; tide reload" &>/dev/null || true
fi

# Set wallpaper from theme backgrounds
theme-bg-next

# =========================================================================
# RESTART COMPONENTS — apply new theme live
# All guarded: only runs if the app is actually present/running
# =========================================================================

# EWW bar (kill + restart so new SCSS is compiled)
if pgrep -x eww >/dev/null; then
  eww --config "$HOME/.config/eww" kill 2>/dev/null
  sleep 0.3
  killall -9 eww 2>/dev/null  # ensure no zombies
  # Kill orphaned listener scripts — eww kill only stops the daemon,
  # deflisten child processes get reparented to PID 1 and leak
  pkill -f "scripts/(volume|network|bluetooth|notification|brightness|workspaces|active-workspace|window-title|sysmenu|notif-hub)-?listener?\.sh" 2>/dev/null
  pkill -f "scripts/(workspaces|active-workspace|window-title)\.sh" 2>/dev/null
  sleep 0.2
  bar-ctl start &
fi

# Hyprland (reload config to pick up new border colors -- runtime only)
if [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v hyprctl &>/dev/null; then
  hyprctl reload 2>/dev/null
fi

# st / st-wl -- apply colors via OSC escape sequences to all running instances
theme-set-st 2>/dev/null &

# Double Commander — regenerate colors.json from theme palette
# theme-set-dc removed — DC replaced by Nemo (GTK3, live-reloads via gtk.css)

# Foot terminal — reload via SIGUSR1 (if running)
if pgrep -x foot >/dev/null; then
  killall -SIGUSR1 foot 2>/dev/null
fi

# Dunst notification daemon
if pgrep -x dunst >/dev/null; then
  dunstctl reload 2>/dev/null
fi

# btop — SIGUSR2 triggers config reload
if pgrep -x btop >/dev/null; then
  killall -USR2 btop 2>/dev/null
fi

# =========================================================================
# APP-SPECIFIC THEMES — optional integrations
# =========================================================================

# GTK / Icon theme + cursor
if [[ -f "$CURRENT_THEME_PATH/light.mode" ]]; then
  _gtk_theme="Adwaita"
  _color_scheme="prefer-light"
  _dark_pref=0
  _gtk_env="Adwaita"
  _cursor_theme="Adwaita"
else
  _gtk_theme="Adwaita-dark"
  _color_scheme="prefer-dark"
  _dark_pref=1
  _gtk_env="Adwaita:dark"
  _cursor_theme="Adwaita"
fi

# dconf/GSettings (primary on Wayland — GTK3/4 read from here)
if command -v gsettings &>/dev/null; then
  gsettings set org.gnome.desktop.interface color-scheme "$_color_scheme" 2>/dev/null
  gsettings set org.gnome.desktop.interface gtk-theme "$_gtk_theme" 2>/dev/null
  gsettings set org.gnome.desktop.interface cursor-theme "$_cursor_theme" 2>/dev/null
  if [[ -f "$CURRENT_THEME_PATH/icons.theme" ]]; then
    gsettings set org.gnome.desktop.interface icon-theme "$(<"$CURRENT_THEME_PATH/icons.theme")" 2>/dev/null
  fi
fi

# Set cursor theme for Hyprland + env
export XCURSOR_THEME="$_cursor_theme"
if command -v hyprctl &>/dev/null && [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
  hyprctl setcursor "$_cursor_theme" 24 2>/dev/null || true
fi

# settings.ini (fallback for X11 and apps that don't use dconf)
# Always gtk-theme-name=Adwaita — the "Adwaita-dark" theme doesn't exist as an
# installed theme. Dark variant is activated by gtk-application-prefer-dark-theme
# (settings.ini) and color-scheme (dconf). The gsettings gtk-theme key can hold
# "Adwaita-dark" because GTK's GSettings codepath special-cases it, but the
# settings.ini parser does not.
for _gtk_dir in "$HOME/.config/gtk-3.0" "$HOME/.config/gtk-4.0"; do
  mkdir -p "$_gtk_dir"
  cat > "$_gtk_dir/settings.ini" << EOF
[Settings]
gtk-theme-name=Adwaita
gtk-application-prefer-dark-theme=$_dark_pref
gtk-icon-theme-name=Adwaita
gtk-font-name=JetBrains Mono 11
gtk-cursor-theme-name=$_cursor_theme
gtk-enable-mnemonics=0
gtk-auto-mnemonics=1
EOF
done

# GTK_THEME env var — forces GTK file dialogs (xdg-desktop-portal-gtk) dark/light.
# gsettings alone is unreliable on non-GNOME desktops; this is the direct override.
export GTK_THEME="$_gtk_env"
# Persist for systemd user services (portals start before Hyprland env import)
mkdir -p "$HOME/.config/environment.d"
printf 'GTK_THEME=%s\nXCURSOR_THEME=%s\n' "$_gtk_env" "$_cursor_theme" > "$HOME/.config/environment.d/gtk.conf"
# Push to Hyprland + systemd so portal services see the change without reboot
command -v hyprctl &>/dev/null && hyprctl setenv GTK_THEME "$GTK_THEME" 2>/dev/null || true
command -v hyprctl &>/dev/null && hyprctl setenv XCURSOR_THEME "$_cursor_theme" 2>/dev/null || true
systemctl --user import-environment GTK_THEME XCURSOR_THEME 2>/dev/null || true
# Restart portal-gtk so it picks up the new GTK_THEME
systemctl --user restart xdg-desktop-portal-gtk 2>/dev/null || true

# App-theme selectors live in colors.toml so each theme can point to any preset.
# Defaults keep legacy behavior: use this theme's own app presets.
NVM_PRESET="$(toml_get "$CURRENT_THEME_PATH/colors.toml" app_theme_nvim)"
VSCODE_PRESET="$(toml_get "$CURRENT_THEME_PATH/colors.toml" app_theme_vscode)"
LOGSEQ_PRESET="$(toml_get "$CURRENT_THEME_PATH/colors.toml" app_theme_logseq)"
NVM_PRESET="${NVM_PRESET:-$THEME_NAME}"
VSCODE_PRESET="${VSCODE_PRESET:-$THEME_NAME}"
LOGSEQ_PRESET="${LOGSEQ_PRESET:-$THEME_NAME}"

# Neovim — deploy lazy.nvim colorscheme spec from selected preset
NVM_THEME_PATH="$(resolve_theme_path "$NVM_PRESET" 2>/dev/null || true)"
if [[ -n "${NVM_THEME_PATH:-}" && -f "$NVM_THEME_PATH/neovim.lua" ]]; then
  mkdir -p "$HOME/.config/nvim/lua/plugins"
  cp "$NVM_THEME_PATH/neovim.lua" "$HOME/.config/nvim/lua/plugins/colorscheme.lua"

  # Live-reload: apply colorscheme to all running Neovim instances via server sockets
  # Neovim 0.9+ auto-creates a socket at $XDG_RUNTIME_DIR/nvim.<pid>.<n>
  _nvim_cs=$(sed -n 's/.*colorscheme[[:space:]]*=[[:space:]]*"\([^"]*\)".*/\1/p' "$NVM_THEME_PATH/neovim.lua" | head -1)
  if [[ -n "$_nvim_cs" ]]; then
    _nvim_rt="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    for _sock in "$_nvim_rt"/nvim.*; do
      [[ -S "$_sock" ]] || continue
      nvim --server "$_sock" --remote-expr "execute('silent! colorscheme $_nvim_cs')" &>/dev/null &
    done
  fi
fi

# VS Code / Codium / Cursor — set workbench.colorTheme from selected preset
VSCODE_THEME_PATH="$(resolve_theme_path "$VSCODE_PRESET" 2>/dev/null || true)"
if [[ -n "${VSCODE_THEME_PATH:-}" && -f "$VSCODE_THEME_PATH/vscode.json" ]]; then
  _set_vscode_theme() {
    local cmd="$1" settings="$2"
    command -v "$cmd" &>/dev/null || return 0

    local theme_name extension vsix
    theme_name=$(jq -r '.name' "$VSCODE_THEME_PATH/vscode.json")
    extension=$(jq -r '.extension // empty' "$VSCODE_THEME_PATH/vscode.json")
    vsix=$(jq -r '.vsix // empty' "$VSCODE_THEME_PATH/vscode.json")

    # Install extension: from bundled .vsix or marketplace
    if [[ -n "$vsix" && -f "$VSCODE_THEME_PATH/$vsix" ]]; then
      "$cmd" --install-extension "$VSCODE_THEME_PATH/$vsix" --force >/dev/null 2>&1 || true
    elif [[ -n "$extension" ]] && ! "$cmd" --list-extensions 2>/dev/null | grep -Fxq "$extension"; then
      "$cmd" --install-extension "$extension" >/dev/null 2>&1 || true
    fi

    # Update settings.json
    mkdir -p "$(dirname "$settings")"
    [[ -f "$settings" ]] || printf '{\n}\n' > "$settings"

    if ! grep -q '"workbench.colorTheme"' "$settings"; then
      sed -i -E '0,/\{/{s/\{/{ "workbench.colorTheme": "",/}' "$settings"
    fi
    sed -i -E "s/(\"workbench.colorTheme\"[[:space:]]*:[[:space:]]*\")[^\"]*(\")/\1$theme_name\2/" "$settings"
  }

  _set_vscode_theme "code" "$HOME/.config/Code/User/settings.json"
  _set_vscode_theme "codium" "$HOME/.config/VSCodium/User/settings.json"
  _set_vscode_theme "cursor" "$HOME/.config/Cursor/User/settings.json"
fi

# Logseq — switch theme via preferences.json + custom.css
# custom.css provides full color theming via CSS variables (always works)
# Plugin themes are optional — enhance theming if plugins are installed
mkdir -p "$HOME/.logseq"
_logseq_prefs="$HOME/.logseq/preferences.json"
_lp="$HOME/.logseq/plugins"

# Detect dark vs light from marker file
_lq_mode=dark
[[ -f "$CURRENT_THEME_PATH/light.mode" ]] && _lq_mode=light

# Map smplOS theme names to Logseq plugin themes (only if plugins are installed)
_lq_name="" _lq_css="" _lq_pid=""
if [[ -d "$_lp" ]]; then
  case "$LOGSEQ_PRESET" in
    catppuccin)       _lq_name="Catppuccin Mocha"          _lq_css="$_lp/logseq-catppuccin/ctp-mocha.css"              _lq_pid=logseq-catppuccin ;;
    catppuccin-latte) _lq_name="Catppuccin Latte"          _lq_css="$_lp/logseq-catppuccin/ctp-latte.css"              _lq_pid=logseq-catppuccin ;;
    tokyo-night)      _lq_name="Tokyo Night"               _lq_css="$_lp/tokyo-night/tokyo.css"                        _lq_pid=tokyo-night ;;
    everforest)       _lq_name="Everforest Dark Medium"    _lq_css="$_lp/logseq-everforest-theme/everforest-dark-medium.css" _lq_pid=logseq-everforest-theme ;;
    rose-pine)        _lq_name="Rosé Pine Dawn"            _lq_css="$_lp/logseq-rose-pine-theme/src/rose-pine-dawn.css" _lq_pid=logseq-rose-pine-theme ;;
    flexoki-light)    _lq_name="Flexoki Light"             _lq_css="$_lp/logseq-flexoki-theme/flexoki-theme.css"        _lq_pid=logseq-flexoki-theme ;;
    hackerman)        _lq_name="Matrix AMOLED Dark"        _lq_css="$_lp/logseq-matrixamoled-theme/matrix.css"          _lq_pid=logseq-matrixamoled-theme ;;
    matrix)           _lq_name="Matrix AMOLED Dark"        _lq_css="$_lp/logseq-matrixamoled-theme/matrix.css"          _lq_pid=logseq-matrixamoled-theme ;;
    matte-black)      _lq_name="D42ker Logseq"             _lq_css="$_lp/logseq-d42ker-theme/custom.css"               _lq_pid=logseq-d42ker-theme ;;
    gruvbox)          _lq_name="Everforest Dark Soft"      _lq_css="$_lp/logseq-everforest-theme/everforest-dark-soft.css" _lq_pid=logseq-everforest-theme ;;
    kanagawa)         _lq_name="Rosé Pine"                 _lq_css="$_lp/logseq-rose-pine-theme/src/rose-pine.css"      _lq_pid=logseq-rose-pine-theme ;;
    nord)             _lq_name="Rosé Pine Moon"            _lq_css="$_lp/logseq-rose-pine-theme/src/rose-pine-moon.css" _lq_pid=logseq-rose-pine-theme ;;
    osaka-jade)       _lq_name="Everforest Dark Hard"      _lq_css="$_lp/logseq-everforest-theme/everforest-dark-hard.css" _lq_pid=logseq-everforest-theme ;;
    ristretto)        _lq_name="Catppuccin Macchiato"      _lq_css="$_lp/logseq-catppuccin/ctp-macchiato.css"           _lq_pid=logseq-catppuccin ;;
    ethereal)         _lq_name="Catppuccin Mocha"          _lq_css="$_lp/logseq-catppuccin/ctp-mocha.css"              _lq_pid=logseq-catppuccin ;;
  esac
fi

if [[ -n "$_lq_pid" && -f "$_lq_css" ]]; then
  # Write preferences.json with plugin theme + correct dark/light mode
  cat > "$_logseq_prefs" <<EOF
{
  "theme": {
    "name": "$_lq_name",
    "url": "assets://$_lq_css",
    "mode": "$_lq_mode",
    "pid": "$_lq_pid"
  },
  "themes": {
    "mode": "$_lq_mode"
  },
  "externals": []
}
EOF
else
  # No plugin for this theme — use legacy "theme" key (with mode, no URL) so
  # activateUserPreferences() calls selectTheme() -> emits "theme-selected"
  # -> handler calls set-theme-mode!.  Without this key, Logseq defaults to
  # "light" on Linux (stored in localStorage, not any config file).
  cat > "$_logseq_prefs" <<EOF
{
  "theme": {
    "mode": "$_lq_mode"
  },
  "themes": {
    "mode": "$_lq_mode"
  },
  "externals": []
}
EOF
fi

# Deploy Logseq theme CSS.
# Logseq's add-style! embeds the :custom-css-url value as CSS *content* in a
# data URL — it does NOT fetch it as a URL. So we must embed the CSS text
# directly into config.edn's :custom-css-url field (not a file:// or assets:// URL).
# Also write to any file-based graph dirs for live-reload via file watcher.
if [[ -f "$CURRENT_THEME_PATH/logseq-custom.css" ]]; then
  mkdir -p "$HOME/.logseq/config"
  cp "$CURRENT_THEME_PATH/logseq-custom.css" "$HOME/.logseq/custom.css"

  # Embed CSS content directly into config.edn as the :custom-css-url value.
  # EDN strings: escape backslashes then double-quotes; collapse to single line.
  _css_content=$(sed 's/\\/\\\\/g; s/"/\\"/g' "$CURRENT_THEME_PATH/logseq-custom.css" \
                 | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')
  _lq_global_cfg="$HOME/.logseq/config/config.edn"

  # Preserve the comment header, replace only the map at the bottom
  if [[ -f "$_lq_global_cfg" ]]; then
    # Strip old map line(s) and append new one
    grep '^;;' "$_lq_global_cfg" > "${_lq_global_cfg}.tmp" 2>/dev/null || true
    printf '\n{:custom-css-url "%s"}\n' "$_css_content" >> "${_lq_global_cfg}.tmp"
    mv "${_lq_global_cfg}.tmp" "$_lq_global_cfg"
  else
    printf '{:custom-css-url "%s"}\n' "$_css_content" > "$_lq_global_cfg"
  fi

  # Also write to any file-based graph's logseq/custom.css (live-reloaded by file watcher)
  while IFS= read -r _lq_config; do
    cp "$CURRENT_THEME_PATH/logseq-custom.css" "$(dirname "$_lq_config")/custom.css"
  done < <(find "$HOME" -maxdepth 5 -name "config.edn" -path "*/logseq/config.edn" \
             -not -path "$HOME/.logseq/*" 2>/dev/null)
fi

# SiYuan — deploy smplOS theme CSS into the "smplos" theme directory
# Live-reload requires three things to work together:
#   1. theme.json must have a NEW version on every switch (browser cache-busting)
#   2. /api/setting/setTheme (or legacy /api/setting/setAppearance) must be
#      called so the kernel updates themeLight/themeDark in memory, calls
#      InitAppearance() to read the new themeVer, then broadcasts "setAppearance"
#      over WebSocket — all open windows call loadAssets() which rewrites the
#      <link> href with the new ?v=<themeVer> parameter, forcing fresh CSS.
#   3. Both themeLight AND themeDark must be set to "smplos"; the correct
#      light/dark mode is passed as the "mode" field (0=light, 1=dark).
if [[ -f "$CURRENT_THEME_PATH/siyuan-theme.css" ]]; then
  # Locate the SiYuan workspace (default ~/SiYuan, overridable via workspace.json)
  _SIYUAN_WS="$HOME/SiYuan"
  if [[ -f "$HOME/.config/siyuan/workspace.json" ]]; then
    _sy_ws=$(sed -n 's/.*"\(\/[^"]*\)".*/\1/p' "$HOME/.config/siyuan/workspace.json" | head -1)
    [[ -n "$_sy_ws" && -d "$_sy_ws" ]] && _SIYUAN_WS="$_sy_ws"
  fi

  _SIYUAN_THEME_DIR="$_SIYUAN_WS/conf/appearance/themes/smplos"
  mkdir -p "$_SIYUAN_THEME_DIR"

  _sy_mode=1
  [[ -f "$CURRENT_THEME_PATH/light.mode" ]] && _sy_mode=0

  # Always write theme.json with a fresh timestamp-based version.
  # SiYuan's InitAppearance() reads this version and embeds it as ?v=<themeVer>
  # in the CSS URL — a new version forces the browser to bypass its cache.
  _ts=$(date +%s)
  cat > "$_SIYUAN_THEME_DIR/theme.json" << EOJSON
{
  "name": "smplos",
  "author": "smplOS",
  "url": "",
  "version": "1.0.0-${_ts}",
  "minAppVersion": "2.0.0",
  "displayName": {"default": "smplOS", "en_US": "smplOS"},
  "description": {"default": "Dynamic theme controlled by smplOS theme switcher"},
  "readme": {"default": ""},
  "modes": ["light", "dark"]
}
EOJSON

  # Deploy the pre-baked CSS
  cp "$CURRENT_THEME_PATH/siyuan-theme.css" "$_SIYUAN_THEME_DIR/theme.css"

  # Detect SiYuan port: 6806 = release build, 6807 = dev build
  _sy_port=""
  for _p in 6806 6807; do
    if curl -s --max-time 1 "http://127.0.0.1:$_p/api/system/version" &>/dev/null; then
      _sy_port="$_p"
      break
    fi
  done

  if [[ -n "$_sy_port" ]]; then
    # SiYuan is running — activate the smplos theme and broadcast to all windows.
    # Try /api/setting/setTheme first (available since SiYuan PR #XXXX); fall back
    # to the heavier getConf → patch → setAppearance dance for older builds.
    _sy_set_result=$(curl -s -o /tmp/_sy_set.json -w "%{http_code}" --max-time 2 \
      "http://127.0.0.1:$_sy_port/api/setting/setTheme" \
      -H "Content-Type: application/json" \
      -d "{\"theme\":\"smplos\",\"mode\":$_sy_mode}" 2>/dev/null)
    _sy_ok=false
    if [[ "$_sy_set_result" == "200" ]]; then
      _sy_code=$(python3 -c "import json,sys; print(json.load(open('/tmp/_sy_set.json'))['code'])" 2>/dev/null || echo "-1")
      [[ "$_sy_code" == "0" ]] && _sy_ok=true
    fi

    if [[ "$_sy_ok" != "true" ]]; then
      # Older SiYuan — fall back to setAppearance (requires jq to build the full blob)
      if command -v jq &>/dev/null; then
        _sy_appearance=$(curl -s --max-time 2 "http://127.0.0.1:$_sy_port/api/system/getConf" \
            -H "Content-Type: application/json" -d '{}' \
            | jq ".data.conf.appearance
                  | .themeLight = \"smplos\"
                  | .themeDark  = \"smplos\"
                  | .mode       = $_sy_mode" 2>/dev/null)
        if [[ -n "$_sy_appearance" && "$_sy_appearance" != "null" ]]; then
          curl -s --max-time 2 "http://127.0.0.1:$_sy_port/api/setting/setAppearance" \
            -H "Content-Type: application/json" \
            -d "$_sy_appearance" &>/dev/null || true
        fi
      else
        # jq not available — mode-only switch (no CSS cache-bust, last resort)
        curl -s --max-time 2 "http://127.0.0.1:$_sy_port/api/system/setAppearanceMode" \
          -H "Content-Type: application/json" \
          -d "{\"mode\":$_sy_mode}" &>/dev/null || true
      fi
    fi
  else
    # SiYuan not running — patch conf.json on disk so the next startup picks up
    # the correct theme and mode without manual intervention.
    _sy_conf_json="$_SIYUAN_WS/conf/conf.json"
    if [[ -f "$_sy_conf_json" ]]; then
      if command -v jq &>/dev/null; then
        _tmp=$(jq --argjson mode "$_sy_mode" \
          '.appearance.themeLight = "smplos"
           | .appearance.themeDark = "smplos"
           | .appearance.mode = $mode' \
          "$_sy_conf_json") && echo "$_tmp" > "$_sy_conf_json"
      else
        sed -i \
          -e 's/"themeLight"[[:space:]]*:[[:space:]]*"[^"]*"/"themeLight": "smplos"/' \
          -e 's/"themeDark"[[:space:]]*:[[:space:]]*"[^"]*"/"themeDark": "smplos"/' \
          "$_sy_conf_json"
      fi
    else
      # conf.json doesn't exist yet (SiYuan never launched). Pre-create a
      # minimal one so the first launch picks up the smplOS theme. SiYuan's
      # InitConf() merges this into its defaults — only appearance fields needed.
      mkdir -p "$(dirname "$_sy_conf_json")"
      cat > "$_sy_conf_json" << EOJSON
{
  "appearance": {
    "mode": $_sy_mode,
    "modeOS": false,
    "themeLight": "smplos",
    "themeDark": "smplos"
  }
}
EOJSON
    fi
  fi
fi

# Chromium / Brave -- full theme support
# Generates a Chrome theme extension from colors.toml (no root required).
# Browser toolbar/tab colors apply on next Brave launch.
# --force-dark-mode applies immediately on next Brave start (pages go dark).

_hex_to_rgb_array() {
  # Convert #rrggbb to "r, g, b" for Chrome theme manifest JSON
  local hex="${1#\#}"
  printf "%d, %d, %d" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

_toml_color() {
  grep "^${1}[[:space:]]*=" "$CURRENT_THEME_PATH/colors.toml" 2>/dev/null \
    | head -1 | sed 's/.*"\(#[^"]*\)".*/\1/'
}

_bg=$(      _toml_color background)
_bg_light=$(  _toml_color bg_light)
_surface=$(   _toml_color surface)
_fg=$(        _toml_color foreground)
_fg_alt=$(    _toml_color fg_alt)
_accent=$(    _toml_color accent)
_muted=$(     _toml_color muted)

if [[ -n "$_bg" ]]; then
  # ── Dark/light mode ────────────────────────────────────────────────────────
  if [[ -f "$CURRENT_THEME_PATH/light.mode" ]]; then
    DARK_MODE=false
  else
    DARK_MODE=true
  fi

  # ── Chrome theme extension manifest ───────────────────────────────────────
  # Loaded via --load-extension in brave-flags.conf.
  # Toolbar and tab colors apply on next Brave launch (extensions read at startup).
  # No root required. No compiling. No Chrome Web Store.
  BRAVE_THEME_DIR="$HOME/.config/smplos/brave-theme"
  mkdir -p "$BRAVE_THEME_DIR"

  _rgb_bg=$(      _hex_to_rgb_array "$_bg")
  _rgb_bg_light=$(  _hex_to_rgb_array "${_bg_light:-$_bg}")
  _rgb_surface=$(   _hex_to_rgb_array "${_surface:-$_bg_light}")
  _rgb_fg=$(        _hex_to_rgb_array "${_fg:-#e0e0e0}")
  _rgb_fg_alt=$(    _hex_to_rgb_array "${_fg_alt:-#888888}")
  _rgb_accent=$(    _hex_to_rgb_array "${_accent:-#7aa2f7}")
  _rgb_muted=$(     _hex_to_rgb_array "${_muted:-#444444}")

  cat > "$BRAVE_THEME_DIR/manifest.json" << EOJSON
{
  "manifest_version": 2,
  "name": "smplOS ${THEME_NAME}",
  "version": "1.0",
  "theme": {
    "colors": {
      "frame":                  [${_rgb_bg}],
      "frame_inactive":         [${_rgb_bg_light}],
      "frame_incognito":        [${_rgb_bg}],
      "toolbar":                [${_rgb_surface}],
      "tab_text":               [${_rgb_fg}],
      "tab_background_text":    [${_rgb_fg_alt}],
      "bookmark_text":          [${_rgb_fg}],
      "ntp_background":         [${_rgb_bg}],
      "ntp_text":               [${_rgb_fg}],
      "ntp_link":               [${_rgb_accent}],
      "omnibox_background":     [${_rgb_bg_light}],
      "omnibox_text":           [${_rgb_fg}],
      "button_background":      [${_rgb_surface}],
      "control_background":     [${_rgb_bg_light}]
    },
    "tints": {
      "background_tab": [0.0, 0.0, 0.45],
      "buttons": [-1, -1, -1]
    }
  }
}
EOJSON

  # ── Brave/Chromium flags ───────────────────────────────────────────────────
  # brave-flags.conf is read by the Brave launcher on every start.
  _set_browser_flags() {
    local flags_file="$1"
    local ext_path="$BRAVE_THEME_DIR"
    mkdir -p "$(dirname "$flags_file")"
    touch "$flags_file"

    # Remove previously managed flags (dark mode + our extension load)
    sed -i \
      -e '/^--force-dark-mode$/d' \
      -e '/^--enable-features=.*WebUIDarkMode/d' \
      -e '/^--load-extension=.*smplos\/brave-theme/d' \
      "$flags_file" 2>/dev/null || true

    # Dark mode flags (controls browser chrome + forces sites dark)
    if $DARK_MODE; then
      echo "--force-dark-mode" >> "$flags_file"
      if grep -q '^--enable-features=' "$flags_file"; then
        sed -i 's/^--enable-features=\(.*\)/--enable-features=\1,WebUIDarkMode/' "$flags_file"
      else
        echo "--enable-features=WebUIDarkMode" >> "$flags_file"
      fi
    fi

    # Load our theme extension (applies toolbar/tab colors on next Brave start)
    echo "--load-extension=${ext_path}" >> "$flags_file"

    # Clean up blank lines
    sed -i '/^[[:space:]]*$/d' "$flags_file"
  }
  _set_browser_flags "$HOME/.config/brave-flags.conf"
  _set_browser_flags "$HOME/.config/chromium-flags.conf"

  # ── Managed policy (only if root — e.g. dev-apply.sh) ─────────────────────
  # BrowserThemeColor hints the native window title bar on some Linux WMs.
  if [[ $EUID -eq 0 ]]; then
    for browser in chromium brave; do
      command -v "$browser" &>/dev/null || continue
      mkdir -p "/etc/$browser/policies/managed" 2>/dev/null
      printf '{"BrowserThemeColor":"%s","BackgroundModeEnabled":false}\n' "$_bg" \
        > "/etc/$browser/policies/managed/color.json" 2>/dev/null
    done
  fi
fi

echo "Theme set to: $THEME_NAME"

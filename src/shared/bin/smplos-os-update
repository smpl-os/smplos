#!/bin/bash
# smplos-os-update — Update smplOS system files via git
#
# Pulls the latest smplOS repo, syncs scripts to /usr/local/bin/,
# and runs pending migrations.
#
# The smplOS repo is cloned to ~/.local/share/smplos/ during installation.
# This script pulls updates and deploys them.
#
# Usage: smplos-os-update [options]
#   --check     Only report whether an update is available
#   --quiet     Suppress per-file output
#   --scripts   Only sync scripts (skip migrations)
#   --migrate   Only run migrations (skip git pull + script sync)

set -euo pipefail

# ── Restore invoker context if running under pkexec/sudo ─────────────────────
# Under pkexec, $HOME is /root and every $HOME-relative path (SMPLOS_PATH,
# migration markers, ~/.config/hypr, ~/.local/share/smplos/repo) points at
# an empty dir — the git pull silently no-ops and the whole update evaporates.
# Restore invoker context so paths resolve to the actual user's home.
# The wrapper (smplos-update) sets SMPLOS_INVOKER_* for us; when this script
# is invoked directly under sudo/pkexec, we derive them here as a fallback.
if [[ $EUID -eq 0 && -z "${SMPLOS_INVOKER_HOME:-}" ]]; then
    _invoker_uid="${PKEXEC_UID:-${SUDO_UID:-}}"
    if [[ -n "${_invoker_uid:-}" && "$_invoker_uid" != "0" ]]; then
        _invoker_ent="$(getent passwd "$_invoker_uid" 2>/dev/null || true)"
        if [[ -n "$_invoker_ent" ]]; then
            export SMPLOS_INVOKER_UID="$_invoker_uid"
            export SMPLOS_INVOKER_USER="$(cut -d: -f1 <<<"$_invoker_ent")"
            export SMPLOS_INVOKER_HOME="$(cut -d: -f6 <<<"$_invoker_ent")"
            export HOME="$SMPLOS_INVOKER_HOME"
            export USER="$SMPLOS_INVOKER_USER"
            export LOGNAME="$SMPLOS_INVOKER_USER"
        fi
    fi
    unset _invoker_uid _invoker_ent
fi

SMPLOS_PATH="${SMPLOS_PATH:-$HOME/.local/share/smplos}"
SMPLOS_REPO="$SMPLOS_PATH/repo"
SMPLOS_REPO_URL="https://github.com/smpl-os/smplos.git"

# ── Run a command as the invoking user when we're root ───────────────────────
# git operations against the user-owned smplOS repo must NOT run as root:
# (a) git 2.35.2+ rejects with "unsafe repository" for cross-uid access, and
# (b) any file git writes as root breaks the user's future `git pull` attempts.
# smplos-migrate similarly writes marker files under $HOME/.local/state/smplos
# that must stay user-owned so the user can clear them without sudo.
# Use runuser (util-linux, always present on Arch) which cleanly drops privs
# without a password prompt.
as_invoker() {
    if [[ $EUID -eq 0 && -n "${SMPLOS_INVOKER_USER:-}" ]]; then
        runuser -u "$SMPLOS_INVOKER_USER" -- "$@"
    else
        "$@"
    fi
}

# Resolve our own path so we can re-exec into the freshly-installed copy after
# sync_scripts, breaking the bootstrap chicken-and-egg where a run started
# from the OLD /usr/local/bin/smplos-os-update would keep executing the old
# in-memory code even after installing its own replacement. Without this,
# users always needed to run smplos-os-update TWICE to actually benefit from
# any fix to smplos-os-update itself — a chronic source of "the fix does not
# take" reports.
SELF_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"
SELF_CANONICAL="/usr/local/bin/smplos-os-update"

# ── Argument parsing ──────────────────────────────────────────────────────────
CHECK_ONLY=0; QUIET=0; SCRIPTS_ONLY=0; MIGRATE_ONLY=0
# Internal flag: set by self-reexec to prevent infinite loops if the newly
# installed script somehow still detects itself as outdated.
SELF_UPDATED="${SMPLOS_OS_UPDATE_RESUMED:-0}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --check)     CHECK_ONLY=1 ;;
        --quiet)     QUIET=1 ;;
        --scripts)   SCRIPTS_ONLY=1 ;;
        --migrate)   MIGRATE_ONLY=1 ;;
        -h|--help)
            echo "Usage: smplos-os-update [--check | --quiet | --scripts | --migrate]"
            exit 0 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
    shift
done

# ── Helpers ───────────────────────────────────────────────────────────────────
log()    { [[ $QUIET -eq 0 ]] && echo "  $*" || true; }
ok()     { [[ $QUIET -eq 0 ]] && echo "  ✓ $*" || true; }
warn()   { echo "  ⚠ $*" >&2; }
header() { [[ $QUIET -eq 0 ]] && echo "$*" || true; }
die()    { echo "ERROR: $*" >&2; exit 1; }

# ── Ensure repo exists ───────────────────────────────────────────────────────
ensure_repo() {
    if [[ ! -d "$SMPLOS_REPO/.git" ]]; then
        log "First run: cloning smplOS repo..."
        # Clone as the invoker so the repo stays user-owned (see as_invoker).
        as_invoker mkdir -p "$(dirname "$SMPLOS_REPO")"
        as_invoker git clone --depth=1 "$SMPLOS_REPO_URL" "$SMPLOS_REPO" 2>/dev/null \
            || die "Failed to clone smplOS repo"
        ok "Repo cloned to $SMPLOS_REPO"
    fi
}

# ── Git pull ──────────────────────────────────────────────────────────────────
# Bulletproof repo sync. The old implementation silently swallowed errors with
# `2>/dev/null` on every git command; we saw repos drift 25 commits behind
# origin because a single failed rebase (dirty tree, detached HEAD, wrong
# branch, network blip) would go completely unnoticed. Every subsequent
# update would then report "Already up to date" against a stale local HEAD.
#
# Invariants this function guarantees on success:
#   1. Working tree exists and is a git repo pointing at the smplos remote.
#   2. HEAD is on branch `main` (never detached; auto-recovers if it was).
#   3. Local main is exactly equal to origin/main after the call.
#   4. All error output from git is surfaced to the log — no silent failures.
#
# Any deviation from those invariants that cannot be recovered from is a
# hard `die` — we refuse to silently deploy from a stale checkout.
pull_updates() {
    header "── smplOS System Files ──"

    ensure_repo

    local repo="$SMPLOS_REPO"
    local before after remote_head branch

    before=$(as_invoker git -C "$repo" rev-parse HEAD 2>/dev/null || echo "unknown")

    # 1) Refuse to run against a repo that isn't ours. Prevents a misconfigured
    #    SMPLOS_REPO from pulling arbitrary upstream code onto the system.
    local remote_url
    remote_url=$(as_invoker git -C "$repo" remote get-url origin 2>/dev/null || echo "")
    if [[ "$remote_url" != *"smpl-os/smplos"* ]]; then
        die "SMPLOS_REPO ($repo) origin is '$remote_url', expected smpl-os/smplos"
    fi

    # 2) Move HEAD to `main` if it drifted (detached HEAD from a manual
    #    checkout, dev experimenting on a feature branch, prior interrupted
    #    rebase leaving REBASE_HEAD around, etc.). Without this, `git pull`
    #    silently does nothing useful on a detached HEAD and we'd never catch
    #    up. Any in-flight rebase is aborted before we try.
    if [[ -d "$repo/.git/rebase-merge" || -d "$repo/.git/rebase-apply" ]]; then
        warn "Aborting stale rebase state in $repo"
        as_invoker git -C "$repo" rebase --abort 2>&1 | while read -r l; do log "  $l"; done || true
    fi
    branch=$(as_invoker git -C "$repo" symbolic-ref --short HEAD 2>/dev/null || echo "")
    if [[ "$branch" != "main" ]]; then
        warn "Repo was on '$branch' (or detached), checking out main"
        as_invoker git -C "$repo" checkout -B main 2>&1 | while read -r l; do log "  $l"; done \
            || die "Cannot switch $repo to branch main"
    fi

    # 3) Fetch. Any network/auth error here MUST surface — this is the single
    #    most common silent-failure point that leaves us stuck on a stale HEAD.
    log "Fetching origin/main..."
    if ! as_invoker git -C "$repo" fetch --prune origin main 2>&1 | while read -r l; do log "  $l"; done; then
        die "git fetch failed for $repo (network? auth? disk?)"
    fi

    remote_head=$(as_invoker git -C "$repo" rev-parse origin/main 2>/dev/null || echo "")
    [[ -n "$remote_head" ]] || die "origin/main missing in $repo after fetch"

    # 4) Already at tip? Great, done.
    if [[ "$before" == "$remote_head" ]]; then
        ok "Already up to date ($(as_invoker git -C "$repo" describe --tags --always 2>/dev/null || echo "$before"))"
        return 1
    fi

    # 5) Try ff-only first — this is the safest path when local main hasn't
    #    diverged. If we can fast-forward, do so; no rebase, no merge, no
    #    surprises. Local changes to tracked files are auto-stashed and
    #    popped so a dev poking at looknfeel.lua doesn't block the update.
    log "Local: $(as_invoker git -C "$repo" rev-parse --short HEAD)  Remote: $(as_invoker git -C "$repo" rev-parse --short origin/main)"
    if ! as_invoker git -C "$repo" pull --ff-only --autostash 2>&1 | while read -r l; do log "  $l"; done; then
        # 6) FF failed → local main has diverged. Rather than silently
        #    creating a merge or dropping user commits, we hard-reset to
        #    origin/main. This mirrors the old behavior's intent but with
        #    LOUD logging so the drift is visible in support tickets.
        warn "Fast-forward failed; local main has diverged from origin/main."
        warn "Hard-resetting to origin/main (any local commits on $repo main will be discarded)."
        as_invoker git -C "$repo" reset --hard "origin/main" 2>&1 | while read -r l; do log "  $l"; done \
            || die "Hard-reset to origin/main failed — repo is in an inconsistent state"
    fi

    after=$(as_invoker git -C "$repo" rev-parse HEAD 2>/dev/null || echo "unknown")

    # 7) Final invariant check: HEAD MUST equal origin/main. If not, refuse
    #    to continue — deploying from a still-stale checkout is exactly the
    #    "update did nothing" bug we're trying to eliminate.
    if [[ "$after" != "$remote_head" ]]; then
        die "Post-pull HEAD ($after) != origin/main ($remote_head) — refusing to deploy stale checkout"
    fi

    local n_changes
    n_changes=$(as_invoker git -C "$repo" diff --stat "$before" "$after" 2>/dev/null | tail -1 || echo "")
    [[ -n "$n_changes" ]] && log "$n_changes"
    ok "Advanced $before → $after"
    return 0
}

# ── Check only ────────────────────────────────────────────────────────────────
check_updates() {
    ensure_repo

    # Same discipline as pull_updates: don't swallow errors, and ensure we
    # compare against the actual current origin/main rather than a stale
    # remote-tracking ref that hasn't been fetched since last week.
    if ! as_invoker git -C "$SMPLOS_REPO" fetch --prune origin main 2>&1 | while read -r l; do log "  $l"; done; then
        warn "Cannot reach GitHub"; exit 1
    fi

    local local_head remote_head
    local_head=$(as_invoker git -C "$SMPLOS_REPO" rev-parse HEAD)
    remote_head=$(as_invoker git -C "$SMPLOS_REPO" rev-parse origin/main 2>/dev/null || echo "")

    if [[ -z "$remote_head" || "$local_head" == "$remote_head" ]]; then
        echo "  smplOS is up to date"
        exit 1
    else
        local behind
        behind=$(as_invoker git -C "$SMPLOS_REPO" rev-list --count "HEAD..origin/main" 2>/dev/null || echo "?")
        echo "  smplOS update available ($behind new commits)"
        exit 0
    fi
}

# ── Sync scripts to /usr/local/bin/ ───────────────────────────────────────────
sync_scripts() {
    local bin_dir="$SMPLOS_REPO/src/shared/bin"
    [[ -d "$bin_dir" ]] || { warn "No scripts directory found at $bin_dir"; return; }

    header ""
    header "── Syncing scripts ──"

    local smplos_bin="$HOME/.local/share/smplos/bin"
    mkdir -p "$smplos_bin"

    local n_updated=0 n_total=0
    for script in "$bin_dir"/*; do
        [[ -f "$script" ]] || continue
        local name dest
        name=$(basename "$script")
        dest="/usr/local/bin/$name"

        ((n_total++)) || true

        # Only copy if changed (compare against the system copy)
        if [[ -f "$dest" ]] && cmp -s "$script" "$dest"; then
            continue
        fi

        if sudo install -m755 "$script" "$dest" 2>/dev/null; then
            ((n_updated++)) || true
        else
            warn "Failed to install $name (sudo required)"
        fi
        # Single-copy invariant: do NOT mirror into ~/.local/share/smplos/bin.
        # Historically we did — the intent was "user-local wins on PATH so a
        # broken sudo path still updates" — but the effect was to seed the
        # exact shadow-copy mess this script now spends its life cleaning up.
        # Any pre-existing shadow gets scrubbed by cleanup_shadow_bins() below.
    done

    if [[ $n_updated -gt 0 ]]; then
        ok "$n_updated of $n_total scripts updated"
    else
        ok "All $n_total scripts are current"
    fi
}

# ── Sync config files to ~/.config/ ───────────────────────────────────────────
sync_configs() {
    header ""
    header "── Syncing configs ──"

    local n_updated=0

    # EWW configs (eww.yuck, eww.scss, scripts/)
    local eww_src="$SMPLOS_REPO/src/shared/eww"
    local eww_dst="$HOME/.config/eww"
    if [[ -d "$eww_src" ]]; then
        mkdir -p "$eww_dst"
        # Sync core EWW files (but not theme-colors.scss — that's managed by theme-set)
        for f in eww.yuck eww.scss; do
            if [[ -f "$eww_src/$f" ]] && ! cmp -s "$eww_src/$f" "$eww_dst/$f" 2>/dev/null; then
                cp "$eww_src/$f" "$eww_dst/$f"
                ((n_updated++)) || true
            fi
        done
        # Sync scripts directory
        if [[ -d "$eww_src/scripts" ]]; then
            mkdir -p "$eww_dst/scripts"
            for script in "$eww_src/scripts/"*; do
                [[ -f "$script" ]] || continue
                local name
                name=$(basename "$script")
                if ! cmp -s "$script" "$eww_dst/scripts/$name" 2>/dev/null; then
                    cp "$script" "$eww_dst/scripts/$name"
                    chmod +x "$eww_dst/scripts/$name"
                    ((n_updated++)) || true
                fi
            done
        fi
    fi

    # Shared configs (hyprshell, smplos, etc.) — only add new files, don't overwrite user edits
    local configs_src="$SMPLOS_REPO/src/shared/configs"
    if [[ -d "$configs_src" ]]; then
        # Walk each config directory
        while IFS= read -r -d '' src_file; do
            local rel_path="${src_file#$configs_src/}"
            # Skip smplos/ subdir — those are Hyprland-specific configs managed separately
            [[ "$rel_path" == smplos/* ]] && continue
            local dst_file="$HOME/.config/$rel_path"
            if [[ ! -f "$dst_file" ]]; then
                mkdir -p "$(dirname "$dst_file")"
                cp "$src_file" "$dst_file"
                ((n_updated++)) || true
            fi
        done < <(find "$configs_src" -type f -print0)
    fi

    if [[ $n_updated -gt 0 ]]; then
        ok "$n_updated config file(s) updated"
    else
        ok "All configs are current"
    fi
}

# ── Sync themes to ~/.local/share/smplos/themes/ ─────────────────────────────
# Stock theme files (colors.toml, nemo.css, eww-colors.scss, etc.) are read by
# theme-set from $STOCK_THEMES_PATH ($HOME/.local/share/smplos/themes). They are
# stamped into the installed system from the ISO and otherwise never updated,
# which means CSS fixes (e.g. nemo submenu rendering) shipped via the repo never
# reach existing installs. User-overridden themes live in $USER_THEMES_PATH
# ($HOME/.config/smplos/themes) and are NOT touched here.
sync_themes() {
    local themes_src="$SMPLOS_REPO/src/shared/themes"
    local themes_dst="$HOME/.local/share/smplos/themes"
    [[ -d "$themes_src" ]] || { warn "No themes directory found at $themes_src"; return; }

    header ""
    header "── Syncing themes ──"

    mkdir -p "$themes_dst"

    local n_updated=0 n_total=0
    for theme_dir in "$themes_src"/*/; do
        [[ -d "$theme_dir" ]] || continue
        local theme_name
        theme_name=$(basename "$theme_dir")
        # Skip _templates and any other private dirs starting with _
        [[ "$theme_name" == _* ]] && continue
        ((n_total++)) || true

        local dst="$themes_dst/$theme_name"
        # rsync would be cleaner but is not always present in the live ISO
        if [[ ! -d "$dst" ]] || ! diff -rq "$theme_dir" "$dst" &>/dev/null; then
            mkdir -p "$dst"
            cp -rT "$theme_dir" "$dst"
            ((n_updated++)) || true
        fi
    done

    if [[ $n_updated -gt 0 ]]; then
        ok "$n_updated of $n_total themes updated"
    else
        ok "All $n_total themes are current"
    fi
}

# ── Fetch + install latest binaries from every smpl-os org repo ──────────────
sync_apps() {
    local fetch_script="$SMPLOS_REPO/src/fetch-org.sh"
    [[ -f "$fetch_script" ]] || { warn "fetch-org.sh not found"; return; }

    header ""
    header "── Updating smpl-os apps ──"

    bash "$fetch_script"

    local stage="$SMPLOS_REPO/.cache/org-binaries"
    local n_bin=0
    # Names of binaries we just updated. Reused in post_deploy to restart any
    # running instances so users don't keep seeing the OLD binary that was
    # already resident in memory when the update ran. Without this, every
    # update would leave the user "not seeing the fix" until the next reboot
    # or manual pkill — a chronic support issue.
    UPDATED_APP_BINS=()

    # Executables → /usr/local/bin/
    if [[ -d "$stage/bin" ]]; then
        local src dest name
        for src in "$stage"/bin/*; do
            [[ -f "$src" ]] || continue
            name="$(basename "$src")"
            dest="/usr/local/bin/$name"
            if [[ ! -f "$dest" ]] || ! cmp -s "$src" "$dest"; then
                if sudo install -m755 "$src" "$dest" 2>/dev/null; then
                    ((n_bin++)) || true
                    UPDATED_APP_BINS+=("$name")
                else
                    warn "Failed to install $name"
                fi
            fi

            # ── Single-copy invariant ────────────────────────────────────
            # Guarantee ONE canonical binary on the system: /usr/local/bin/$name.
            # Any file at a PATH location that comes BEFORE /usr/local/bin on
            # the effective shell PATH will silently override it — Eww, tray
            # buttons, keybindings, and toggle-scripts using bare `$name` all
            # then launch the OLD binary and the "I updated but nothing changed"
            # trap fires again.
            #
            # We MUST also scrub ~/.local/share/smplos/bin/, even though that
            # dir is normally meant to hold sync_scripts output (bash scripts).
            # Eww inherits its PATH from smplos-start-session, which prepends
            # ~/.local/share/smplos/bin, so any binary that landed there via a
            # historical `deploy-local.sh` cp (or manual copy) silently takes
            # priority over every sync_apps install to /usr/local/bin. This is
            # exactly how ~/.local/share/smplos/bin/smpl-calendar ended up
            # stuck at v0.7.4 while /usr/local/bin was at v0.8.11 — Eww
            # launched the March binary and users saw "the fix did not take".
            #
            # Policy: if a shadow exists and differs, delete it. If it exists
            # and is identical, leave it alone. Non-destructive for devs:
            # deploy-local.sh should install to /usr/local/bin (via sudo)
            # rather than dropping into user-writable PATH dirs.
            local shadow
            for shadow in \
                "$HOME/.local/share/smplos/bin/$name" \
                "$HOME/.local/bin/$name" \
                "$HOME/bin/$name"
            do
                [[ -e "$shadow" || -L "$shadow" ]] || continue
                if [[ -L "$shadow" ]]; then
                    local target
                    target=$(readlink -f "$shadow" 2>/dev/null || echo "")
                    if [[ "$target" == "$dest" ]]; then
                        continue
                    fi
                    rm -f "$shadow" 2>/dev/null && \
                        warn "  removed stale symlink shadow: $shadow -> $target"
                elif cmp -s "$shadow" "$dest" 2>/dev/null; then
                    continue
                else
                    rm -f "$shadow" 2>/dev/null && \
                        warn "  removed stale shadow binary: $shadow (was overriding $dest on \$PATH)"
                fi
            done
        done
    fi

    # NOTE: compositor plugins (*.so) are intentionally NOT installed here.
    # They are ABI-locked to the exact hyprland version, which is frozen by the
    # critical-package hold and only moves via a critical bundle. Installing
    # the latest plugin build here — while hyprland stays pinned to an older
    # version — would break the plugin (ABI mismatch). Any future compositor
    # plugin is therefore installed by smplos-update right after the critical
    # bundle sets hyprland to its pinned version.

    if [[ $n_bin -gt 0 ]]; then
        ok "$n_bin app binary/binaries updated"
        # Signal post_deploy so it runs restart_updated_apps even when git
        # pull was a no-op (org repos update independently from smplos).
        APPS_CHANGED=1
        rebuild-app-cache 2>/dev/null && ok "App cache rebuilt" || true
    else
        ok "smpl-os apps already current"
    fi
}

# ── Run migrations ────────────────────────────────────────────────────────────
run_migrations() {
    if command -v smplos-migrate &>/dev/null; then
        header ""
        header "── Migrations ──"
        # Run as the invoker so:
        #  (a) migration marker files under ~/.local/state/smplos/migrations/
        #      stay user-owned (else the user can never clear them without sudo),
        #  (b) migrations touching ~/.config/*, WAYLAND_DISPLAY-scoped tools
        #      (hyprctl, systemctl --user), and other user-context work run
        #      in the right context.
        # Migrations that legitimately need root should `sudo` internally.
        if [[ $EUID -eq 0 && -n "${SMPLOS_INVOKER_USER:-}" ]]; then
            runuser -u "$SMPLOS_INVOKER_USER" -- env SMPLOS_PATH="$SMPLOS_PATH" smplos-migrate
        else
            SMPLOS_PATH="$SMPLOS_PATH" smplos-migrate
        fi
    fi
}

# ── Sync smplOS version ───────────────────────────────────────────────────────
sync_version() {
    local version_file="$SMPLOS_REPO/src/VERSION"
    [[ -f "$version_file" ]] || return

    local new_ver
    new_ver=$(tr -d '[:space:]' < "$version_file")
    [[ -z "$new_ver" ]] && return

    # Update /etc/os-release so fastfetch, smplos-settings about, etc. show the correct version
    if [[ -f /etc/os-release ]]; then
        local current_ver
        current_ver=$(grep '^VERSION_ID=' /etc/os-release 2>/dev/null | cut -d'=' -f2 | tr -d '"')
        if [[ "$current_ver" != "$new_ver" ]]; then
            local os_release_template="$SMPLOS_REPO/src/shared/system/os-release"
            if [[ -f "$os_release_template" ]]; then
                sudo sed "s/@BUILD_VERSION@/${new_ver}/g" "$os_release_template" \
                    | sudo tee /etc/os-release > /dev/null 2>&1 \
                    && ok "smplOS version: $current_ver -> $new_ver" \
                    || warn "Failed to update /etc/os-release"
            fi
        fi
    fi
}

# ── Sync Hyprland compositor configs ─────────────────────────────────────────
# Syncs every .conf and .lua file from the repo's hypr directory into
# ~/.config/hypr, skipping files that are user-generated or tool-written.
# This automatically picks up new files added to the repo without needing
# a hardcoded list — same model as sync_scripts.
sync_hypr_configs() {
    local hypr_repo="$SMPLOS_REPO/src/compositors/hyprland/hypr"
    local hypr_dst="$HOME/.config/hypr"
    [[ -d "$hypr_repo" ]] || return 0

    header ""
    header "── Syncing Hyprland configs ──"

    # Files owned by the user or generated by smplOS tools at runtime.
    # These are NEVER overwritten — they hold per-machine state.
    local protected=(
        monitors.conf           # written by Settings → Display
        bindings.conf           # written by Settings → Keyboard / user
        messenger-bindings.conf # generated by generate-messenger-bindings
        theme.conf              # generated by theme-set (colors)
        hyprlock-theme.conf     # generated by theme-set
    )

    _is_protected() {
        local name="$1"
        for p in "${protected[@]}"; do
            [[ "$name" == "$p" ]] && return 0
        done
        return 1
    }

    mkdir -p "$hypr_dst"
    local n_updated=0 n_new=0 n_total=0

    # Top-level .conf and .lua files
    for src in "$hypr_repo"/*.conf "$hypr_repo"/*.lua; do
        [[ -f "$src" ]] || continue
        local name; name=$(basename "$src")
        _is_protected "$name" && continue
        ((n_total++)) || true
        local dst="$hypr_dst/$name"
        if [[ ! -f "$dst" ]]; then
            cp "$src" "$dst"
            ((n_new++)) || true
            log "  + $name (new)"
        elif ! cmp -s "$src" "$dst"; then
            cp "$src" "$dst"
            ((n_updated++)) || true
        fi
    done

    # apps/ subdirectory — all files, none protected
    if [[ -d "$hypr_repo/apps" ]]; then
        mkdir -p "$hypr_dst/apps"
        for src in "$hypr_repo/apps"/*; do
            [[ -f "$src" ]] || continue
            local name; name=$(basename "$src")
            ((n_total++)) || true
            local dst="$hypr_dst/apps/$name"
            if [[ ! -f "$dst" ]]; then
                cp "$src" "$dst"
                ((n_new++)) || true
                log "  + apps/$name (new)"
            elif ! cmp -s "$src" "$dst"; then
                cp "$src" "$dst"
                ((n_updated++)) || true
            fi
        done
    fi

    if [[ $((n_new + n_updated)) -gt 0 ]]; then
        ok "$n_updated config(s) updated, $n_new new config(s) synced ($n_total total)"
        # Signal to main() that Hyprland must be reloaded even if the git pull
        # was a no-op (e.g. previous run pulled but crashed before reload, or
        # ~/.config/hypr drifted from repo and this sync restored it).
        HYPR_CONFIGS_CHANGED=1
    else
        ok "All $n_total Hyprland configs are current"
    fi
}

# ── Cleanup shadow binaries on PATH ───────────────────────────────────────────
# Blanket sweep of the three legacy user-writable PATH dirs that show up ahead
# of /usr/local/bin in envs.conf. For every entry we find, if the same basename
# exists in /usr/local/bin, the shadow is unconditionally removed — the entire
# reason we're here is that "shadow wins on PATH" turned every partial install
# into a permanent stale-binary trap (Eww's smpl-calendar pinned at v0.7.4
# while /usr/local/bin/smpl-calendar was v0.8.11 is the canonical example).
#
# Policy:
#   * symlink under a shadow dir       -> delete (it's routing PATH to somewhere
#                                          we don't control; noisy report)
#   * regular file, canonical exists   -> delete (canonical is authoritative
#                                          regardless of whether content matches)
#   * regular file, no canonical       -> keep (it's a user script we didn't
#                                          put there and don't manage)
#
# This runs on every update, unconditionally — a few hundred stat calls per
# run is a rounding error compared to the pacman transaction, and doing it
# every time is what makes the invariant self-healing.
cleanup_shadow_bins() {
    header ""
    header "── Scrubbing shadow \$PATH binaries ──"

    local shadow_dirs=(
        "$HOME/.local/share/smplos/bin"
        "$HOME/.local/bin"
        "$HOME/bin"
    )

    local n_removed=0 n_kept=0
    local dir entry name canonical target
    for dir in "${shadow_dirs[@]}"; do
        [[ -d "$dir" ]] || continue
        # Include hidden files defensively, but there shouldn't be any.
        shopt -s nullglob dotglob
        for entry in "$dir"/*; do
            # Skip subdirectories — we only manage executables at the top level.
            [[ -d "$entry" && ! -L "$entry" ]] && continue

            name=$(basename "$entry")
            canonical="/usr/local/bin/$name"

            if [[ -L "$entry" ]]; then
                target=$(readlink -f "$entry" 2>/dev/null || echo "?")
                if rm -f "$entry" 2>/dev/null; then
                    warn "  removed symlink shadow: $entry -> $target"
                    ((n_removed++)) || true
                fi
                continue
            fi

            if [[ -f "$canonical" ]]; then
                # Canonical exists — shadow is by definition unwanted.
                if cmp -s "$entry" "$canonical" 2>/dev/null; then
                    if rm -f "$entry" 2>/dev/null; then
                        log "  removed duplicate: $entry (matches canonical)"
                        ((n_removed++)) || true
                    fi
                else
                    if rm -f "$entry" 2>/dev/null; then
                        warn "  removed STALE shadow: $entry (was overriding $canonical on \$PATH)"
                        ((n_removed++)) || true
                    fi
                fi
            else
                # No canonical /usr/local/bin/<name> — this is a user script
                # or something we didn't install. Leave it alone.
                ((n_kept++)) || true
            fi
        done
        shopt -u nullglob dotglob
    done

    if [[ $n_removed -gt 0 ]]; then
        ok "Removed $n_removed shadow entrie(s); left $n_kept unmanaged entry(ies) alone"
    else
        ok "No shadow binaries found (kept $n_kept unmanaged entry(ies))"
    fi
}

# ── Post-deploy hooks ─────────────────────────────────────────────────────────

# Kill any running instance of a smpl-os app whose binary we just replaced,
# so the user's NEXT interaction (tray click, keybinding) respawns from the
# fresh binary. Without this, popup apps that were already running when the
# update installed a new binary keep serving stale UI/logic from the resident
# copy in memory — the "I updated but the fix didn't take" trap that's bitten
# us on every release. SIGTERM is safe: these are ephemeral popups; if the
# binary was launched from a stale shadow path (e.g. ~/.local/bin) we surface
# that too so the user knows why the update wouldn't stick.
restart_updated_apps() {
    [[ ${#UPDATED_APP_BINS[@]} -eq 0 ]] && return 0

    local name canonical shadow shadow_paths=("$HOME/.local/bin" "$HOME/bin")
    local killed=0 shadowed=()

    for name in "${UPDATED_APP_BINS[@]}"; do
        canonical="/usr/local/bin/$name"

        # Warn about shadow copies BEFORE killing — restarting a shadowed app
        # would just relaunch the stale binary and the user would still not
        # see the fix. This is the dev-machine "deploy-local.sh installed to
        # ~/.local/bin and now $PATH prefers it forever" trap.
        for sp in "${shadow_paths[@]}"; do
            shadow="$sp/$name"
            if [[ -f "$shadow" ]] && ! cmp -s "$canonical" "$shadow" 2>/dev/null; then
                shadowed+=("$shadow")
            fi
        done

        # Match the exact resolved binary path, not just process name — a
        # random script called "smpl-calendar" shouldn't get killed. -f/-a
        # matches the full command line; we scope it to /usr/local/bin/NAME
        # and any known shadow paths so we catch every instance of the app
        # that we actually shipped.
        local pids
        pids=$(pgrep -f "(/usr/local/bin/${name}|/\.local/bin/${name}|/home/[^ /]+/bin/${name})( |$)" 2>/dev/null || true)
        if [[ -n "$pids" ]]; then
            # shellcheck disable=SC2086
            kill -TERM $pids 2>/dev/null || true
            ((killed++)) || true
            log "  restarted: $name (pid $(echo "$pids" | tr '\n' ' '))"
        fi
    done

    if [[ $killed -gt 0 ]]; then
        ok "$killed running app(s) sent SIGTERM — next launch uses the new binary"
    fi

    if [[ ${#shadowed[@]} -gt 0 ]]; then
        warn "Shadow binaries detected (these override /usr/local/bin on \$PATH):"
        for shadow in "${shadowed[@]}"; do
            warn "  $shadow  <- will keep serving OLD code until you delete or refresh it"
        done
        warn "  Fix: rm the shadow copies, or run deploy-local.sh to rebuild them from source."
    fi
}

post_deploy() {
    sync_version

    local current_theme
    current_theme=$(theme-current 2>/dev/null || echo "catppuccin")
    log "Reapplying theme ($current_theme)..."
    theme-set "$current_theme" 2>/dev/null || warn "theme-set failed"

    # Restart updated app binaries BEFORE reloading Hyprland — if any restarted
    # app also had a windowrule change, the reload below picks that up too and
    # the app's next spawn gets the fresh rules from the start.
    restart_updated_apps

    if hyprctl version &>/dev/null 2>&1; then
        log "Reloading Hyprland config..."
        hyprctl reload 2>/dev/null || true
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
if [[ $CHECK_ONLY -eq 1 ]]; then
    check_updates
    exit $?
fi

if [[ $MIGRATE_ONLY -eq 1 ]]; then
    run_migrations
    exit 0
fi

had_updates=0
HYPR_CONFIGS_CHANGED=0
APPS_CHANGED=0
# Populated by sync_apps with the basename of every binary it just replaced,
# consumed by restart_updated_apps in post_deploy. Declared here so nounset
# doesn't trip when sync_apps is skipped (e.g. --scripts) or is a no-op.
UPDATED_APP_BINS=()
if pull_updates; then
    had_updates=1
fi

if [[ $SCRIPTS_ONLY -eq 0 ]]; then
    sync_scripts

    # ── Self-reexec if this script just got updated ──────────────────────
    # If we were launched from the old /usr/local/bin/smplos-os-update and
    # sync_scripts just installed a newer copy on top, keep running the OLD
    # in-memory logic would defeat the point — every subsequent sync_apps,
    # sync_hypr_configs, restart_updated_apps improvement would only take
    # effect on the NEXT invocation. Detect the version drift, then re-exec
    # into the fresh copy with a sentinel env var so we don't loop.
    if [[ "$SELF_UPDATED" != "1" ]] && [[ -x "$SELF_CANONICAL" ]] \
        && ! cmp -s "$SELF_PATH" "$SELF_CANONICAL" 2>/dev/null; then
        header ""
        warn "smplos-os-update itself was refreshed — re-executing to pick up new logic"
        # Preserve --quiet/--scripts intent so behavior is identical to the
        # original invocation. --scripts already returned above so we only
        # forward --quiet here.
        reexec_args=()
        [[ $QUIET -eq 1 ]] && reexec_args+=(--quiet)
        export SMPLOS_OS_UPDATE_RESUMED=1
        exec "$SELF_CANONICAL" "${local_args[@]}"
    fi

    sync_configs
    sync_themes
    sync_apps
    sync_hypr_configs
    run_migrations

    # Unconditional shadow-binary sweep. Runs AFTER sync_apps so we've already
    # deposited the fresh canonical /usr/local/bin/<foo> before deciding whether
    # its shadow is stale. Costs a few hundred stat calls; the payoff is that
    # dev-machine deploy-local.sh drops, hand-copied binaries, and any prior
    # broken update-apps runs all get healed on every OS update.
    cleanup_shadow_bins

    # Reload Hyprland whenever EITHER new commits were pulled OR the hypr
    # config sync wrote anything. The latter catches the case where the git
    # pull was a no-op but ~/.config/hypr had drifted from repo (e.g. a
    # previous run interrupted before reload). Without this, users would need
    # to manually `hyprctl reload` after certain updates — and we've promised
    # them the process is self-contained.
    # Also runs on APPS_CHANGED so restart_updated_apps fires even when only
    # an org-repo binary changed (no smplos commits, no config diff).
    if [[ $had_updates -eq 1 || $HYPR_CONFIGS_CHANGED -eq 1 || $APPS_CHANGED -eq 1 ]]; then
        header ""
        header "── Post-deploy ──"
        post_deploy
    fi
fi

if [[ $SCRIPTS_ONLY -eq 1 ]]; then
    sync_scripts
fi

header ""
ok "smplOS system update complete"

#!/bin/bash
# smplos-os-update — Update smplOS system files via git
#
# Pulls the latest smplOS repo, syncs scripts to /usr/local/bin/,
# and runs pending migrations.
#
# The smplOS repo is cloned to ~/.local/share/smplos/ during installation.
# This script pulls updates and deploys them.
#
# Usage: smplos-os-update [options]
#   --check     Only report whether an update is available
#   --quiet     Suppress per-file output
#   --scripts   Only sync scripts (skip migrations)
#   --migrate   Only run migrations (skip git pull + script sync)

set -euo pipefail

SMPLOS_PATH="${SMPLOS_PATH:-$HOME/.local/share/smplos}"
SMPLOS_REPO="$SMPLOS_PATH/repo"
SMPLOS_REPO_URL="https://github.com/smpl-os/smplos.git"

# ── Argument parsing ──────────────────────────────────────────────────────────
CHECK_ONLY=0; QUIET=0; SCRIPTS_ONLY=0; MIGRATE_ONLY=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --check)     CHECK_ONLY=1 ;;
        --quiet)     QUIET=1 ;;
        --scripts)   SCRIPTS_ONLY=1 ;;
        --migrate)   MIGRATE_ONLY=1 ;;
        -h|--help)
            echo "Usage: smplos-os-update [--check | --quiet | --scripts | --migrate]"
            exit 0 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
    shift
done

# ── Helpers ───────────────────────────────────────────────────────────────────
log()    { [[ $QUIET -eq 0 ]] && echo "  $*" || true; }
ok()     { [[ $QUIET -eq 0 ]] && echo "  ✓ $*" || true; }
warn()   { echo "  ⚠ $*" >&2; }
header() { [[ $QUIET -eq 0 ]] && echo "$*" || true; }
die()    { echo "ERROR: $*" >&2; exit 1; }

# ── Ensure repo exists ───────────────────────────────────────────────────────
ensure_repo() {
    if [[ ! -d "$SMPLOS_REPO/.git" ]]; then
        log "First run: cloning smplOS repo..."
        git clone --depth=1 "$SMPLOS_REPO_URL" "$SMPLOS_REPO" 2>/dev/null \
            || die "Failed to clone smplOS repo"
        ok "Repo cloned to $SMPLOS_REPO"
    fi
}

# ── Git pull ──────────────────────────────────────────────────────────────────
pull_updates() {
    header "── smplOS System Files ──"

    ensure_repo

    local before after
    before=$(git -C "$SMPLOS_REPO" rev-parse HEAD 2>/dev/null || echo "unknown")

    log "Checking for updates..."
    if ! git -C "$SMPLOS_REPO" pull --autostash --rebase 2>/dev/null; then
        warn "Git pull failed, attempting reset..."
        git -C "$SMPLOS_REPO" reset --hard origin/main 2>/dev/null \
            || git -C "$SMPLOS_REPO" reset --hard origin/master 2>/dev/null \
            || die "Git pull and reset both failed"
    fi

    after=$(git -C "$SMPLOS_REPO" rev-parse HEAD 2>/dev/null || echo "unknown")

    if [[ "$before" == "$after" ]]; then
        ok "Already up to date"
        return 1  # no updates
    fi

    # Show what changed
    local n_changes
    n_changes=$(git -C "$SMPLOS_REPO" diff --stat "$before" "$after" 2>/dev/null \
        | tail -1 || echo "")
    [[ -n "$n_changes" ]] && log "$n_changes"
    return 0  # had updates
}

# ── Check only ────────────────────────────────────────────────────────────────
check_updates() {
    ensure_repo

    git -C "$SMPLOS_REPO" fetch --quiet 2>/dev/null || { warn "Cannot reach GitHub"; exit 1; }

    local local_head remote_head
    local_head=$(git -C "$SMPLOS_REPO" rev-parse HEAD)
    remote_head=$(git -C "$SMPLOS_REPO" rev-parse @{u} 2>/dev/null || echo "")

    if [[ -z "$remote_head" || "$local_head" == "$remote_head" ]]; then
        echo "  smplOS is up to date"
        exit 1
    else
        local behind
        behind=$(git -C "$SMPLOS_REPO" rev-list --count HEAD..@{u} 2>/dev/null || echo "?")
        echo "  smplOS update available ($behind new commits)"
        exit 0
    fi
}

# ── Sync scripts to /usr/local/bin/ ───────────────────────────────────────────
sync_scripts() {
    local bin_dir="$SMPLOS_REPO/src/shared/bin"
    [[ -d "$bin_dir" ]] || { warn "No scripts directory found at $bin_dir"; return; }

    header ""
    header "── Syncing scripts ──"

    local smplos_bin="$HOME/.local/share/smplos/bin"
    mkdir -p "$smplos_bin"

    local n_updated=0 n_total=0
    for script in "$bin_dir"/*; do
        [[ -f "$script" ]] || continue
        local name dest
        name=$(basename "$script")
        dest="/usr/local/bin/$name"

        ((n_total++)) || true

        # Only copy if changed (compare against the system copy)
        if [[ -f "$dest" ]] && cmp -s "$script" "$dest"; then
            # Still sync to user-local bin in case it's stale
            if [[ -f "$smplos_bin/$name" ]] && ! cmp -s "$script" "$smplos_bin/$name"; then
                install -m755 "$script" "$smplos_bin/$name" 2>/dev/null || true
            fi
            continue
        fi

        if sudo install -m755 "$script" "$dest" 2>/dev/null; then
            ((n_updated++)) || true
        else
            warn "Failed to install $name (sudo required)"
        fi
        # Also update the user-local copy (takes priority in PATH)
        install -m755 "$script" "$smplos_bin/$name" 2>/dev/null || true
    done

    if [[ $n_updated -gt 0 ]]; then
        ok "$n_updated of $n_total scripts updated"
    else
        ok "All $n_total scripts are current"
    fi
}

# ── Sync config files to ~/.config/ ───────────────────────────────────────────
sync_configs() {
    header ""
    header "── Syncing configs ──"

    local n_updated=0

    # EWW configs (eww.yuck, eww.scss, scripts/)
    local eww_src="$SMPLOS_REPO/src/shared/eww"
    local eww_dst="$HOME/.config/eww"
    if [[ -d "$eww_src" ]]; then
        mkdir -p "$eww_dst"
        # Sync core EWW files (but not theme-colors.scss — that's managed by theme-set)
        for f in eww.yuck eww.scss; do
            if [[ -f "$eww_src/$f" ]] && ! cmp -s "$eww_src/$f" "$eww_dst/$f" 2>/dev/null; then
                cp "$eww_src/$f" "$eww_dst/$f"
                ((n_updated++)) || true
            fi
        done
        # Sync scripts directory
        if [[ -d "$eww_src/scripts" ]]; then
            mkdir -p "$eww_dst/scripts"
            for script in "$eww_src/scripts/"*; do
                [[ -f "$script" ]] || continue
                local name
                name=$(basename "$script")
                if ! cmp -s "$script" "$eww_dst/scripts/$name" 2>/dev/null; then
                    cp "$script" "$eww_dst/scripts/$name"
                    chmod +x "$eww_dst/scripts/$name"
                    ((n_updated++)) || true
                fi
            done
        fi
    fi

    # Shared configs (hyprshell, smplos, etc.) — only add new files, don't overwrite user edits
    local configs_src="$SMPLOS_REPO/src/shared/configs"
    if [[ -d "$configs_src" ]]; then
        # Walk each config directory
        while IFS= read -r -d '' src_file; do
            local rel_path="${src_file#$configs_src/}"
            # Skip smplos/ subdir — those are Hyprland-specific configs managed separately
            [[ "$rel_path" == smplos/* ]] && continue
            local dst_file="$HOME/.config/$rel_path"
            if [[ ! -f "$dst_file" ]]; then
                mkdir -p "$(dirname "$dst_file")"
                cp "$src_file" "$dst_file"
                ((n_updated++)) || true
            fi
        done < <(find "$configs_src" -type f -print0)
    fi

    if [[ $n_updated -gt 0 ]]; then
        ok "$n_updated config file(s) updated"
    else
        ok "All configs are current"
    fi
}

# ── Fetch + install latest smpl-apps binaries ────────────────────────────────
sync_apps() {
    local fetch_script="$SMPLOS_REPO/src/fetch-apps.sh"
    [[ -f "$fetch_script" ]] || { warn "fetch-apps.sh not found"; return; }

    header ""
    header "── Updating smpl-apps ──"

    bash "$fetch_script"

    # Install fetched binaries to /usr/local/bin/
    local bin_dir="$SMPLOS_REPO/.cache/app-binaries"
    local n_updated=0
    for bin in start-menu notif-center settings app-center webapp-center \
               sync-center-gui sync-center-daemon smpl-calendar smpl-calendar-alertd; do
        local src="$bin_dir/$bin"
        [[ -x "$src" ]] || continue
        local dest="/usr/local/bin/$bin"
        if [[ ! -f "$dest" ]] || ! cmp -s "$src" "$dest"; then
            if sudo install -m755 "$src" "$dest" 2>/dev/null; then
                ((n_updated++)) || true
            else
                warn "Failed to install $bin"
            fi
        fi
    done

    if [[ $n_updated -gt 0 ]]; then
        ok "$n_updated smpl-apps binary/binaries updated"
        # Rebuild app cache so search keywords reflect the new build
        rebuild-app-cache 2>/dev/null && ok "App cache rebuilt" || true
    else
        ok "smpl-apps already current"
    fi
}

# ── Run migrations ────────────────────────────────────────────────────────────
run_migrations() {
    if command -v smplos-migrate &>/dev/null; then
        header ""
        header "── Migrations ──"
        SMPLOS_PATH="$SMPLOS_PATH" smplos-migrate
    fi
}

# ── Sync smplOS version ───────────────────────────────────────────────────────
sync_version() {
    local version_file="$SMPLOS_REPO/src/VERSION"
    [[ -f "$version_file" ]] || return

    local new_ver
    new_ver=$(tr -d '[:space:]' < "$version_file")
    [[ -z "$new_ver" ]] && return

    # Update /etc/os-release so fastfetch, smplos-settings about, etc. show the correct version
    if [[ -f /etc/os-release ]]; then
        local current_ver
        current_ver=$(grep '^VERSION_ID=' /etc/os-release 2>/dev/null | cut -d'=' -f2 | tr -d '"')
        if [[ "$current_ver" != "$new_ver" ]]; then
            local os_release_template="$SMPLOS_REPO/src/shared/system/os-release"
            if [[ -f "$os_release_template" ]]; then
                sudo sed "s/@BUILD_VERSION@/${new_ver}/g" "$os_release_template" \
                    | sudo tee /etc/os-release > /dev/null 2>&1 \
                    && ok "smplOS version: $current_ver -> $new_ver" \
                    || warn "Failed to update /etc/os-release"
            fi
        fi
    fi
}

# ── Post-deploy hooks ─────────────────────────────────────────────────────────
post_deploy() {
    sync_version

    local current_theme
    current_theme=$(theme-current 2>/dev/null || echo "catppuccin")
    log "Reapplying theme ($current_theme)..."
    theme-set "$current_theme" 2>/dev/null || warn "theme-set failed"

    if hyprctl version &>/dev/null 2>&1; then
        log "Reloading Hyprland config..."
        hyprctl reload 2>/dev/null || true
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
if [[ $CHECK_ONLY -eq 1 ]]; then
    check_updates
    exit $?
fi

if [[ $MIGRATE_ONLY -eq 1 ]]; then
    run_migrations
    exit 0
fi

had_updates=0
if pull_updates; then
    had_updates=1
fi

if [[ $SCRIPTS_ONLY -eq 0 ]]; then
    sync_scripts
    sync_configs
    sync_apps
    run_migrations

    if [[ $had_updates -eq 1 ]]; then
        header ""
        header "── Post-deploy ──"
        post_deploy
    fi
fi

if [[ $SCRIPTS_ONLY -eq 1 ]]; then
    sync_scripts
fi

header ""
ok "smplOS system update complete"

#!/bin/bash
# Install and configure Voxtype for global dictation on smplOS.
# Voxtype runs a local Whisper AI model -- fully offline, no cloud.
# After setup, press SUPER+CTRL+X to start/stop speaking.
#
# Handles both fresh installs and reconfiguration of pre-installed voxtype.

set -e

die() { echo "ERROR: $*" >&2; exit 1; }
log() { echo "  $*"; }

HF_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/huggingface/hub"

# Check if a specific Whisper model is already cached in the HF hub
model_cached() {
    local m="$1"
    local cache_dir="$HF_CACHE/models--Systran--faster-whisper-${m}"
    [[ -d "$cache_dir/snapshots" ]] && \
        find "$cache_dir/snapshots" -name "model.bin" -print -quit 2>/dev/null | grep -q .
}

already_installed=false
if command -v voxtype &>/dev/null; then
    already_installed=true
fi

echo ""
echo "  smplOS Dictation Setup (Voxtype)"
echo "  Local AI speech-to-text -- fully offline, no cloud."
echo ""

if $already_installed; then
    echo "  Voxtype is already installed."
    echo "  This wizard lets you change language or model."
else
    echo "  This will install:"
    echo "    - wtype       (Wayland text injector)"
    echo "    - voxtype-bin (local AI speech daemon)"
    echo "    - A Whisper model (size depends on language choice)"
fi
echo ""
read -r -p "  Continue? [y/N] " ans
[[ "${ans,,}" == "y" ]] || exit 0

# ── Install packages (skip if already installed) ──────────────────────────────
if ! $already_installed; then
    log "Installing wtype and voxtype-bin..."
    if command -v paru &>/dev/null; then
        paru -S --noconfirm --needed wtype voxtype-bin
    elif command -v yay &>/dev/null; then
        yay -S --noconfirm --needed wtype voxtype-bin
    else
        die "No AUR helper found. Install paru first: paru -S paru-bin"
    fi
fi

# ── Language selection ────────────────────────────────────────────────────────
LANG_LIST="English -- fastest, recommended
Auto-detect -- detects from 99 languages automatically
Afrikaans (af)
Albanian (sq)
Amharic (am)
Arabic (ar)
Armenian (hy)
Assamese (as)
Azerbaijani (az)
Bashkir (ba)
Basque (eu)
Belarusian (be)
Bengali (bn)
Bosnian (bs)
Breton (br)
Bulgarian (bg)
Cantonese (yue)
Catalan (ca)
Chinese (zh)
Croatian (hr)
Czech (cs)
Danish (da)
Dutch (nl)
Estonian (et)
Faroese (fo)
Finnish (fi)
French (fr)
Galician (gl)
Georgian (ka)
German (de)
Greek (el)
Gujarati (gu)
Haitian Creole (ht)
Hausa (ha)
Hawaiian (haw)
Hebrew (he)
Hindi (hi)
Hungarian (hu)
Icelandic (is)
Indonesian (id)
Italian (it)
Japanese (ja)
Javanese (jw)
Kannada (kn)
Kazakh (kk)
Khmer (km)
Korean (ko)
Lao (lo)
Latin (la)
Latvian (lv)
Lingala (ln)
Lithuanian (lt)
Luxembourgish (lb)
Macedonian (mk)
Malagasy (mg)
Malay (ms)
Malayalam (ml)
Maltese (mt)
Maori (mi)
Marathi (mr)
Mongolian (mn)
Myanmar (my)
Nepali (ne)
Norwegian (no)
Nynorsk (nn)
Occitan (oc)
Pashto (ps)
Persian (fa)
Polish (pl)
Portuguese (pt)
Punjabi (pa)
Romanian (ro)
Russian (ru)
Sanskrit (sa)
Serbian (sr)
Shona (sn)
Sindhi (sd)
Sinhala (si)
Slovak (sk)
Slovenian (sl)
Somali (so)
Spanish (es)
Sundanese (su)
Swahili (sw)
Swedish (sv)
Tagalog (tl)
Tajik (tg)
Tamil (ta)
Tatar (tt)
Telugu (te)
Thai (th)
Tibetan (bo)
Turkish (tr)
Turkmen (tk)
Ukrainian (uk)
Urdu (ur)
Uzbek (uz)
Vietnamese (vi)
Welsh (cy)
Yiddish (yi)
Yoruba (yo)"

echo ""
choice=$(echo "$LANG_LIST" | gum filter --height 15 \
    --header "  Language (type to search, ESC to cancel)") || exit 0

# Parse choice into config values
model="base"
lang_cfg='language = "auto"'

case "$choice" in
    "English --"*)
        model="base.en"
        lang_cfg='language = "en"'
        ;;
    "Auto-detect --"*)
        model="base"
        lang_cfg='language = "auto"'
        ;;
    *)
        code=$(echo "$choice" | grep -oP '\([a-z]+\)' | tr -d '()')
        [[ -z "$code" ]] && die "Could not parse language code from: $choice"
        model="base"
        echo ""
        read -r -p "  Also add English for auto-switching between both? [Y/n] " ans
        if [[ "${ans,,}" != "n" ]]; then
            lang_cfg="language = [\"en\", \"$code\"]"
        else
            lang_cfg="language = \"$code\""
        fi
        ;;
esac

# ── Write config ──────────────────────────────────────────────────────────────
mkdir -p ~/.config/voxtype
log "Writing config to ~/.config/voxtype/config.toml..."
cat > ~/.config/voxtype/config.toml << TOML
# Voxtype configuration for smplOS
# Docs: https://github.com/peteonrails/voxtype

# Use compositor keybindings (SUPER+CTRL+X) instead of built-in hotkey
[hotkey]
enabled = false

state_file = "auto"

[whisper]
model = "$model"
$lang_cfg

[output]
mode = "type"
fallback_to_clipboard = true
append_text = " "

[output.notification]
on_transcription = true

[audio]
device = "auto"
sample_rate = 16000
max_duration_secs = 60

[audio.feedback]
enabled = true
theme = "default"
TOML

# ── Download model + systemd service ─────────────────────────────────────────
if model_cached "$model"; then
    log "Whisper model ($model) is already cached -- skipping download."
else
    log "Downloading Whisper model ($model)..."
    voxtype setup --download --no-post-install
fi

# Ensure systemd service is set up
if [[ ! -f "$HOME/.config/systemd/user/voxtype.service" ]]; then
    log "Installing systemd user service..."
    voxtype setup systemd 2>/dev/null || true
fi
systemctl --user daemon-reload 2>/dev/null || true
systemctl --user enable voxtype 2>/dev/null || true
systemctl --user restart voxtype 2>/dev/null || true

# Mark as primed so dictation-toggle skips the prime step
mkdir -p "$HOME/.config/smplos"
touch "$HOME/.config/smplos/.dictation-primed"

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
echo "  Dictation is ready!"
echo "  Press SUPER+CTRL+X to start speaking. Press again to stop and type."
if [[ "$model" != "base.en" ]]; then
    echo ""
    echo "  Tip: For better multilingual accuracy, upgrade to large-v3-turbo:"
    echo "       Edit ~/.config/voxtype/config.toml -> model = \"large-v3-turbo\""
    echo "       Then run: voxtype setup --download"
fi
echo ""
notify-send "Dictation ready" \
    "Press Super+Ctrl+X to start/stop speaking.\nVoxtype types into the focused window." \
    -i microphone -u normal -t 8000

#!/bin/bash
# smplOS Hyprland session wrapper
# Called by greetd as the initial_session command.
#
# Delegates to the real start-hyprland binary (/usr/bin/start-hyprland,
# shipped by the hyprland package).
#
# The real binary is a C++ watchdog that:
#   1. Opens a pipe and passes --watchdog-fd <fd> to Hyprland
#   2. Monitors Hyprland and restarts it in safe mode on an unclean exit
# Without it, Hyprland logs: "WARNING: Hyprland is being launched without
# start-hyprland. This is highly advised against." (src/main.cpp)
#
# NOTE (2025): Hyprland >= 0.40 uses the Aquamarine backend, NOT wlroots.
# All WLR_* env vars (WLR_NO_HARDWARE_CURSORS, WLR_RENDERER_ALLOW_SOFTWARE)
# are completely ignored. VM hardware-cursor workaround is now handled via
# `cursor:no_hardware_cursors = 1` in looknfeel.conf.

# exec replaces this process image in the same PID, so greetd keeps tracking
# the correct PID and env vars above are inherited by the child Hyprland.
if [[ -x /usr/bin/start-hyprland ]]; then
    exec /usr/bin/start-hyprland "$@"
fi

# Fallback: real binary not found (shouldn't happen on a normal install).
# Warning will appear in logs but Hyprland will still run.
exec Hyprland "$@"

# Maintainer: smplOS <https://github.com/smplOS>
# Always pulls the latest release from GitHub — no version pinning.
# Source: https://github.com/smpl-os/nemo (release branch)

_gh_owner=smpl-os
_gh_repo=nemo

pkgname=nemo-smpl
pkgver=0
pkgrel=1
pkgdesc='Nemo file manager with smplOS patches (configurable keybindings, preview pane, substring search, MTP support)'
arch=(x86_64)
url="https://github.com/${_gh_owner}/${_gh_repo}"
license=('GPL-3.0-or-later AND LGPL-2.1-or-later')
depends=(
  at-spi2-core
  bash
  cairo
  cinnamon-desktop
  dconf
  exempi
  gcc-libs
  gdk-pixbuf2
  glib2
  glibc
  gtk3
  gvfs
  gvfs-mtp
  hicolor-icon-theme
  json-glib
  libexif
  libx11
  libxmlb
  pango
  python
  python-cairo
  python-gobject
  xapp
  # Preview pane dependencies
  gstreamer
  gst-plugins-base
  gst-plugins-good
  webp-pixbuf-loader
  libraw
)
optdepends=(
  'cinnamon-translations: i18n'
  'ffmpegthumbnailer: video thumbnails'
  'gst-plugins-bad: extra video format support in preview pane'
  'gst-plugins-ugly: extra video format support in preview pane'
)
makedepends=(curl)
provides=(nemo)
conflicts=(nemo)
replaces=(nemo)

# No pinned source — prepare() downloads the latest release dynamically
source=()
sha256sums=()

prepare() {
  # Query GitHub API for the latest release tag
  local api_url="https://api.github.com/repos/${_gh_owner}/${_gh_repo}/releases/latest"
  local latest
  latest=$(curl -fsSL "$api_url" \
           | grep -oP '"tag_name"\s*:\s*"\Kv?[^"]+' \
           | sed 's/^v//')

  if [[ -z "$latest" ]]; then
    echo "ERROR: Could not determine latest nemo-smpl version from GitHub" >&2
    return 1
  fi

  # Persist version for pkgver() and package()
  echo "$latest" > "$srcdir/.pkgver"

  local artifact="nemo-smpl-${latest}-arch-x86_64-rootfs.tar.zst"
  if [[ ! -f "$srcdir/$artifact" ]]; then
    echo "==> Downloading $artifact ..."
    curl -fSL -o "$srcdir/$artifact" \
      "https://github.com/${_gh_owner}/${_gh_repo}/releases/download/v${latest}/$artifact"
  fi
}

pkgver() {
  # Called by makepkg after prepare() — returns the real version
  cat "$srcdir/.pkgver"
}

build() {
  echo "Using pre-built nemo-smpl $(cat "$srcdir/.pkgver") from GitHub Releases"
}

package() {
  cd "$srcdir"
  local ver
  ver=$(cat .pkgver)
  tar -xf "nemo-smpl-${ver}-arch-x86_64-rootfs.tar.zst" -C "$pkgdir"
}

post_install() {
  # Reload udev rules for MTP device access (bundled in package)
  udevadm control --reload-rules 2>/dev/null || true
  udevadm trigger --subsystem-match=usb 2>/dev/null || true
}

# Maintainer: smplOS <https://github.com/smplOS>
# Auto-fetches the latest release from GitHub — no manual version bumps needed.
# Source: https://github.com/KonTy/nemo (release branch)

_gh_owner=KonTy
_gh_repo=nemo

pkgname=nemo-smpl
pkgver=1.4.2
pkgrel=1
pkgdesc='Nemo file manager with smplOS patches (configurable keybindings, preview pane, substring search, MTP support)'
arch=(x86_64)
url="https://github.com/${_gh_owner}/${_gh_repo}"
license=('GPL-3.0-or-later AND LGPL-2.1-or-later')
depends=(
  at-spi2-core
  bash
  cairo
  cinnamon-desktop
  dconf
  exempi
  gcc-libs
  gdk-pixbuf2
  glib2
  glibc
  gtk3
  gvfs
  gvfs-mtp
  hicolor-icon-theme
  json-glib
  libexif
  libx11
  libxmlb
  pango
  python
  python-cairo
  python-gobject
  xapp
  # Preview pane dependencies
  gstreamer
  gst-plugins-base
  gst-plugins-good
  webp-pixbuf-loader
  libraw
)
optdepends=(
  'cinnamon-translations: i18n'
  'ffmpegthumbnailer: video thumbnails'
  'gst-plugins-bad: extra video format support in preview pane'
  'gst-plugins-ugly: extra video format support in preview pane'
)
makedepends=(curl)
provides=(nemo)
conflicts=(nemo)
replaces=(nemo)

# Placeholder — overwritten by _resolve_latest_version() in prepare()
source=("https://github.com/${_gh_owner}/${_gh_repo}/releases/download/v${pkgver}/nemo-smpl-${pkgver}-arch-x86_64-rootfs.tar.zst")
sha256sums=('SKIP')

# Query GitHub API for the latest release tag and update pkgver + source URL.
# Called automatically by makepkg before build().
_resolve_latest_version() {
  local api_url="https://api.github.com/repos/${_gh_owner}/${_gh_repo}/releases/latest"
  local latest
  latest=$(curl -fsSL "$api_url" | grep -oP '"tag_name"\s*:\s*"\Kv?[^"]+' | sed 's/^v//')

  if [[ -z "$latest" ]]; then
    echo "WARNING: Could not query GitHub API — using pkgver=$pkgver"
    return
  fi

  if [[ "$latest" != "$pkgver" ]]; then
    echo "==> Auto-detected latest nemo-smpl release: $latest (PKGBUILD had $pkgver)"
    pkgver="$latest"
    source=("https://github.com/${_gh_owner}/${_gh_repo}/releases/download/v${pkgver}/nemo-smpl-${pkgver}-arch-x86_64-rootfs.tar.zst")
  fi
}

prepare() {
  _resolve_latest_version
  # Re-download if pkgver changed (makepkg caches by filename)
  local artifact="nemo-smpl-${pkgver}-arch-x86_64-rootfs.tar.zst"
  if [[ ! -f "$srcdir/$artifact" ]]; then
    echo "==> Downloading $artifact ..."
    curl -fSL -o "$srcdir/$artifact" \
      "https://github.com/${_gh_owner}/${_gh_repo}/releases/download/v${pkgver}/$artifact"
  fi
}

build() {
  # Pre-built artifact — no compilation needed
  echo "Using pre-built nemo-smpl $pkgver from GitHub Releases"
}

package() {
  cd "$srcdir"
  tar -xf "nemo-smpl-${pkgver}-arch-x86_64-rootfs.tar.zst" -C "$pkgdir"
}

post_install() {
  # Reload udev rules for MTP device access (bundled in package)
  udevadm control --reload-rules 2>/dev/null || true
  udevadm trigger --subsystem-match=usb 2>/dev/null || true
}

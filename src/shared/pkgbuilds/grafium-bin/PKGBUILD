# Maintainer: smplOS <https://github.com/smplOS>
# Grafium (knowledge graph / note-taking GUI). Not in the AUR yet, so smplOS
# repackages the upstream .deb release asset into a native pacman package.
# Always pulls the latest GitHub release — no version pinning.
# Source: https://github.com/KonTy/grafium

_gh_owner=KonTy
_gh_repo=grafium
_appname=Grafium

pkgname=grafium-bin
pkgver=0
pkgrel=1
pkgdesc='Grafium — local-first knowledge graph & note-taking workspace'
arch=(x86_64)
url="https://github.com/${_gh_owner}/${_gh_repo}"
license=('custom')
depends=(webkit2gtk-4.1 gtk3)
makedepends=(curl libarchive)
provides=(grafium)
conflicts=(grafium)
options=('!strip' '!debug')

# No pinned source — prepare() downloads the latest release .deb dynamically
source=()
sha256sums=()

prepare() {
  # Query GitHub API for the latest release tag.
  # Respect PKGVER_OVERRIDE if set by the build system (avoids race with new releases).
  local api_url="https://api.github.com/repos/${_gh_owner}/${_gh_repo}/releases/latest"
  local latest
  if [[ -n "${PKGVER_OVERRIDE:-}" ]]; then
    latest="${PKGVER_OVERRIDE#v}"
    echo "==> Using locked version: $latest"
  else
    latest=$(curl -fsSL "$api_url" \
             | grep -oP '"tag_name"\s*:\s*"\Kv?[^"]+' \
             | sed 's/^v//')
  fi

  if [[ -z "$latest" ]]; then
    echo "ERROR: Could not determine latest grafium version from GitHub" >&2
    return 1
  fi

  # Persist version for pkgver() and package()
  echo "$latest" > "$srcdir/.pkgver"

  local artifact="${_appname}_${latest}_amd64.deb"
  if [[ ! -f "$srcdir/$artifact" ]]; then
    echo "==> Downloading $artifact ..."
    curl -fSL -o "$srcdir/$artifact" \
      "https://github.com/${_gh_owner}/${_gh_repo}/releases/download/v${latest}/$artifact"
  fi
}

pkgver() {
  # Called by makepkg after prepare() — returns the real version
  cat "$srcdir/.pkgver"
}

build() {
  echo "Using pre-built ${_appname} $(cat "$srcdir/.pkgver") from GitHub Releases"
}

package() {
  cd "$srcdir"
  local ver
  ver=$(cat .pkgver)
  # Unpack the Debian archive, then extract its data payload into the package root.
  bsdtar -xf "${_appname}_${ver}_amd64.deb"
  bsdtar -xf data.tar.* -C "$pkgdir"
}

# smplOS Nemo defaults
# Double Commander-inspired keybindings + preview pane settings

[org/nemo/keybindings]
# F5 = Copy to other pane (clears reload-alt)
reload-alt=''
copy-to-other-pane='F5'

# F6 = Move to other pane (clears switch-pane)
switch-pane=''
move-to-other-pane='F6'

# F7 = New Folder
new-folder='F7'

# Insert = New Folder (alternate)
new-folder-alt='Insert'

# F4 = Open with default application
open-default='F4'

# F8 = Move to Trash
trash='F8'

# Delete = Delete permanently (since Trash is on F8)
delete-permanently='Delete'

# Alt+F7 = Search
search='<Alt>F7'

# Ctrl+B = Toggle Sidebar (like VS Code)
show-sidebar='<Control>b'

# F3 = Quick Preview
quick-preview='F3'

# Ctrl+F3 = Toggle Split View (moved from F3)
split-view='<Control>F3'

# Ctrl+Shift+O = Edit Bookmarks (clears open-alternate)
open-alternate=''
edit-bookmarks='<Control><Shift>o'

# Ctrl+D = Add Bookmark
add-bookmark='<Control>d'

# Alt+F1/F2 = Bookmark/Disk picker
bookmark-picker='<Alt>F1'
bookmark-picker-other='<Alt>F2'

[org/nemo/preferences]
# Confirm before moving files to trash (F8 safety)
confirm-move-to-trash=true

# Start with dual-pane view (Double Commander style)
start-with-dual-pane=true

# Show per-pane location labels in dual-pane mode
show-dual-pane-location-labels=true

# Always use list (details) view by default
default-folder-viewer='list-view'

# Child folders inherit the current view from the parent window
inherit-folder-viewer=true

# Ignore per-folder view metadata so every folder uses the setting above
# (prevents Nemo from switching back to icon-view based on past sessions)
ignore-view-metadata=true
